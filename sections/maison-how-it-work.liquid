    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "color_bg_top",
      "label": "Background gradient (top)",
      "default": "#e5eefb"
    },
    {
      "type": "color",
      "id": "color_bg_bottom",
      "label": "Background gradient (bottom)",
      "default": "#fdfcfa"
    },
    {
      "type": "color",
      "id": "color_brand",
      "label": "Accent / badge color",
      "default": "#065BDC"
    },
    {
      "type": "color",
      "id": "color_text_primary",
