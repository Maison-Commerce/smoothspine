          "settings": {
            "tab_label": "Dr. Blane Schilling",
            "title": "Endorsed by Dr. Blane Schilling",
            "description": "<p>We didn't build this alone. We worked with physical therapists and spine specialists to create something that actually makes sense for chronic pain.</p>",
