<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>

<script>
  function initPdpHero_{{ section.id | replace: '-', '_' }}() {
    var section = document.getElementById('shopify-section-{{ section.id }}');
    if (!section) return;

    /* Swiper: Thumbs gallery */
    var thumbsEl = section.querySelector('[data-pdp-thumbs-swiper]');
    var mainEl = section.querySelector('[data-pdp-main-swiper]');
    var thumbsSwiper = null;

    if (thumbsEl) {
      thumbsSwiper = new Swiper(thumbsEl, {
        spaceBetween: 8,
        slidesPerView: 'auto',
        freeMode: true,
        watchSlidesProgress: true
      });
    }

    if (mainEl) {
      new Swiper(mainEl, {
        spaceBetween: 8,
        slidesPerView: 1,
        thumbs: thumbsSwiper ? { swiper: thumbsSwiper } : undefined,
        breakpoints: {
          0: {
            slidesPerView: 'auto'
          },
          1000: {
            slidesPerView: 1
          }
        }
      });
    }

    /* Add to cart: main product + gift products with bundle ID */
    var addBtn = section.querySelector('[data-pdp-add-to-cart]');
    if (addBtn) {
      addBtn.addEventListener('click', function() {
        if (addBtn.classList.contains('is-loading')) return;
        addBtn.classList.add('is-loading');

        var bundleId = 'bundle_' + Date.now() + '_' + Math.random().toString(36).substr(2, 6);
        var items = [];

        /* Main product from product template */
        {% if product and product.selected_or_first_available_variant %}
          items.push({
            id: {{ product.selected_or_first_available_variant.id }},
            quantity: 1,
            properties: {
              '_bundle_id': bundleId,
              '_bundle_role': 'main'
            }
          });
        {% endif %}

        /* Gift products */
        {% for block in section.blocks %}
          {% if block.type == 'gift_item' and block.settings.gift_product != blank %}
            {% assign gp = block.settings.gift_product %}
            {% if gp.available %}
              items.push({
                id: {{ gp.first_available_variant.id }},
                quantity: 1,
                properties: {
                  '_bundle_id': bundleId,
                  '_bundle_role': 'gift'
                }
              });
            {% endif %}
          {% endif %}
        {% endfor %}

        if (items.length === 0) {
          addBtn.classList.remove('is-loading');
          return;
        }

        console.log('[PDP Bundle] Adding items:', JSON.stringify(items, null, 2));

        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: items })
        })
        .then(function(res) { return res.json(); })
        .then(function(data) {
          console.log('[PDP Bundle] Add response:', JSON.stringify(data, null, 2));
          return fetch('/cart.js');
        })
        .then(function(res) { return res.json(); })
        .then(function(cart) {
          console.log('[PDP Bundle] Full cart items:', cart.items.map(function(i) { return { title: i.title, properties: i.properties, qty: i.quantity }; }));
          addBtn.classList.remove('is-loading');
          var cartDrawer = document.getElementById('cart-drawer');
          if (cartDrawer) {
            cartDrawer.setAttribute('open', '');
            document.dispatchEvent(new CustomEvent('cart:refresh'));
          } else {
            window.location.href = '/cart';
          }
        })
        .catch(function() {
          addBtn.classList.remove('is-loading');
          window.location.href = '/cart';
        });
      });
    }

    /* Remove gift items when main bundle product is removed */
    var _isCleaningBundle = false;

    document.documentElement.addEventListener('cart:change', function(e) {
      console.log('[PDP Bundle] cart:change fired', e.detail);
      if (_isCleaningBundle) return;
      var cart = e.detail && e.detail.cart;
      console.log('[PDP Bundle] cart object:', cart);
      console.log('[PDP Bundle] cart items:', cart && cart.items);
      if (!cart || !cart.items) {
        console.log('[PDP Bundle] No cart.items, skipping');
        return;
      }

      var bundleIds = {};
      cart.items.forEach(function(item) {
        if (item.properties && item.properties._bundle_id) {
          var bid = item.properties._bundle_id;
          if (!bundleIds[bid]) bundleIds[bid] = { main: false, giftKeys: [] };
          if (item.properties._bundle_role === 'main') {
            bundleIds[bid].main = true;
          } else if (item.properties._bundle_role === 'gift') {
            bundleIds[bid].giftKeys.push(item.key);
          }
        }
      });

      var keysToRemove = {};
      Object.keys(bundleIds).forEach(function(bid) {
        if (!bundleIds[bid].main && bundleIds[bid].giftKeys.length > 0) {
          bundleIds[bid].giftKeys.forEach(function(key) {
            keysToRemove[key] = 0;
          });
        }
      });

      if (Object.keys(keysToRemove).length > 0) {
        _isCleaningBundle = true;
        var giftKeys = Object.keys(keysToRemove);

        /* Get cart drawer section ID for bundled section rendering */
        var cartDrawer = document.querySelector('cart-drawer');
        var sectionId = '';
        if (cartDrawer) {
          var shopifySection = cartDrawer.closest('.shopify-section');
          if (shopifySection) sectionId = shopifySection.id.replace('shopify-section-', '');
        }

        /* Remove gifts one by one using the same method as the theme */
        var lastResponse = null;
        var chain = Promise.resolve();
        giftKeys.forEach(function(key) {
          chain = chain.then(function() {
            var body = { id: key, quantity: 0 };
            if (sectionId) body.sections = sectionId;
            return fetch('/cart/change.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(body)
            }).then(function(res) { return res.json(); }).then(function(data) {
              lastResponse = data;
            });
          });
        });

        chain.then(function() {
          _isCleaningBundle = false;
          /* Dispatch cart:change exactly like the theme does — this triggers the drawer to update */
          if (lastResponse) {
            document.documentElement.dispatchEvent(new CustomEvent('cart:change', {
              bubbles: true,
              detail: {
                baseEvent: 'line-item:change',
                cart: lastResponse
              }
            }));
          }
        }).catch(function() { _isCleaningBundle = false; });
      }
    });
  }

  if (typeof Swiper !== 'undefined') {
    initPdpHero_{{ section.id | replace: '-', '_' }}();
  } else {
    document.addEventListener('DOMContentLoaded', function() {
      initPdpHero_{{ section.id | replace: '-', '_' }}();
    });
  }
</script>

