                    <span>{{ section.settings.verified_text }}</span>
                  </div>
                {% endif %}
              </div>
            </div>
          </article>
        {% endif %}
      {% endfor %}
    </div>

    {%- comment -%} Mobile swiper {%- endcomment -%}
    <div class="reviews-container reviews-swiper-wrapper">
      <div class="swiper reviews-swiper-{{ section.id }}">
        <div class="swiper-wrapper">
          {% for block in section.blocks %}
            {% if block.type == 'review_card' %}
              <div class="swiper-slide">
                <article class="review-card" {{ block.shopify_attributes }}>
                  {% if block.settings.image != blank %}
                    {{ block.settings.image | image_url: width: 560 | image_tag:
                      class: 'review-card-image',
                      loading: 'lazy',
                      widths: '280, 420, 560',
                      sizes: '280px'
                    }}
                  {% else %}
                    <div class="review-card-placeholder">
                      {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                    </div>
                  {% endif %}
                  <div class="review-card-body">
                    <div class="review-stars">
                      {% for i in (1..block.settings.rating) %}
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none"><rect width="16" height="16" fill="#00B67A"/><path d="M8 11.1509L10.6071 10.4528L11.6964 14L8 11.1509ZM14 6.56604H9.41071L8 2L6.58929 6.56604H2L5.71429 9.39623L4.30357 13.9623L8.01786 11.1321L10.3036 9.39623L14 6.56604Z" fill="white"/></svg>
                      {% endfor %}
                    </div>
                    {% if block.settings.title != blank %}
                      <h3 class="review-title">{{ block.settings.title }}</h3>
                    {% endif %}
                    {% if block.settings.quote != blank %}
                      <p class="review-text">{{ block.settings.quote }}</p>
                    {% endif %}
                    <div class="review-meta">
                      {% if block.settings.author != blank %}
                        <span class="review-author">{{ block.settings.author }}</span>
                      {% endif %}
                      {% if block.settings.show_verified %}
                        <div class="review-verified">
                          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none"><g clip-path="url(#rv-verified-m-{{ block.id }})"><path fill-rule="evenodd" clip-rule="evenodd" d="M6.84687 0.422743C7.50338 -0.141185 8.47232 -0.140794 9.12851 0.423196C9.37005 0.630789 9.6083 0.838566 9.8436 1.04685C10.1567 0.983031 10.472 0.921248 10.7899 0.861387C11.6405 0.70127 12.4794 1.18608 12.7657 2.00261C12.8711 2.30314 12.9735 2.60222 13.0731 2.90025C13.3761 3.0015 13.6801 3.10563 13.9854 3.21278C14.8019 3.49937 15.2862 4.3387 15.1258 5.18897C15.0655 5.50886 15.0033 5.82587 14.9391 6.1405C15.1521 6.38097 15.3646 6.62451 15.5768 6.87149C16.1408 7.52768 16.1411 8.49662 15.5773 9.15313C15.3664 9.39862 15.1552 9.64083 14.9433 9.88008C15.0061 10.188 15.0669 10.4982 15.1259 10.8111C15.2863 11.6614 14.8021 12.5007 13.9855 12.7873C13.6801 12.8945 13.3761 12.9986 13.073 13.0999C12.9734 13.3979 12.871 13.697 12.7656 13.9975C12.4793 14.8141 11.6403 15.2989 10.7898 15.1387C10.4788 15.0801 10.1704 15.0198 9.86415 14.9575C9.63008 15.1646 9.39318 15.3711 9.15313 15.5773C8.49662 16.1411 7.52767 16.1408 6.87149 15.5768C6.62998 15.3693 6.39175 15.1615 6.15647 14.9533C5.84335 15.017 5.52799 15.0789 5.20995 15.1387C4.35943 15.2989 3.52049 14.8141 3.23422 13.9975C3.12885 13.697 3.02641 13.3979 2.92679 13.0999C2.62369 12.9986 2.31968 12.8945 2.0143 12.7873C1.19767 12.5007 0.713537 11.6614 0.873872 10.8111C0.934217 10.4911 0.996441 10.174 1.06067 9.85921C0.847755 9.61883 0.635379 9.37538 0.423195 9.12851C-0.140793 8.47232 -0.141185 7.50338 0.422742 6.84687C0.63357 6.60143 0.844727 6.35926 1.05653 6.12006C0.993801 5.81215 0.932989 5.50193 0.873976 5.18897C0.713643 4.3387 1.19777 3.49937 2.01441 3.21278C2.3197 3.10563 2.62363 3.0015 2.92665 2.90025C3.02629 2.60222 3.12873 2.30314 3.23411 2.00261C3.52039 1.18608 4.35933 0.701269 5.20985 0.861387C5.52089 0.919943 5.82937 0.980338 6.13569 1.04268C6.36982 0.835525 6.60678 0.628976 6.84687 0.422743ZM10.8616 6.34914C11.2122 6.03109 11.2386 5.48902 10.9206 5.1384C10.6025 4.78777 10.0604 4.76138 9.70982 5.07944C8.86921 5.84199 8.22869 6.53552 7.68647 7.38183C7.34702 7.91166 7.05533 8.48701 6.77625 9.1553L5.89491 8.24644C5.56537 7.90658 5.02272 7.89824 4.68288 8.22778C4.34304 8.55734 4.33469 9.09998 4.66423 9.43983L6.48465 11.3171C6.69168 11.5306 6.99457 11.6216 7.28496 11.5574C7.57535 11.4933 7.81171 11.2831 7.90949 11.0022C8.32745 9.80161 8.69395 8.98709 9.12992 8.30662C9.56249 7.63144 10.0865 7.05226 10.8616 6.34914Z" fill="#065BDC"/></g><defs><clipPath id="rv-verified-m-{{ block.id }}"><rect width="16" height="16" fill="white"/></clipPath></defs></svg>
                          <span>{{ section.settings.verified_text }}</span>
                        </div>
                      {% endif %}
                    </div>
                  </div>
                </article>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  {% endif %}
</section>

{% if section.blocks.size > 0 %}
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" media="(max-width: 949px)">
  <script>
    (function() {
      var sectionId = '{{ section.id }}';
      function initSwiper() {
        if (window.innerWidth <= 949 && typeof Swiper !== 'undefined') {
          new Swiper('.reviews-swiper-' + sectionId, {
            slidesPerView: 'auto',
            spaceBetween: {{ section.settings.mobile_swiper_gap }},
            centeredSlides: false,
          });
        }
      }
      if (typeof Swiper === 'undefined') {
        var script = document.createElement('script');
        script.src = 'https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js';
        script.onload = initSwiper;
        document.head.appendChild(script);
      } else {
        initSwiper();
      }
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "Customer Reviews",
  "tag": "section",
  "class": "customer-reviews-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Heading accent line",
      "default": "Real Users"
    },
    {
      "type": "text",
      "id": "heading_dark",
      "label": "Heading main line",
      "default": "Real Life-Changing Results"
    },
    {
      "type": "text",
      "id": "verified_text",
      "label": "Verified badge text",
      "default": "Verified Purchase"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "color_bg_start",
      "label": "Background gradient start",
      "default": "#fdfcfa"
    },
    {
      "type": "color",
      "id": "color_bg_end",
      "label": "Background gradient end",
      "default": "#e5eefb"
    },
    {
      "type": "color",
      "id": "color_brand",
      "label": "Heading accent color",
      "default": "#065BDC"
    },
    {
      "type": "color",
      "id": "color_primary",
      "label": "Primary text color",
      "default": "#102A43"
    },
    {
      "type": "color",
      "id": "color_secondary",
      "label": "Secondary text color",
      "default": "#102A43"
    },
    {
      "type": "color",
      "id": "color_card_bg",
      "label": "Card background",
      "default": "#FFFFFC"
    },
    {
      "type": "color",
