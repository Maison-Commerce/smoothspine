        "ggNGKLJM3mV_text": "<p><a href=\"https://smoothspine.com/policies/privacy-policy\">Privacy Policy</a> <a href=\"https://smoothspine.com/policies/terms-of-service\">Terms of Service</a> <a href=\"https://smoothspine.com/policies/refund-policy\">Return Policy</a></p>",
