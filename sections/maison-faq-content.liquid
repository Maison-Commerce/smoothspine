{% comment %}
  Section: FAQ Accordion
  Description: Two-column FAQ layout with a heading on the left and an
    accordion of expandable question/answer items on the right.
    Responsive: stacks vertically on mobile. Ideal for product pages,
    landing pages, or support sections.

  Dependencies:
  - Font: 'Plus Jakarta Sans' (heading), 'Open Sans' (body) — must be loaded by the theme or replaced via font_picker

  Blocks:
  - faq_item: Individual FAQ with question and answer (limit: 20)

  Notes:
  - Accordion uses vanilla JavaScript for open/close toggling (no external libraries)
  - Only one item can be open at a time; clicking an open item closes it
  - Arrow icon rotates 180deg when item is expanded
  - All colors, typography, spacing, and layout values are merchant-configurable
  - Original source class prefix: maisoncode_faq-content
{% endcomment %}

{% style %}
  #shopify-section-{{ section.id }} .maisoncode_faq-content {
    --s-color-bg: {{ section.settings.color_background }};
    --s-color-heading: {{ section.settings.color_heading }};
    --s-color-text: {{ section.settings.color_text }};
    {%- assign border_alpha = section.settings.border_opacity | divided_by: 100.0 -%}
    --s-color-border: {{ section.settings.color_border | color_modify: 'alpha', border_alpha }};
    --s-font-size-heading: {{ section.settings.heading_font_size }}px;
    --s-font-size-question: {{ section.settings.question_font_size }}px;
    --s-font-size-answer: {{ section.settings.answer_font_size }}px;
    --s-answer-opacity: {{ section.settings.answer_opacity | divided_by: 100.0 }};
    --s-padding-x: {{ section.settings.padding_horizontal }}px;
    --s-padding-y: {{ section.settings.padding_vertical }}px;
    --s-gap: {{ section.settings.column_gap }}px;
    --s-max-width: {{ section.settings.max_width }}px;
    --s-arrow-size: {{ section.settings.arrow_size }}px;

    font-family: 'Open Sans', sans-serif;
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    background-color: var(--s-color-bg);
    width: 100%;
    overflow: clip;
  }

  #shopify-section-{{ section.id }} .maisoncode_faq-content *,
  #shopify-section-{{ section.id }} .maisoncode_faq-content *::before,
  #shopify-section-{{ section.id }} .maisoncode_faq-content *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  #shopify-section-{{ section.id }} .faq-inner {
    max-width: var(--s-max-width);
    margin: 0 auto;
    display: flex;
    gap: var(--s-gap);
    align-items: flex-start;
    justify-content: center;
    padding: var(--s-padding-y) var(--s-padding-x);
  }

  #shopify-section-{{ section.id }} .faq-title {
    flex: 1;
    max-width: 100%;
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .faq-title h2 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 800;
    font-size: var(--s-font-size-heading);
    line-height: 1.5;
    color: var(--s-color-heading);
    text-transform: capitalize;
  }

  #shopify-section-{{ section.id }} .faq-accordion {
    flex: 1 0 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: stretch;
  }

  #shopify-section-{{ section.id }} .faq-item {
    width: 100%;
  }

  #shopify-section-{{ section.id }} .faq-item + .faq-item {
    border-top: 1px solid var(--s-color-border);
  }

  #shopify-section-{{ section.id }} .faq-question {
    display: flex;
    gap: 24px;
    align-items: center;
    padding: 20px 0;
    cursor: pointer;
    width: 100%;
    background: none;
    border: none;
    text-align: left;
    font-family: 'Open Sans', sans-serif;
    font-weight: 600;
    font-size: var(--s-font-size-question);
    line-height: 1.5;
    color: var(--s-color-text);
    text-transform: capitalize;
  }

  #shopify-section-{{ section.id }} .faq-question:focus {
    outline: none;
  }

  #shopify-section-{{ section.id }} .faq-question:focus-visible {
    outline: 2px solid var(--s-color-heading);
    outline-offset: 2px;
    border-radius: 4px;
  }

  #shopify-section-{{ section.id }} .faq-question span {
    flex: 1;
  }

  #shopify-section-{{ section.id }} .faq-arrow {
    width: var(--s-arrow-size);
    height: var(--s-arrow-size);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease;
  }

  #shopify-section-{{ section.id }} .faq-arrow.is-open {
    transform: rotate(180deg);
  }

  #shopify-section-{{ section.id }} .faq-arrow svg {
    width: 100%;
    height: 100%;
  }

  #shopify-section-{{ section.id }} .faq-answer {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition: max-height 0.35s ease, opacity 0.3s ease;
  }

  #shopify-section-{{ section.id }} .faq-answer.is-open {
    opacity: 1;
  }

  #shopify-section-{{ section.id }} .faq-answer-inner {
    padding-bottom: 20px;
    font-family: 'Open Sans', sans-serif;
    font-weight: 400;
    font-size: var(--s-font-size-answer);
    line-height: 1.7;
    color: var(--s-color-text);
    opacity: var(--s-answer-opacity);
  }

  @media (max-width: 767px) {
    #shopify-section-{{ section.id }} .maisoncode_faq-content {
      --s-padding-x: {{ section.settings.padding_horizontal_mobile }}px;
      --s-padding-y: {{ section.settings.padding_vertical_mobile }}px;
      --s-font-size-heading: {{ section.settings.heading_font_size_mobile }}px;
      --s-font-size-question: {{ section.settings.question_font_size_mobile }}px;
    }

    #shopify-section-{{ section.id }} .faq-inner {
      flex-direction: column;
      gap: 24px;
    }

    #shopify-section-{{ section.id }} .faq-title {
      width: 100%;
    }

    #shopify-section-{{ section.id }} .faq-title h2 {
      line-height: 1.4;
      text-align: center;
    }

    #shopify-section-{{ section.id }} .faq-question {
      gap: 16px;
      text-transform: none;
    }
  }
{% endstyle %}

<section class="maisoncode_faq-content">
  <div class="faq-inner">

    {%- comment -%} Left Column: Heading {%- endcomment -%}
    {% if section.settings.heading != blank %}
      <div class="faq-title">
        <h2>{{ section.settings.heading }}</h2>
      </div>
    {% endif %}

    {%- comment -%} Right Column: Accordion (Blocks) {%- endcomment -%}
    {% if section.blocks.size > 0 %}
      <div class="faq-accordion" data-faq-accordion-{{ section.id }}>
        {% for block in section.blocks %}
          {% if block.type == 'faq_item' %}
            <div class="faq-item" {{ block.shopify_attributes }}>
              <button
                class="faq-question"
                aria-expanded="false"
                aria-controls="faq-answer-{{ section.id }}-{{ block.id }}"
                data-faq-trigger
              >
                <span>{{ block.settings.question }}</span>
                <div class="faq-arrow">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="6 9 12 15 18 9"/>
                  </svg>
                </div>
              </button>
              <div
                class="faq-answer"
                id="faq-answer-{{ section.id }}-{{ block.id }}"
                role="region"
              >
                <div class="faq-answer-inner">
                  {{ block.settings.answer }}
                </div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

  </div>
</section>

<script>
  (function() {
    var sectionId = '{{ section.id }}';
    var accordion = document.querySelector('[data-faq-accordion-' + sectionId + ']');
    if (!accordion) return;

    accordion.addEventListener('click', function(e) {
      var trigger = e.target.closest('[data-faq-trigger]');
      if (!trigger) return;

      var item = trigger.closest('.faq-item');
      var arrow = trigger.querySelector('.faq-arrow');
      var answer = item.querySelector('.faq-answer');
      var isOpen = arrow.classList.contains('is-open');

      /* Close all items in this section */
      var allTriggers = accordion.querySelectorAll('[data-faq-trigger]');
      allTriggers.forEach(function(t) {
        var a = t.closest('.faq-item').querySelector('.faq-answer');
        var ar = t.querySelector('.faq-arrow');
        ar.classList.remove('is-open');
        a.classList.remove('is-open');
        a.style.maxHeight = null;
        t.setAttribute('aria-expanded', 'false');
      });

      /* Toggle clicked item */
      if (!isOpen) {
        arrow.classList.add('is-open');
        answer.classList.add('is-open');
        answer.style.maxHeight = answer.scrollHeight + 'px';
        trigger.setAttribute('aria-expanded', 'true');
      }
    });
  })();
</script>

{% schema %}
{
  "name": "FAQ Accordion",
  "tag": "section",
  "class": "faq-accordion-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How It Works"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "color_background",
      "label": "Background",
      "default": "#FDFCFA"
    },
    {
      "type": "color",
      "id": "color_heading",
      "label": "Heading text",
      "default": "#102A43"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Body text",
      "default": "#102A43"
    },
    {
      "type": "color",
      "id": "color_border",
      "label": "Divider line",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "border_opacity",
      "label": "Divider opacity",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "%",
      "default": 8
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading font size (desktop)",
      "min": 20,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "label": "Heading font size (mobile)",
      "min": 18,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "question_font_size",
      "label": "Question font size (desktop)",
      "min": 14,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "question_font_size_mobile",
      "label": "Question font size (mobile)",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "answer_font_size",
      "label": "Answer font size",
      "min": 12,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "answer_opacity",
      "label": "Answer text opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 75
    },
    {
      "type": "header",
      "content": "Spacing & Layout"
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Vertical padding (desktop)",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Horizontal padding (desktop)",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_vertical_mobile",
      "label": "Vertical padding (mobile)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_horizontal_mobile",
      "label": "Horizontal padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Column gap",
      "min": 16,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "arrow_size",
      "label": "Arrow icon size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max content width",
      "min": 800,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 1400
