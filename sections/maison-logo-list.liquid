{% comment %}
  Section: Logo List
  Description: A simple "As Advertised In" logo bar. Heading centered above a row
    of logos that are evenly spaced on desktop and wrap into a grid on mobile.

  Dependencies:
  - Font: 'Plus Jakarta Sans' (heading) — must be loaded by theme or via @import

  Blocks:
  - logo: Individual logo image (limit: 12)
{% endcomment %}

{% style %}
  #shopify-section-{{ section.id }} .maisoncode_logo-list {
    --s-color-bg: {{ section.settings.color_bg }};
    --s-color-heading: {{ section.settings.color_heading }};
    --s-font-heading: 'Plus Jakarta Sans', sans-serif;
    --s-font-size-heading: {{ section.settings.heading_font_size }}px;
    --s-logo-height: {{ section.settings.logo_height }}px;
    --s-padding-top: {{ section.settings.padding_top }}px;
    --s-padding-bottom: {{ section.settings.padding_bottom }}px;
    --s-padding-horizontal: {{ section.settings.padding_horizontal }}px;
    --s-gap: {{ section.settings.gap }}px;

    box-sizing: border-box;
    width: 100%;
    background-color: var(--s-color-bg);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--s-gap);
    padding: var(--s-padding-top) var(--s-padding-horizontal) var(--s-padding-bottom);
  }

  #shopify-section-{{ section.id }} .maisoncode_logo-list *,
  #shopify-section-{{ section.id }} .maisoncode_logo-list *::before,
  #shopify-section-{{ section.id }} .maisoncode_logo-list *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  #shopify-section-{{ section.id }} .logo-list__heading {
    font-family: var(--s-font-heading);
    font-weight: 800;
    font-size: var(--s-font-size-heading);
    line-height: 1.4;
    color: var(--s-color-heading);
    text-align: center;
  }

  #shopify-section-{{ section.id }} .logo-list__logos {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .logo-list__item {
    height: var(--s-logo-height);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .logo-list__item img {
    height: 100%;
    width: auto;
    object-fit: contain;
    display: block;
  }

  /* Responsive — Mobile */
  @media (max-width: 767px) {
    #shopify-section-{{ section.id }} .maisoncode_logo-list {
      --s-font-size-heading: {{ section.settings.heading_font_size_mobile }}px;
      --s-logo-height: {{ section.settings.logo_height_mobile }}px;
      padding: {{ section.settings.padding_top_mobile }}px {{ section.settings.padding_horizontal_mobile }}px {{ section.settings.padding_bottom_mobile }}px;
    }

    #shopify-section-{{ section.id }} .logo-list__logos {
      flex-wrap: wrap;
      justify-content: center;
      gap: {{ section.settings.logo_gap_mobile }}px;
    }

    #shopify-section-{{ section.id }} .logo-list__item {
      width: calc(33.333% - {{ section.settings.logo_gap_mobile | times: 2 | divided_by: 3 }}px);
    }
  }
{% endstyle %}

<section class="maisoncode_logo-list">
  {% if section.settings.heading != blank %}
    <h2 class="logo-list__heading">{{ section.settings.heading }}</h2>
  {% endif %}

  {% if section.blocks.size > 0 %}
    <div class="logo-list__logos">
      {% for block in section.blocks %}
        {% if block.type == 'logo' %}
          <div class="logo-list__item" {{ block.shopify_attributes }}>
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: height: 200 | image_tag:
                loading: 'lazy',
                widths: '100, 150, 200',
                sizes: '(max-width: 767px) 102px, 136px'
              }}
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Logo List",
  "tag": "section",
  "class": "logo-list-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "As Advertised In"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Background",
      "default": "#FDFCFA"
    },
    {
      "type": "color",
      "id": "color_heading",
      "label": "Heading color",
      "default": "#102A43"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading size (desktop)",
      "min": 14,
      "max": 36,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "label": "Heading size (mobile)",
      "min": 14,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo height (desktop)",
      "min": 40,
      "max": 140,
      "step": 4,
      "unit": "px",
      "default": 96
    },
    {
      "type": "range",
      "id": "logo_height_mobile",
      "label": "Logo height (mobile)",
      "min": 32,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap (heading to logos)",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "logo_gap_mobile",
      "label": "Logo gap (mobile)",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Padding horizontal (desktop)",
      "min": 16,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_horizontal_mobile",
      "label": "Padding horizontal (mobile)",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 8
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "limit": 12,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Logo List",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
