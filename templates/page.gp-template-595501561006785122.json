    "gp_section_595501561191400034": {
      "settings": {
        "checksum": "bb06e03a184d9042ddc9e4b1c538577448d65390f0276adc42eb8b9ecda3b380_1_1_0_0__1",
        "gg8yY22gLoi_text": "<p><span style=\"background-color:transparent;color:#000000;font-size:18px;\">We provide fast free shipping and handling for all orders.</span></p>",
        "ggLDYJogvxV_text": "<p>90-DAY MONEY BACK GUARANTEE</p>",
        "ggM5PyQMWIe_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0252/1261/6781/files/gempages_464015397612422087-4509bc60-7755-4bb1-bf01-ade8debf7b92.png",
