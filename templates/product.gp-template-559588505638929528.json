        "ggIQbGud7CS_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0252/1261/6781/files/gempages_464015397612422087-ac376fcb-93e3-44ab-b806-b3776be94c38.png",
        "ggYA73ZA0Jl_text": "90-Night Money Back Guarantee",
        "ggdvCqtTqTJ_text": "<p>The SmoothSpine™ Alignment Pillow is made of premium materials to provide consistent, reliable support and lasting comfort.</p>",
        "gggxDJcXxLS_text": "<p>The SmoothSpine™ Alignment Pillow pillow is designed to improve spine alignment, reduce discomfort, and improve sleep quality.</p><p>&nbsp;</p>",
        "ggrqQNvlo9r_text": "Guaranteed high quality",
