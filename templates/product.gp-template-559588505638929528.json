        "gg_7mUbWOc4_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0252/1261/6781/files/gempages_464015397612422087-f538d10b-5fad-4415-8e60-1531973eeb8f.jpg",
        "gg-_-ksTCT6_text": "BONUS!",
        "ggg0bztCRRw_text": "Order Today and Receive Free Hip &amp; Back Health eBook!",
        "gg2j3JvR1ix_text": "<p><strong>Normally valued at $20.00,</strong> our Hip &amp; Back Health eBook comes free with every purchase:</p>",
        "ggYFu-OKzLo_text": "<p>Revealed Inside:</p>",
        "ggnI7C6EkAT_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0252/1261/6781/files/gempages_464015397612422087-c5ce7c38-03db-478a-bc49-4a9517d3b80c.svg",
        "ggTufPYveB1_text": "<p>Four clinically proven safe exercises for healthy backs and smooth hips</p>",
        "ggB8S9Wg-FF_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0252/1261/6781/files/gempages_464015397612422087-1940a74a-6ab3-4b00-8c86-dab33c3f8b1c.svg",
        "gg2C8_kKMlk_text": "<p>How-to-use guide &amp; best practices.</p>",
        "ggYm60uheT2_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0252/1261/6781/files/gempages_464015397612422087-691b0b58-09aa-4ef5-807e-8fd688b4c054.svg",
