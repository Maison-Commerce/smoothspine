        "paragraph_J6hGYP": {
          "type": "paragraph",
          "settings": {
            "text": "Nothing stuck. The pain always came back.",
            "italic": false
          }
        },
        "paragraph_gY4far": {
          "type": "paragraph",
          "settings": {
            "text": "He started asking doctors a different question: \"What if someone could do this at home? What if relief didn't have to mean endless appointments or pills?\"",
            "italic": false
          }
        },
        "paragraph_PGQF77": {
          "type": "paragraph",
          "settings": {
            "text": "That question became SmoothSpine.",
            "italic": false
          }
        }
