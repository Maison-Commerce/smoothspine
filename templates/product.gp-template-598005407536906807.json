    "gp_section_598005407789613623": {
      "type": "gp-section-598005407789613623",
      "settings": {
        "section_preload": "false",
        "checksum": "b000b26d80b9deed05e8708f3199c2a67a05860d6fb5e0bac295f2875055882c_1_1_1_0__1",
        "ggrydDXALPH_text": "Real Users, Real Life-Changing Results",
        "gg_nv0E1WSj_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0252/1261/6781/files/rvww_1.webp",
        "gg029TQ7PQT_text": "<p>\"I Thought I Was Too Far Gone.\"</p>",
        "ggnkoHZd9S5_text": "<p>\"I'm 68. Had sciatica for 12 years. Tried everything. Doctor said surgery was my only option, but the risks scared me. My daughter bought me the SmoothSpine as a last resort. After one week, I could sit through dinner without wincing. After three weeks, I walked 18 holes of golf for the first time in a decade. I wasn't too far gone. I just needed something that actually worked.\"</p>",
        "ggmciU_MO8m_text": "<p>— Robert Jennings, 68, Verified Purchase</p>",
        "ggx_FgcD6ei_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0252/1261/6781/files/rvww_2.webp",
        "ggBi7vQvbIj_text": "<p>\"It Beat My $8,000 in Physical Therapy\"</p>",
        "ggJ8hCrLXJq_text": "<p>\"Eight months of PT. Three times a week. $8,000 out of pocket. I got maybe 10% better. Then I'd tweak my back and be back to square one. Got the SmoothSpine out of desperation. Within TWO WEEKS, I felt better than I had in eight months of professional therapy. Turns out I didn't need more stretches. I needed decompression, heat, massage, and EMS working together.\"</p>",
        "ggReBUA1njy_text": "<p>— Amanda Peterson, 44, Verified Purchase</p>",
        "ggcIBXq5yW6_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0252/1261/6781/files/rvww_3.webp",
        "gg4lOxj8MET_text": "<p>\"My Doctor Called It 'Medically Impossible'\"</p>",
        "ggZSVoxxXVa_text": "<p>\"Herniated L5-S1. MRI confirmed it. My surgeon scheduled a microdiscectomy in 6 weeks. Tried the SmoothSpine for one month before surgery. After 3 weeks, my pain was almost gone. At my pre-op, my surgeon was confused. 'Your symptoms drastically improved. What have you been doing?' I showed him. He pulled out his phone and ordered one in the exam room. We canceled the surgery. Nine months later: still pain-free.\"</p>",
        "ggQgcHb_VvV_text": "<p>— Linda McCarthy, 52, Verified Purchase</p>"
      }
    },
