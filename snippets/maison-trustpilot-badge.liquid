{% comment %}
  Reusable Trustpilot badge with live data.
  Renders a container with 5 empty stars + placeholder rating + optional Trustpilot logo.
  JS in snippets/maison-trustpilot-script.liquid (loaded globally via theme.liquid) finds all
  [data-tp-badge] elements and hydrates them with live data from the Worker.

  Params:
    wrapper_class   — CSS class for the outer <div> (REQUIRED)
    stars_class     — CSS class for the stars <div>
    rating_class    — CSS class for the rating <span>
    logo_class      — CSS class for the Trustpilot logo <div> (only rendered if show_logo)
    show_logo       — boolean, default false
    logo_label      — text next to logo, default "Trustpilot"
    domain          — trustpilot domain, default "smoothspine.com"
    worker_url      — Cloudflare Worker URL returning live Trustpilot JSON
    href            — if set, wraps the badge in <a href> (opens Trustpilot in new tab)
    rating_format   — "score_count" (default) → "4.4/5 (3,448+ reviews)"
                    — "count_only"           → "3,448+ reviews"
                    — "score_only"           → "4.4/5"
{% endcomment %}

{%- assign mt_domain = domain | default: 'smoothspine.com' -%}
{%- assign mt_worker = worker_url | default: 'https://smoothspine-videoask.choojiie.workers.dev/trustpilot' -%}
{%- assign mt_logo_label = logo_label | default: 'Trustpilot' -%}
{%- assign mt_format = rating_format | default: 'score_count' -%}
{%- assign mt_link = href | default: blank -%}

{%- capture mt_badge_inner -%}
  <div class="{{ stars_class }}" data-tp-stars>
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none"><rect width="16" height="16" fill="#C5C2BD"/><path d="M8 11.1509L10.6071 10.4528L11.6964 14L8 11.1509ZM14 6.56604H9.41071L8 2L6.58929 6.56604H2L5.71429 9.39623L4.30357 13.9623L8.01786 11.1321L10.3036 9.39623L14 6.56604Z" fill="white"/></svg>
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none"><rect width="16" height="16" fill="#C5C2BD"/><path d="M8 11.1509L10.6071 10.4528L11.6964 14L8 11.1509ZM14 6.56604H9.41071L8 2L6.58929 6.56604H2L5.71429 9.39623L4.30357 13.9623L8.01786 11.1321L10.3036 9.39623L14 6.56604Z" fill="white"/></svg>
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none"><rect width="16" height="16" fill="#C5C2BD"/><path d="M8 11.1509L10.6071 10.4528L11.6964 14L8 11.1509ZM14 6.56604H9.41071L8 2L6.58929 6.56604H2L5.71429 9.39623L4.30357 13.9623L8.01786 11.1321L10.3036 9.39623L14 6.56604Z" fill="white"/></svg>
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none"><rect width="16" height="16" fill="#C5C2BD"/><path d="M8 11.1509L10.6071 10.4528L11.6964 14L8 11.1509ZM14 6.56604H9.41071L8 2L6.58929 6.56604H2L5.71429 9.39623L4.30357 13.9623L8.01786 11.1321L10.3036 9.39623L14 6.56604Z" fill="white"/></svg>
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none"><rect width="16" height="16" fill="#C5C2BD"/><path d="M8 11.1509L10.6071 10.4528L11.6964 14L8 11.1509ZM14 6.56604H9.41071L8 2L6.58929 6.56604H2L5.71429 9.39623L4.30357 13.9623L8.01786 11.1321L10.3036 9.39623L14 6.56604Z" fill="white"/></svg>
  </div>
  <span class="{{ rating_class }}" data-tp-rating>&nbsp;</span>
  {% if show_logo %}
    <div class="{{ logo_class }}">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 10.6761L10.0417 9.86164L11.3125 14L7 10.6761ZM14 5.32704H8.64583L7 0L5.35417 5.32704H0L4.33334 8.62893L2.6875 13.956L7.02083 10.6541L9.6875 8.62893L14 5.32704Z" fill="#00B67A"/></svg>
      <span>{{ mt_logo_label }}</span>
    </div>
  {% endif %}
{%- endcapture -%}

{% if mt_link != blank %}
  <a class="{{ wrapper_class }}" href="{{ mt_link }}" target="_blank" rel="noopener" data-tp-badge data-tp-domain="{{ mt_domain }}" data-tp-worker="{{ mt_worker }}" data-tp-format="{{ mt_format }}">
    {{ mt_badge_inner }}
  </a>
{% else %}
  <div class="{{ wrapper_class }}" data-tp-badge data-tp-domain="{{ mt_domain }}" data-tp-worker="{{ mt_worker }}" data-tp-format="{{ mt_format }}">
    {{ mt_badge_inner }}
  </div>
{% endif %}
