        "ggb3x-tTKfi_vimeoUrl": "https://vimeo.com/347119375",
        "ggb3x-tTKfi_youtubeUrl": "https://www.youtube.com/watch?v=cyzh48XRS4M",
        "ggiF75sp5pb_text": "<p><strong>5–10 Minutes: </strong>The combination of sustained traction + heat + vibration creates the perfect environment for disc rehydration. Years of compression begins reversing.</p>"
      },
      "type": "gp-section-596273538513437214"
