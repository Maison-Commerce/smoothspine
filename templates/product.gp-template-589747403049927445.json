        "gglxMzPDaXv_background_desktop_video": "https://www.youtube.com/watch?v=cyzh48XRS4M",
        "gglxMzPDaXv_background_desktop_videoHtml5": "https://media.w3.org/2010/05/sintel/trailer.mp4",
        "ggTWbR7J5A3_text": "<p>(4.7/5 Rated By 21,539+ Customers)</p>",
        "ggiIss1Rofn_customContent_prefix": "Save",
        "ggavmk0YmvV_text": "<p>Still struggling with back pain, sciatica, or stiff, aching<br>muscles?</p><p><i><u>These fast-acting herbal patches deliver targeted relief in just minutes - no pills, no injections, no appointments.</u></i></p>",
        "ggs0hHOJvUw_text": "<p>Each patch uses a time-tested traditional herbal blend and deep-penetrating heat to increase circulation, reduce inflammation, and dull pain - right at the source. </p>",
        "gg6tXSXNWai_text": "<p>Noticeable relief in just 15–20 minutes </p>",
        "ggbcW1KUC8b_text": "<p>Reduces swelling, stiffness, and inflammation</p>",
        "ggxUNGGnafQ_text": "<p>Keeps working for 12 hours straight </p>",
        "ggM-PIG0RRS_text": "<p>Clean, natural relief without the side effects</p>",
        "ggifZ8Bz922_label": "Add to cart",
        "ggifZ8Bz922_outOfStockLabel": "Out of stock",
        "ggifZ8Bz922_unavailableLabel": "Unavailable",
