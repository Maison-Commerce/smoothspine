{%- comment -%}
  Maison Product Card
  Renders a product card matching the Maison design system.

  Supported variables:
  * product: the product to render (required)
  * position: position in list (for lazy loading)
{%- endcomment -%}

{%- assign variant = product.selected_or_first_available_variant -%}
{%- assign compare_price = variant.compare_at_price -%}
{%- assign price = variant.price -%}
{%- assign on_sale = false -%}
{%- if compare_price > price -%}
  {%- assign on_sale = true -%}
  {%- assign save_percent = compare_price | minus: price | times: 100 | divided_by: compare_price -%}
{%- endif -%}

{%- assign rating_value = product.metafields.reviews.rating.value.rating | round: 1 | default: 0 -%}
{%- assign rating_count = product.metafields.reviews.rating_count.value | default: 0 -%}

<div class="mpc">
  {%- comment -%} Image {%- endcomment -%}
  <a href="{{ product.url }}" class="mpc__image-wrap">
    {%- if product.featured_media -%}
      {%- liquid
        assign loading = 'lazy'
        if position <= 4
          assign loading = 'eager'
        endif
      -%}
      <img
        src="{{ product.featured_media | image_url: width: 600 }}"
        srcset="{{ product.featured_media | image_url: width: 300 }} 300w, {{ product.featured_media | image_url: width: 450 }} 450w, {{ product.featured_media | image_url: width: 600 }} 600w"
        sizes="(max-width: 767px) 50vw, 25vw"
        alt="{{ product.featured_media.alt | escape | default: product.title | escape }}"
        width="{{ product.featured_media.width }}"
        height="{{ product.featured_media.height }}"
        loading="{{ loading }}"
        class="mpc__image"
      >
    {%- else -%}
      <div class="mpc__image-placeholder"></div>
    {%- endif -%}
  </a>

  {%- comment -%} Content {%- endcomment -%}
  <div class="mpc__content">
    {%- comment -%} Text block {%- endcomment -%}
    <div class="mpc__text">
      {%- comment -%} Title + Description {%- endcomment -%}
      <div class="mpc__title-group">
        <a href="{{ product.url }}" class="mpc__title">{{ product.title }}</a>
        {%- if product.metafields.custom.maison_short_product_card_description != blank -%}
          <p class="mpc__description">{{ product.metafields.custom.maison_short_product_card_description }}</p>
        {%- endif -%}
      </div>

      {%- comment -%} Rating {%- endcomment -%}
      {%- if rating_count > 0 -%}
        <div class="mpc__rating">
          <div class="mpc__stars">
            {%- assign full_stars = rating_value | floor -%}
            {%- for i in (1..5) -%}
              {%- if i <= full_stars -%}
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 1.33L10.06 5.51L14.67 6.18L11.33 9.43L12.12 14.01L8 11.85L3.88 14.01L4.67 9.43L1.33 6.18L5.94 5.51L8 1.33Z" fill="#FEC84B"/></svg>
              {%- else -%}
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 1.33L10.06 5.51L14.67 6.18L11.33 9.43L12.12 14.01L8 11.85L3.88 14.01L4.67 9.43L1.33 6.18L5.94 5.51L8 1.33Z" fill="#E8E6E3"/></svg>
              {%- endif -%}
            {%- endfor -%}
          </div>
          <span class="mpc__review-count">({{ rating_count | default: '0' }} Reviews)</span>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Price {%- endcomment -%}
    <div class="mpc__price-row">
      {%- if on_sale -%}
        <div class="mpc__prices">
          <span class="mpc__compare-price">{{ compare_price | money }}</span>
          <span class="mpc__sale-price">{{ price | money }}</span>
        </div>
        <span class="mpc__save-badge">Save {{ save_percent }}%</span>
      {%- else -%}
        <span class="mpc__sale-price">{{ price | money }}</span>
      {%- endif -%}
    </div>

    {%- comment -%} CTA Button {%- endcomment -%}
    <a href="{{ product.url }}" class="mpc__button">Shop Now</a>
  </div>
</div>

<style>
  .mpc {
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  /* Image */
  .mpc__image-wrap {
    display: block;
    aspect-ratio: 1 / 1;
    border-radius: 16px;
    overflow: hidden;
    position: relative;
  }

  .mpc__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .mpc__image-placeholder {
    width: 100%;
    height: 100%;
    background: #F8F4EE;
  }

  /* Content */
  .mpc__content {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding: 12px;
  }

  /* Text block */
  .mpc__text {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .mpc__title-group {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .mpc__title {
    font-family: 'Open Sans', sans-serif;
    font-weight: 700;
    font-size: 14px;
    line-height: 1.5;
    color: #102A43;
    text-decoration: none;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
  }

  .mpc__description {
    font-family: 'Open Sans', sans-serif;
    font-weight: 400;
    font-size: 14px;
    line-height: 1.5;
    color: rgba(16, 42, 67, 0.75);
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  /* Rating */
  .mpc__rating {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .mpc__stars {
    display: flex;
    gap: 2px;
    align-items: center;
  }

  .mpc__stars svg {
    width: 16px;
    height: 16px;
    display: block;
  }

  .mpc__review-count {
    font-family: 'Open Sans', sans-serif;
    font-weight: 600;
    font-size: 12px;
    line-height: 1.5;
    color: rgba(16, 42, 67, 0.75);
    white-space: nowrap;
  }

  /* Price */
  .mpc__price-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .mpc__prices {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .mpc__compare-price {
    font-family: 'Open Sans', sans-serif;
    font-weight: 600;
    font-size: 14px;
    line-height: 1.5;
    color: #102A43;
    opacity: 0.5;
    text-decoration: line-through;
  }

  .mpc__sale-price {
    font-family: 'Open Sans', sans-serif;
    font-weight: 700;
    font-size: 16px;
    line-height: 1.5;
    color: #102A43;
  }

  .mpc__save-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 24px;
    padding: 0 12px;
    background-color: #12B76A;
    border-radius: 4px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 800;
    font-size: 12px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #FFFFFF;
    white-space: nowrap;
  }

  /* Button */
  .mpc__button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 36px;
    background-color: #F07E3B;
    border-bottom: 4px solid #BF642F;
    border-radius: 8px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 800;
    font-size: 12px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #FFFCFB;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .mpc__button:hover {
    opacity: 0.9;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 767px) {
    .mpc__content {
      gap: 12px;
      padding: 8px 4px 4px;
    }

    .mpc__title-group {
      gap: 4px;
    }

    .mpc__title {
      font-size: 12px;
    }

    .mpc__description {
      font-size: 12px;
    }

    .mpc__stars svg {
      width: 12px;
      height: 12px;
    }

    .mpc__review-count {
      font-size: 10px;
    }

    .mpc__price-row {
      flex-direction: row;
      gap: 8px;
    }

    .mpc__prices {
      flex-direction: column;
      gap: 0;
      align-items: flex-start;
    }

    .mpc__compare-price {
      font-size: 10px;
    }

    .mpc__sale-price {
      font-size: 12px;
    }

    .mpc__save-badge {
      height: 20px;
      padding: 0 8px;
      font-size: 8px;
    }

    .mpc__button {
      height: 32px;
      font-size: 12px;
    }
  }
</style>
