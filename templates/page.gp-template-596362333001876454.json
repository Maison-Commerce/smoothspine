        "ggb3x-tTKfi_vimeoUrl": "https://vimeo.com/347119375",
        "ggb3x-tTKfi_youtubeUrl": "https://www.youtube.com/watch?v=cyzh48XRS4M",
        "ggd9w5iVAlN_text": "<p>The more you use it, the more your back rebuilds strength and mobility — so relief lasts longer every day.</p>",
