      "settings": {
        "checksum": "4430573c996f4c08efcea56b98c82d2b98610dd8a93f3f82d6e096d963c56aaf_1_1_0_0__1",
        "gg6lqX8ncBw_text": "Backed by Experts. Built on Proven Clinic Therapies.",
        "gg9L3EDUCMV_text": "Trusted by Thousands: From Sleepless Nights to Pain-Free Days",
        "ggGQXnMY5zT_text": "Trusted by Thousands: From Sleepless Nights to Pain-Free Days",
        "ggW6FuzFFTV_html5Url": "https://cdn.shopify.com/videos/c/o/v/9e81285dd00c475296faa9a79c31f46e.mov",
        "ggW6FuzFFTV_poster_src": "https://cdn.shopify.com/s/files/1/0252/1261/6781/files/Trusted_by_Thousands.webp",
        "ggW6FuzFFTV_vimeoUrl": "https://vimeo.com/347119375",
        "ggW6FuzFFTV_youtubeUrl": "https://www.youtube.com/watch?v=cyzh48XRS4M",
        "ggaFHF5sugD_text": "<p>Thousands of users report their pain and stiffness going from 10 to 6 after the very first session! Our customers are finally cancelling expensive treatments, not relying on daily pain meds, and enjoying pain-free life just a few weeks after they start using the Red Light Therapy Belt.</p>",
        "ggiVlsgDWSA_text": "<p>Developed with input from leading physiotherapists and pain specialists, this technology is grounded in proven therapies already used in clinics — but now made simple, portable, and affordable for at-home use.</p>",
        "ggihisY810h_text": "Backed by Experts. Built on Proven Clinic Therapies.",
        "ggr9awOTvod_html5Url": "https://cdn.shopify.com/videos/c/o/v/e90e767df8e1414bb8deb370636c690c.mp4",
        "ggr9awOTvod_poster_src": "https://cdn.shopify.com/s/files/1/0252/1261/6781/files/Backed_by_Experts.webp",
        "ggr9awOTvod_vimeoUrl": "https://vimeo.com/347119375",
