        "ggYRGn3_-rs_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0252/1261/6781/files/gempages_464015397612422087-00428b28-be38-4a92-add3-22f1e8e1171f.png",
        "gggjLf4dDUF_text": "<p>FREE SHIPPING</p>",
        "ggnO_gdadKG_text": "<p><span style=\"background-color:transparent;color:#000000;font-size:18px;\">The SmoothSpine™ Belt is engineered to support spinal alignment, relieve lower back and hip pain, and restore natural mobility without disrupting your daily routine.</span></p>",
        "ggnoiLlCDO__text": "<p><span style=\"background-color:transparent;color:#000000;font-size:18px;\">If you’re not absolutely thrilled with the results, we will refund every single penny of your investment. No hassle.&nbsp;</span></p>",
