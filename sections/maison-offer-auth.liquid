{% comment %}
  Section: Offer Authority Trust
  Description: Multi-part landing page section combining three connected blocks:
    1. Offer Block — Two-column layout with product offer details (trust badge, heading,
       checklist, free gifts, CTA button) and a product image.
    2. Authority/Endorsement Block — Tabbed expert endorsements with doctor quotes
       and images, using Alpine.js for tab switching.
    3. Trust Signals Block — Three-column trust indicators (guarantee, shipping, quality)
       with icons and descriptions.
    Sections are visually connected via decorative wave dividers.

  Dependencies:
  - Font: 'Plus Jakarta Sans' (headings), 'Open Sans' (body) — must be loaded by theme
    or via @import (noted below in style block)
  - Alpine.js — required for endorsement tab switching functionality;
    must be loaded by theme or included separately

  Blocks:
  - checklist_item: Offer checklist item with checkmark icon and text (limit: 8)
  - gift_item: Free gift card with badge, image, and label (limit: 6)
  - endorsement: Expert endorsement tab with name, title, quote, role, and image (limit: 6)
  - trust_item: Trust signal with icon, heading, and description (limit: 6)

  Notes:
  - Wave divider images between blocks use image_picker settings; merchant must upload SVG/PNG waves
  - Endorsement tabs require Alpine.js (x-data, x-show, @click directives)
  - All colors, typography, spacing, and border radius values are merchant-configurable
  - Original source class prefix: maisoncode_offer-authority
  - Gift badge icons and checklist icons use image_picker for full merchant control
{% endcomment %}

{% style %}
  #shopify-section-{{ section.id }} .maisoncode_offer-authority {
    --s-color-bg-offer: {{ section.settings.color_bg_offer }};
    --s-color-bg-authority: {{ section.settings.color_bg_authority }};
    --s-color-bg-trust: {{ section.settings.color_bg_trust }};
    --s-color-bg-outer: {{ section.settings.color_bg_outer }};
    --s-color-text-primary: {{ section.settings.color_text_primary }};
    --s-color-text-secondary: {{ section.settings.color_text_secondary }};
    --s-color-highlight: {{ section.settings.color_highlight }};
    --s-color-accent: {{ section.settings.color_accent }};
    --s-color-accent-border: {{ section.settings.color_accent_border }};
    --s-color-btn-bg: {{ section.settings.color_btn_bg }};
    --s-color-btn-border: {{ section.settings.color_btn_border }};
    --s-color-btn-text: {{ section.settings.color_btn_text }};
    --s-color-gift-bg: {{ section.settings.color_gift_bg }};
    --s-color-gift-border: {{ section.settings.color_gift_border }};
    --s-color-gift-badge-bg: {{ section.settings.color_gift_badge_bg }};
    --s-color-gift-badge-text: {{ section.settings.color_gift_badge_text }};
    --s-color-trust-icon-bg: {{ section.settings.color_trust_icon_bg }};
    --s-color-trust-icon-border: {{ section.settings.color_trust_icon_border }};
    --s-color-trust-divider: {{ section.settings.color_trust_divider }};
    --s-color-tab-active: {{ section.settings.color_tab_active }};
    --s-color-expert-badge: {{ section.settings.color_expert_badge }};
    --s-color-divider: {{ section.settings.color_divider }};

    --s-font-heading: 'Plus Jakarta Sans', sans-serif;
    --s-font-body: 'Open Sans', sans-serif;

    --s-font-size-heading: {{ section.settings.heading_font_size }}px;
    --s-font-size-subtext: {{ section.settings.subtext_font_size }}px;
    --s-font-size-checklist: {{ section.settings.checklist_font_size }}px;
    --s-font-size-endorsement-title: {{ section.settings.endorsement_title_font_size }}px;
    --s-font-size-quote: {{ section.settings.quote_font_size }}px;
    --s-font-size-trust-heading: {{ section.settings.trust_heading_font_size }}px;
    --s-font-size-trust-body: {{ section.settings.trust_body_font_size }}px;
    --s-font-size-btn: {{ section.settings.btn_font_size }}px;
    --s-font-size-badge: {{ section.settings.badge_font_size }}px;
    --s-font-size-tab: {{ section.settings.tab_font_size }}px;
    --s-font-size-rating: {{ section.settings.rating_font_size }}px;

    --s-padding-top: {{ section.settings.padding_top }}px;
    --s-padding-bottom: {{ section.settings.padding_bottom }}px;
    --s-padding-x: {{ section.settings.padding_x }}px;
    --s-max-width: {{ section.settings.max_width }}px;
    --s-block-padding-x: {{ section.settings.block_padding_x }}px;
    --s-block-padding-y: {{ section.settings.block_padding_y }}px;
    --s-column-gap: {{ section.settings.column_gap }}px;
    --s-radius-block: {{ section.settings.block_border_radius }}px;
    --s-radius-image: {{ section.settings.image_border_radius }}px;
    --s-radius-btn: {{ section.settings.btn_border_radius }}px;
    --s-radius-gift: {{ section.settings.gift_border_radius }}px;
    --s-radius-trust-icon: {{ section.settings.trust_icon_border_radius }}px;

    box-sizing: border-box;
    background: var(--s-color-bg-outer);
    padding: var(--s-padding-top) var(--s-padding-x) var(--s-padding-bottom);
    font-family: var(--s-font-body);
  }

  #shopify-section-{{ section.id }} .maisoncode_offer-authority *,
  #shopify-section-{{ section.id }} .maisoncode_offer-authority *::before,
  #shopify-section-{{ section.id }} .maisoncode_offer-authority *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  #shopify-section-{{ section.id }} .oa-inner {
    max-width: var(--s-max-width);
    margin: 0 auto;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* === OFFER BLOCK === */
  #shopify-section-{{ section.id }} .oa-offer-wrap {
    width: 100%;
    display: flex;
    flex-direction: column;
  }

  #shopify-section-{{ section.id }} .oa-offer {
    background: var(--s-color-bg-offer);
    border-radius: var(--s-radius-block) var(--s-radius-block) 0 var(--s-radius-block);
    padding: var(--s-block-padding-y) var(--s-block-padding-x);
    display: flex;
    gap: var(--s-column-gap);
    align-items: center;
    overflow: hidden;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .oa-offer-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 32px;
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .oa-badge-row {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  #shopify-section-{{ section.id }} .oa-stars {
    display: flex;
    gap: 2px;
  }

  #shopify-section-{{ section.id }} .oa-stars svg {
    width: 16px;
    height: 16px;
  }

  #shopify-section-{{ section.id }} .oa-rating-text {
    font-family: var(--s-font-body);
    font-weight: 600;
    font-size: var(--s-font-size-rating);
    line-height: 1.5;
    color: #111;
  }

  #shopify-section-{{ section.id }} .oa-rating-text a {
    color: inherit;
  }

  #shopify-section-{{ section.id }} .oa-trustpilot {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  #shopify-section-{{ section.id }} .oa-trustpilot img {
    width: 14px;
    height: 14px;
  }

  #shopify-section-{{ section.id }} .oa-trustpilot span {
    font-family: var(--s-font-body);
    font-weight: 600;
    font-size: var(--s-font-size-rating);
    line-height: 1.5;
    color: #111;
  }

  #shopify-section-{{ section.id }} .oa-heading {
    font-family: var(--s-font-heading);
    font-weight: 800;
    font-size: var(--s-font-size-heading);
    line-height: 1.5;
    color: var(--s-color-text-primary);
    text-transform: capitalize;
    max-width: 500px;
  }

  #shopify-section-{{ section.id }} .oa-heading .oa-highlight {
    color: var(--s-color-highlight);
    text-decoration: underline;
    font-style: italic;
  }

  #shopify-section-{{ section.id }} .oa-subtext {
    font-family: var(--s-font-body);
    font-weight: 400;
    font-size: var(--s-font-size-subtext);
    line-height: 1.5;
    color: var(--s-color-text-secondary);
  }

  #shopify-section-{{ section.id }} .oa-subtext u {
    text-decoration: underline;
  }

  #shopify-section-{{ section.id }} .oa-divider {
    width: 100%;
    height: 1px;
    background: var(--s-color-divider);
    opacity: 0.1;
  }

  #shopify-section-{{ section.id }} .oa-checklist {
    display: flex;
    flex-direction: column;
    gap: 8px;
    list-style: none;
  }

  #shopify-section-{{ section.id }} .oa-checklist li {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  #shopify-section-{{ section.id }} .oa-checklist li svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .oa-checklist li span {
    font-family: var(--s-font-body);
    font-weight: 600;
    font-size: var(--s-font-size-checklist);
    line-height: 1.5;
    color: var(--s-color-text-primary);
  }

  #shopify-section-{{ section.id }} .oa-gifts-heading {
    font-family: var(--s-font-heading);
    font-weight: 800;
    font-size: 14px;
    line-height: 1.5;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--s-color-text-primary);
    text-align: center;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .oa-gifts-row {
    display: flex;
    gap: 8px;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .oa-gift-card {
    flex: 1;
    background: var(--s-color-gift-bg);
    border: 1px dashed var(--s-color-gift-border);
    border-radius: var(--s-radius-gift);
    padding: 20px 16px 12px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    position: relative;
  }

  #shopify-section-{{ section.id }} .oa-gift-card img.oa-gift-img {
    width: 80px;
    height: 80px;
    object-fit: contain;
  }

  #shopify-section-{{ section.id }} .oa-gift-card .oa-gift-placeholder {
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.3;
  }

  #shopify-section-{{ section.id }} .oa-gift-card .oa-gift-placeholder svg {
    width: 40px;
    height: 40px;
  }

  #shopify-section-{{ section.id }} .oa-gift-card .oa-gift-label {
    font-family: var(--s-font-body);
    font-weight: 600;
    font-size: 10px;
    line-height: 1.5;
    color: var(--s-color-text-primary);
    text-align: center;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .oa-gift-badge {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--s-color-gift-badge-bg);
    border-radius: 4px;
    padding: 2px 8px;
    display: flex;
    align-items: center;
    gap: 4px;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .oa-gift-badge svg {
    width: 12px;
    height: 12px;
  }

  #shopify-section-{{ section.id }} .oa-gift-badge span {
    font-family: var(--s-font-body);
    font-weight: 700;
    font-size: 10px;
    line-height: 1.5;
    color: var(--s-color-gift-badge-text);
  }

  #shopify-section-{{ section.id }} .oa-cta-area {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .oa-cta-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 56px;
    background: var(--s-color-btn-bg);
    border: none;
    border-bottom: 4px solid var(--s-color-btn-border);
    border-radius: var(--s-radius-btn);
    padding: 16px 32px;
    cursor: pointer;
    text-decoration: none;
  }

  #shopify-section-{{ section.id }} .oa-cta-btn span {
    font-family: var(--s-font-heading);
    font-weight: 800;
    font-size: var(--s-font-size-btn);
    line-height: 1.5;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--s-color-btn-text);
  }

  #shopify-section-{{ section.id }} .oa-cta-btn:hover {
    opacity: 0.92;
  }

  #shopify-section-{{ section.id }} .oa-note {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  #shopify-section-{{ section.id }} .oa-note svg {
    width: 20px;
    height: 20px;
  }

  #shopify-section-{{ section.id }} .oa-note span {
    font-family: var(--s-font-heading);
    font-weight: 800;
    font-size: var(--s-font-size-rating);
    line-height: 1.5;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--s-color-text-primary);
  }

  #shopify-section-{{ section.id }} .oa-offer-image {
    flex: 1;
    aspect-ratio: 1;
    border-radius: var(--s-radius-image);
    overflow: hidden;
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .oa-offer-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #shopify-section-{{ section.id }} .oa-offer-image .oa-image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #e8d5c4 0%, #f0e6da 50%, #d4bfae 100%);
  }

  #shopify-section-{{ section.id }} .oa-wave {
    width: 100%;
    display: block;
  }

  #shopify-section-{{ section.id }} .oa-wave img {
    width: 100%;
    height: 100%;
    display: block;
  }

  #shopify-section-{{ section.id }} .oa-wave--top {
    position: relative;
    top: 1px;
  }

  #shopify-section-{{ section.id }} .oa-wave--bottom {
    position: relative;
    top: -1px;
  }

  /* === AUTHORITY / ENDORSEMENT BLOCK === */
  #shopify-section-{{ section.id }} .oa-authority-wrap {
    width: 100%;
    display: flex;
    flex-direction: column;
  }

  #shopify-section-{{ section.id }} .oa-authority {
    background: var(--s-color-bg-authority);
    border-radius: 0 var(--s-radius-block) 0 var(--s-radius-block);
    padding: var(--s-block-padding-y) var(--s-block-padding-x);
    display: flex;
    gap: var(--s-column-gap);
    align-items: center;
    overflow: hidden;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .oa-authority-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 40px;
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .oa-tabs {
    display: flex;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .oa-tab {
    flex: 1;
    padding: 0 20px 20px;
    background: none;
    border: none;
    border-bottom: 2px solid rgba(16,16,16,0.1);
    cursor: pointer;
    font-family: var(--s-font-heading);
    font-weight: 800;
    font-size: var(--s-font-size-tab);
    line-height: 1.5;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--s-color-text-secondary);
    text-align: center;
  }

  #shopify-section-{{ section.id }} .oa-tab.active {
    color: var(--s-color-tab-active);
    border-bottom-color: var(--s-color-tab-active);
  }

  #shopify-section-{{ section.id }} .oa-endorsement-title {
    font-family: var(--s-font-heading);
    font-weight: 800;
    font-size: var(--s-font-size-endorsement-title);
    line-height: 1.4;
    color: var(--s-color-text-primary);
    text-transform: capitalize;
  }

  #shopify-section-{{ section.id }} .oa-expert-badge {
    font-family: var(--s-font-heading);
    font-weight: 800;
    font-size: var(--s-font-size-rating);
    line-height: 1.5;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--s-color-expert-badge);
  }

  #shopify-section-{{ section.id }} .oa-quote {
    font-family: var(--s-font-body);
    font-weight: 400;
    font-size: var(--s-font-size-quote);
    line-height: 1.5;
    color: var(--s-color-text-secondary);
  }

  #shopify-section-{{ section.id }} .oa-attribution {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  #shopify-section-{{ section.id }} .oa-attribution .oa-attr-name {
    font-family: var(--s-font-body);
    font-weight: 600;
    font-size: var(--s-font-size-rating);
    line-height: 1.5;
    color: var(--s-color-text-primary);
  }

  #shopify-section-{{ section.id }} .oa-attr-role {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  #shopify-section-{{ section.id }} .oa-attr-role svg {
    width: 16px;
    height: 16px;
  }

  #shopify-section-{{ section.id }} .oa-attr-role span {
    font-family: var(--s-font-body);
    font-weight: 600;
    font-size: var(--s-font-size-rating);
    line-height: 1.5;
    color: var(--s-color-text-secondary);
  }

  #shopify-section-{{ section.id }} .oa-authority-image {
    flex: 1;
    border-radius: var(--s-radius-image);
    overflow: hidden;
    min-width: 0;
    height: 544px;
  }

  #shopify-section-{{ section.id }} .oa-authority-image div{
    display: flex;
  }  

  #shopify-section-{{ section.id }} .oa-authority-image img,
  #shopify-section-{{ section.id }} .oa-authority-image video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #shopify-section-{{ section.id }} .oa-authority-image .oa-image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #c4d5e8 0%, #dae6f0 50%, #aebfd4 100%);
  }

  /* === TRUST SIGNALS === */
  #shopify-section-{{ section.id }} .oa-trust-wrap {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .oa-trust {
    background: var(--s-color-bg-trust);
    border-radius: 0 var(--s-radius-block) var(--s-radius-block) var(--s-radius-block);
    padding: var(--s-block-padding-y) var(--s-block-padding-x);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .oa-trust-row {
    display: flex;
    gap: 32px;
    align-items: flex-start;
    justify-content: center;
    flex: 1;
  }

  #shopify-section-{{ section.id }} .oa-trust-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  #shopify-section-{{ section.id }} .oa-trust-icon {
    background: var(--s-color-trust-icon-bg);
    border: 1px dashed var(--s-color-trust-icon-border);
    border-radius: var(--s-radius-trust-icon);
    padding: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .oa-trust-icon img {
    width: 32px;
    height: 32px;
  }

  #shopify-section-{{ section.id }} .oa-trust-icon svg {
    width: 32px;
    height: 32px;
  }

  #shopify-section-{{ section.id }} .oa-trust-text {
    display: flex;
    flex-direction: column;
    gap: 8px;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .oa-trust-text h3 {
    font-family: var(--s-font-body);
    font-weight: 700;
    font-size: var(--s-font-size-trust-heading);
    line-height: 1.5;
    color: var(--s-color-text-primary);
  }

  #shopify-section-{{ section.id }} .oa-trust-text p {
    font-family: var(--s-font-body);
    font-weight: 400;
    font-size: var(--s-font-size-trust-body);
    line-height: 1.5;
    color: var(--s-color-text-secondary);
  }

  #shopify-section-{{ section.id }} .oa-trust-divider {
    width: 1px;
    height: 64px;
    background: var(--s-color-trust-divider);
    flex-shrink: 0;
    align-self: center;
  }

  /* === RESPONSIVE === */
  @media (max-width: 767px) {
    #shopify-section-{{ section.id }} .maisoncode_offer-authority {
      --s-padding-top: {{ section.settings.padding_top_mobile }}px;
      --s-padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      --s-padding-x: {{ section.settings.padding_x_mobile }}px;
      --s-font-size-heading: {{ section.settings.heading_font_size_mobile }}px;
      --s-font-size-subtext: {{ section.settings.subtext_font_size_mobile }}px;
      --s-font-size-endorsement-title: {{ section.settings.endorsement_title_font_size_mobile }}px;
      --s-font-size-quote: {{ section.settings.quote_font_size_mobile }}px;
      --s-font-size-tab: {{ section.settings.tab_font_size_mobile }}px;
      --s-block-padding-x: 20px;
      --s-block-padding-y: 32px;
    }

    #shopify-section-{{ section.id }} .oa-offer {
      flex-direction: column-reverse;
      gap: 24px;
      padding: 20px;
    }

    #shopify-section-{{ section.id }} .oa-offer-content {
      text-align: center;
      align-items: center;
    }

    #shopify-section-{{ section.id }} .oa-offer-image {
      width: 100%;
      aspect-ratio: 1;
    }

    #shopify-section-{{ section.id }} .oa-heading {
      max-width: 100%;
      line-height: 1.4;
    }

    #shopify-section-{{ section.id }} .oa-badge-row {
      justify-content: center;
    }

    #shopify-section-{{ section.id }} .oa-gift-card img.oa-gift-img {
      width: 64px;
      height: 64px;
    }

    #shopify-section-{{ section.id }} .oa-gift-card .oa-gift-placeholder {
      width: 64px;
      height: 64px;
    }

    #shopify-section-{{ section.id }} .oa-cta-btn {
      height: 44px;
    }

    #shopify-section-{{ section.id }} .oa-cta-btn span {
      font-size: 14px;
    }

    #shopify-section-{{ section.id }} .oa-note svg {
      width: 16px;
      height: 16px;
    }

    #shopify-section-{{ section.id }} .oa-note span {
      font-size: 10px;
    }

    #shopify-section-{{ section.id }} .oa-authority {
      flex-direction: column;
      gap: 32px;
      padding: 20px;
    }

    #shopify-section-{{ section.id }} .oa-authority-image {
      width: 100%;
      height: 300px;
      order: -1;
    }

    #shopify-section-{{ section.id }} .oa-trust {
      padding: 20px;
    }

    #shopify-section-{{ section.id }} .oa-trust-row {
      flex-direction: column;
      gap: 12px;
    }

    #shopify-section-{{ section.id }} .oa-trust-item {
      flex-direction: row;
      gap: 18px;
      padding: 12px;
      align-items: center;
    }

    #shopify-section-{{ section.id }} .oa-trust-text {
      text-align: left;
    }

    #shopify-section-{{ section.id }} .oa-trust-divider {
      width: 100%;
      height: 1px;
    }
  }
{% endstyle %}

<section class="maisoncode_offer-authority">
  <div class="oa-inner">

    {%- comment -%} === OFFER BLOCK === {%- endcomment -%}
    {% if section.settings.show_offer_block %}
      <div class="oa-offer-wrap">
        <div class="oa-offer">
          <div class="oa-offer-content">
            {%- comment -%} Top meta {%- endcomment -%}
            <div style="display:flex;flex-direction:column;gap:20px;">
              <div style="display:flex;flex-direction:column;gap:12px;">
                {% if section.settings.show_rating_badge %}
                  <div class="oa-badge-row">
                    <div class="oa-stars">
                      {% for i in (1..4) %}
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none"><rect width="16" height="16" fill="#00B67A"/><path d="M8 11.1509L10.6071 10.4528L11.6964 14L8 11.1509ZM14 6.56604H9.41071L8 2L6.58929 6.56604H2L5.71429 9.39623L4.30357 13.9623L8.01786 11.1321L10.3036 9.39623L14 6.56604Z" fill="white"/></svg>
                      {% endfor %}
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none"><rect width="16" height="16" fill="#00B67A"/><rect x="8" width="8" height="16" fill="#C5C2BD"/><path d="M8 11.1509L10.6071 10.4528L11.6964 14L8 11.1509ZM14 6.56604H9.41071L8 2L6.58929 6.56604H2L5.71429 9.39623L4.30357 13.9623L8.01786 11.1321L10.3036 9.39623L14 6.56604Z" fill="white"/></svg>
                    </div>
                    {% if section.settings.rating_text != blank %}
                      <span class="oa-rating-text">{{ section.settings.rating_text }}</span>
                    {% endif %}
                    {% if section.settings.show_trustpilot_badge %}
                      <div class="oa-trustpilot">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 10.6761L10.0417 9.86164L11.3125 14L7 10.6761ZM14 5.32704H8.64583L7 0L5.35417 5.32704H0L4.33334 8.62893L2.6875 13.956L7.02083 10.6541L9.6875 8.62893L14 5.32704Z" fill="#00B67A"/></svg>
                        <span>Trustpilot</span>
                      </div>
                    {% endif %}
                  </div>
                {% endif %}
                {% if section.settings.offer_heading != blank %}
                  <h2 class="oa-heading">{{ section.settings.offer_heading }}</h2>
                {% endif %}
              </div>
              {% if section.settings.offer_subtext != blank %}
                <p class="oa-subtext">{{ section.settings.offer_subtext }}</p>
              {% endif %}
              <div class="oa-divider"></div>
            </div>

            {%- comment -%} Checklist + gifts {%- endcomment -%}
            <div style="display:flex;flex-direction:column;gap:32px;">
              {%- assign checklist_blocks = section.blocks | where: "type", "checklist_item" -%}
              {% if checklist_blocks.size > 0 %}
                <ul class="oa-checklist">
                  {% for block in checklist_blocks %}
                    <li {{ block.shopify_attributes }}>
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none"><g clip-path="url(#oa-check-{{ block.id }})"><path fill-rule="evenodd" clip-rule="evenodd" d="M2.6235 2.6235C4.37209 0.874903 6.8971 0 10 0C13.1029 0 15.6279 0.874903 17.3766 2.6235C19.1251 4.37209 20 6.8971 20 10C20 13.1029 19.1251 15.6279 17.3766 17.3766C15.6279 19.1251 13.1029 20 10 20C6.8971 20 4.37209 19.1251 2.6235 17.3766C0.874903 15.6279 0 13.1029 0 10C0 6.8971 0.874903 4.37209 2.6235 2.6235ZM14.1713 7.08989C14.5366 6.75857 14.564 6.19391 14.2327 5.82869C13.9014 5.46346 13.3368 5.43596 12.9715 5.76727C11.7848 6.84384 10.8933 7.81137 10.1408 8.98594C9.59271 9.84133 9.13136 10.7863 8.67961 11.9317L7.06956 10.2713C6.72627 9.9173 6.16101 9.9086 5.80701 10.2519C5.45301 10.5952 5.44431 11.1604 5.78759 11.5144L8.38499 14.193C8.60064 14.4154 8.91617 14.5101 9.21866 14.4433C9.52113 14.3764 9.76736 14.1575 9.8692 13.865C10.4695 12.1405 11.0025 10.9511 11.6443 9.94926C12.2827 8.95296 13.0528 8.10454 14.1713 7.08989Z" fill="#065BDC"/></g><defs><clipPath id="oa-check-{{ block.id }}"><rect width="20" height="20" fill="white"/></clipPath></defs></svg>
                      {% if block.settings.text != blank %}
                        <span>{{ block.settings.text }}</span>
                      {% endif %}
                    </li>
                  {% endfor %}
                </ul>
              {% endif %}

              {%- assign gift_blocks = section.blocks | where: "type", "gift_item" -%}
              {% if gift_blocks.size > 0 %}
                <div style="display:flex;flex-direction:column;gap:24px;">
                  {% if section.settings.gifts_heading != blank %}
                    <p class="oa-gifts-heading">{{ section.settings.gifts_heading }}</p>
                  {% endif %}
                  <div class="oa-gifts-row">
                    {% for block in gift_blocks %}
                      <div class="oa-gift-card" {{ block.shopify_attributes }}>
                        {% if block.settings.badge_text != blank %}
                          <div class="oa-gift-badge">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="8" width="18" height="13" rx="2"/><path d="M12 8V21"/><path d="M3 12h18"/><path d="M12 8c-1.5-2-4-3-4-3s1.5-2 4 0c2.5-2 4 0 4 0s-2.5 1-4 3z"/></svg>
                            <span>{{ block.settings.badge_text }}</span>
                          </div>
                        {% endif %}
                        {% if block.settings.image != blank %}
                          {{ block.settings.image | image_url: width: 160 | image_tag:
                            class: 'oa-gift-img',
                            loading: 'lazy',
                            widths: '80, 120, 160'
                          }}
                        {% else %}
                          <div class="oa-gift-placeholder">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                          </div>
                        {% endif %}
                        {% if block.settings.label != blank %}
                          <span class="oa-gift-label">{{ block.settings.label }}</span>
                        {% endif %}
                      </div>
                    {% endfor %}
                  </div>
                </div>
              {% endif %}
            </div>

            {%- comment -%} CTA {%- endcomment -%}
            <div class="oa-cta-area">
              {% if section.settings.cta_label != blank %}
                <a
                  {% if section.settings.cta_link != blank %}href="{{ section.settings.cta_link }}"{% endif %}
                  class="oa-cta-btn"
                >
                  <span>{{ section.settings.cta_label }}</span>
                </a>
              {% endif %}
              {% if section.settings.show_cta_note and section.settings.cta_note != blank %}
                <div class="oa-note">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="9" stroke="#F07E3B" stroke-width="2"/><line x1="10" y1="6" x2="10" y2="11" stroke="#F07E3B" stroke-width="2" stroke-linecap="round"/><circle cx="10" cy="14" r="1" fill="#F07E3B"/></svg>
                  <span>{{ section.settings.cta_note }}</span>
                </div>
              {% endif %}
            </div>
          </div>

          {%- comment -%} Product image {%- endcomment -%}
          <div class="oa-offer-image">
            {% if section.settings.offer_image != blank %}
              {{ section.settings.offer_image | image_url: width: 1200 | image_tag:
                loading: 'lazy',
                widths: '375, 550, 750, 1000, 1200',
                sizes: '(max-width: 767px) 100vw, 50vw'
              }}
            {% else %}
              <div class="oa-image-placeholder">
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {% endif %}
          </div>
        </div>

        {%- comment -%} Wave between offer and authority {%- endcomment -%}
        {% if section.settings.wave_offer_to_authority != blank %}
          <div class="oa-wave oa-wave--bottom">
            {{ section.settings.wave_offer_to_authority | image_url: width: 1600 | image_tag:
              loading: 'lazy',
              widths: '800, 1200, 1600'
            }}
          </div>
        {% endif %}
      </div>
    {% endif %}

    {%- comment -%} === AUTHORITY / ENDORSEMENT BLOCK === {%- endcomment -%}
    {%- assign endorsement_blocks = section.blocks | where: "type", "endorsement" -%}
    {% if section.settings.show_authority_block and endorsement_blocks.size > 0 %}
      <div class="oa-authority-wrap">
        {% if section.settings.wave_top_authority != blank %}
          <div class="oa-wave oa-wave--top">
            {{ section.settings.wave_top_authority | image_url: width: 1600 | image_tag:
              loading: 'lazy',
              widths: '800, 1200, 1600'
            }}
          </div>
        {% endif %}

        <div class="oa-authority" x-data="{ activeTab: 0 }">
          <div class="oa-authority-content">
            {%- comment -%} Tabs {%- endcomment -%}
            {% if endorsement_blocks.size > 1 %}
              <div class="oa-tabs">
                {% for block in endorsement_blocks %}
                  <button
                    class="oa-tab"
                    :class="activeTab === {{ forloop.index0 }} ? 'active' : ''"
                    @click="activeTab = {{ forloop.index0 }}"
                  >
                    {{ block.settings.tab_label }}
                  </button>
                {% endfor %}
              </div>
            {% endif %}

            {%- comment -%} Tab content {%- endcomment -%}
            {% for block in endorsement_blocks %}
              <div
                x-show="activeTab === {{ forloop.index0 }}"
                {% if forloop.index0 != 0 %}style="display:none;"{% endif %}
                {{ block.shopify_attributes }}
              >
                <div style="display:flex;flex-direction:column;gap:40px;">
                  {% if block.settings.title != blank %}
                    <h3 class="oa-endorsement-title">{{ block.settings.title }}</h3>
                  {% endif %}
                  <div style="display:flex;flex-direction:column;gap:12px;">
                    {% if block.settings.badge_label != blank %}
                      <span class="oa-expert-badge">{{ block.settings.badge_label }}</span>
                    {% endif %}
                    {% if block.settings.quote != blank %}
                      <p class="oa-quote">{{ block.settings.quote }}</p>
                    {% endif %}
                    <div class="oa-attribution">
                      {% if block.settings.author_name != blank %}
                        <span class="oa-attr-name">{{ block.settings.author_name }}</span>
                      {% endif %}
                      {% if block.settings.author_role != blank %}
                        <div class="oa-attr-role">
                          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none"><g clip-path="url(#oa-verified-{{ block.id }})"><path fill-rule="evenodd" clip-rule="evenodd" d="M6.84687 0.422743C7.50338 -0.141185 8.47232 -0.140794 9.12851 0.423196C9.37005 0.630789 9.6083 0.838566 9.8436 1.04685C10.1567 0.983031 10.472 0.921248 10.7899 0.861387C11.6405 0.70127 12.4794 1.18608 12.7657 2.00261C12.8711 2.30314 12.9735 2.60222 13.0731 2.90025C13.3761 3.0015 13.6801 3.10563 13.9854 3.21278C14.8019 3.49937 15.2862 4.3387 15.1258 5.18897C15.0655 5.50886 15.0033 5.82587 14.9391 6.1405C15.1521 6.38097 15.3646 6.62451 15.5768 6.87149C16.1408 7.52768 16.1411 8.49662 15.5773 9.15313C15.3664 9.39862 15.1552 9.64083 14.9433 9.88008C15.0061 10.188 15.0669 10.4982 15.1259 10.8111C15.2863 11.6614 14.8021 12.5007 13.9855 12.7873C13.6801 12.8945 13.3761 12.9986 13.073 13.0999C12.9734 13.3979 12.871 13.697 12.7656 13.9975C12.4793 14.8141 11.6403 15.2989 10.7898 15.1387C10.4788 15.0801 10.1704 15.0198 9.86415 14.9575C9.63008 15.1646 9.39318 15.3711 9.15313 15.5773C8.49662 16.1411 7.52767 16.1408 6.87149 15.5768C6.62998 15.3693 6.39175 15.1615 6.15647 14.9533C5.84335 15.017 5.52799 15.0789 5.20995 15.1387C4.35943 15.2989 3.52049 14.8141 3.23422 13.9975C3.12885 13.697 3.02641 13.3979 2.92679 13.0999C2.62369 12.9986 2.31968 12.8945 2.0143 12.7873C1.19767 12.5007 0.713537 11.6614 0.873872 10.8111C0.934217 10.4911 0.996441 10.174 1.06067 9.85921C0.847755 9.61883 0.635379 9.37538 0.423195 9.12851C-0.140793 8.47232 -0.141185 7.50338 0.422742 6.84687C0.63357 6.60143 0.844727 6.35926 1.05653 6.12006C0.993801 5.81215 0.932989 5.50193 0.873976 5.18897C0.713643 4.3387 1.19777 3.49937 2.01441 3.21278C2.3197 3.10563 2.62363 3.0015 2.92665 2.90025C3.02629 2.60222 3.12873 2.30314 3.23411 2.00261C3.52039 1.18608 4.35933 0.701269 5.20985 0.861387C5.52089 0.919943 5.82937 0.980338 6.13569 1.04268C6.36982 0.835525 6.60678 0.628976 6.84687 0.422743ZM10.8616 6.34914C11.2122 6.03109 11.2386 5.48902 10.9206 5.1384C10.6025 4.78777 10.0604 4.76138 9.70982 5.07944C8.86921 5.84199 8.22869 6.53552 7.68647 7.38183C7.34702 7.91166 7.05533 8.48701 6.77625 9.1553L5.89491 8.24644C5.56537 7.90658 5.02272 7.89824 4.68288 8.22778C4.34304 8.55734 4.33469 9.09998 4.66423 9.43983L6.48465 11.3171C6.69168 11.5306 6.99457 11.6216 7.28496 11.5574C7.57535 11.4933 7.81171 11.2831 7.90949 11.0022C8.32745 9.80161 8.69395 8.98709 9.12992 8.30662C9.56249 7.63144 10.0865 7.05226 10.8616 6.34914Z" fill="#065BDC"/></g><defs><clipPath id="oa-verified-{{ block.id }}"><rect width="16" height="16" fill="white"/></clipPath></defs></svg>
                          <span>{{ block.settings.author_role }}</span>
                        </div>
                      {% endif %}
                    </div>
                  </div>
                </div>
              </div>
            {% endfor %}
          </div>

          {%- comment -%} Doctor media — video or image per tab {%- endcomment -%}
          <div class="oa-authority-image">
            {% for block in endorsement_blocks %}
              {% if block.settings.video != blank %}
                <div x-show="activeTab === {{ forloop.index0 }}" {% if forloop.index0 != 0 %}style="display:none;"{% endif %}>
                  {{ block.settings.video | video_tag:
                    autoplay: true,
                    loop: true,
                    muted: true,
                    playsinline: true,
                    controls: false
                  }}
                </div>
              {% elsif block.settings.image != blank %}
                <div x-show="activeTab === {{ forloop.index0 }}" {% if forloop.index0 != 0 %}style="display:none;"{% endif %}>
                  {{ block.settings.image | image_url: width: 1200 | image_tag:
                    loading: 'lazy',
                    widths: '375, 550, 750, 1000, 1200',
                    sizes: '(max-width: 767px) 100vw, 50vw'
                  }}
                </div>
              {% else %}
                <div x-show="activeTab === {{ forloop.index0 }}" {% if forloop.index0 != 0 %}style="display:none;"{% endif %} class="oa-image-placeholder">
                  {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>

        {% if section.settings.wave_authority_to_trust != blank %}
          <div class="oa-wave oa-wave--bottom">
            {{ section.settings.wave_authority_to_trust | image_url: width: 1600 | image_tag:
              loading: 'lazy',
              widths: '800, 1200, 1600'
            }}
          </div>
        {% endif %}
      </div>
    {% endif %}

    {%- comment -%} === TRUST SIGNALS === {%- endcomment -%}
    {%- assign trust_blocks = section.blocks | where: "type", "trust_item" -%}
    {% if section.settings.show_trust_block and trust_blocks.size > 0 %}
      <div class="oa-trust-wrap">
        {% if section.settings.wave_top_trust != blank %}
          <div class="oa-wave oa-wave--top">
            {{ section.settings.wave_top_trust | image_url: width: 1600 | image_tag:
              loading: 'lazy',
              widths: '800, 1200, 1600'
            }}
          </div>
        {% endif %}

        <div class="oa-trust">
          <div class="oa-trust-row">
            {% for block in trust_blocks %}
              {% unless forloop.first %}
                <div class="oa-trust-divider"></div>
              {% endunless %}
              <div class="oa-trust-item" {{ block.shopify_attributes }}>
                <div class="oa-trust-icon">
                  {% if block.settings.icon != blank %}
                    {{ block.settings.icon | image_url: width: 64 | image_tag:
                      loading: 'lazy',
                      widths: '32, 64'
                    }}
                  {% else %}
                    <svg viewBox="0 0 24 24" fill="none" stroke="{{ section.settings.color_accent }}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                  {% endif %}
                </div>
                <div class="oa-trust-text">
                  {% if block.settings.heading != blank %}
                    <h3>{{ block.settings.heading }}</h3>
                  {% endif %}
                  {% if block.settings.description != blank %}
                    <p>{{ block.settings.description }}</p>
                  {% endif %}
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
      </div>
    {% endif %}

  </div>
</section>

<script src="//unpkg.com/alpinejs" defer></script>

{% schema %}
{
  "name": "Offer Authority Trust",
  "tag": "section",
  "class": "offer-authority-trust-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Offer content"
    },
    {
      "type": "checkbox",
      "id": "show_offer_block",
      "label": "Show offer block",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_rating_badge",
      "label": "Show rating badge",
      "default": true
    },
    {
      "type": "text",
      "id": "rating_text",
      "label": "Rating text",
      "default": "4.4/5 (2,295 + reviews)"
    },
    {
      "type": "checkbox",
      "id": "show_trustpilot_badge",
      "label": "Show Trustpilot badge",
      "default": true
    },
    {
      "type": "inline_richtext",
      "id": "offer_heading",
      "label": "Offer heading",
      "default": "<em><u>Special Offer</u></em> On Now!"
    },
    {
      "type": "inline_richtext",
      "id": "offer_subtext",
      "label": "Offer subtext",
      "default": "Try Your SmoothSpine Massager NOW <u>Risk-Free</u> at an All Time Low Price! Act Now and You'll Get:"
    },
    {
      "type": "header",
      "content": "Free gifts"
    },
    {
      "type": "text",
      "id": "gifts_heading",
      "label": "Gifts heading",
      "default": "Exclusive Offer! Order today for free gifts (valued at $64)!"
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "GET 60% OFF TODAY ONLY!"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "show_cta_note",
      "label": "Show note below button",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_note",
      "label": "Note text",
      "default": "Note: Not Available on Amazon or eBay"
    },
    {
      "type": "header",
      "content": "Offer media"
    },
    {
      "type": "image_picker",
      "id": "offer_image",
      "label": "Product image"
    },
    {
      "type": "header",
      "content": "Authority block"
    },
    {
      "type": "checkbox",
      "id": "show_authority_block",
      "label": "Show authority/endorsement block",
      "default": true
    },
    {
      "type": "header",
      "content": "Trust block"
    },
    {
      "type": "checkbox",
      "id": "show_trust_block",
      "label": "Show trust signals block",
      "default": true
    },
    {
      "type": "header",
      "content": "Wave dividers"
    },
    {
      "type": "paragraph",
      "content": "Upload SVG or PNG wave images to connect sections. Leave blank to hide."
    },
    {
      "type": "image_picker",
      "id": "wave_offer_to_authority",
      "label": "Wave: Offer to Authority"
    },
    {
      "type": "image_picker",
      "id": "wave_top_authority",
      "label": "Wave: Above Authority"
    },
    {
      "type": "image_picker",
      "id": "wave_authority_to_trust",
      "label": "Wave: Authority to Trust"
    },
    {
      "type": "image_picker",
      "id": "wave_top_trust",
      "label": "Wave: Above Trust"
    },
    {
      "type": "header",
      "content": "Colors — Backgrounds"
    },
    {
      "type": "color",
      "id": "color_bg_outer",
      "label": "Outer background",
      "default": "#FDFCFA"
    },
    {
      "type": "color",
      "id": "color_bg_offer",
      "label": "Offer block background",
      "default": "#F8F4EE"
    },
    {
      "type": "color",
      "id": "color_bg_authority",
      "label": "Authority block background",
      "default": "#E5EEFB"
    },
    {
