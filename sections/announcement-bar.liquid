{%- comment -%}
Original announcement text / marquee code has been replaced with responsive image banners.

Desktop banner:
https://cdn.shopify.com/s/files/1/0252/1261/6781/files/Smoothspine_-_Memorial_Day_Sale_Banner_min.png?v=1778701606

Mobile banner:
https://cdn.shopify.com/s/files/1/0252/1261/6781/files/M_-_Smoothspine_-_Memorial_Day_Sale_Banner_v1_Mobile.png?v=1778701607
{%- endcomment -%}

{%- unless request.page_type != 'index' and section.settings.show_on_homepage_only -%}
  <style>
    :root {
      --sticky-announcement-bar-enabled: {%- if section.settings.enable_sticky -%}1{% else %}0{% endif %};
    }

    {%- if section.settings.enable_sticky -%}
      #shopify-section-{{ section.id }} {
        position: sticky;
        top: 0;
        z-index: 20;
      }

      .shopify-section--header ~ #shopify-section-{{ section.id }} {
        top: calc(var(--sticky-header-enabled, 0) * var(--header-height, 0px));
      }
    {%- endif -%}

    #shopify-section-{{ section.id }} .announcement-sale-banner {
      width: 100%;
      overflow: hidden;
      line-height: 0;
    }

    #shopify-section-{{ section.id }} .announcement-sale-banner__link,
    #shopify-section-{{ section.id }} .announcement-sale-banner__picture,
    #shopify-section-{{ section.id }} .announcement-sale-banner__image {
      display: block;
      width: 100%;
    }

    #shopify-section-{{ section.id }} .announcement-sale-banner__image {
      height: auto;
      object-fit: cover;
    }
  </style>

  <height-observer variable="announcement-bar">
    <div class="announcement-sale-banner" role="region" aria-label="Announcement">
      {%- if section.settings.banner_link != blank -%}
        <a href="{{ section.settings.banner_link }}" class="announcement-sale-banner__link">
      {%- endif -%}

        <picture class="announcement-sale-banner__picture">
          <source
            media="(max-width: 749px)"
            srcset="https://cdn.shopify.com/s/files/1/0252/1261/6781/files/M_-_Smoothspine_-_Memorial_Day_Sale_Banner_v1_Mobile.png?v=1778701607"
          >

          <img
            class="announcement-sale-banner__image"
            src="https://cdn.shopify.com/s/files/1/0252/1261/6781/files/Smoothspine_-_Memorial_Day_Sale_Banner_min.png?v=1778701606"
            alt="{{ section.settings.banner_alt | escape }}"
            loading="eager"
            fetchpriority="high"
          >
        </picture>

      {%- if section.settings.banner_link != blank -%}
        </a>
      {%- endif -%}
    </div>
  </height-observer>

  <script>
    (function () {
      var section = document.getElementById('shopify-section-{{ section.id }}');

      if (!section) {
        return;
      }

      function updateAnnouncementBarHeight() {
        document.documentElement.style.setProperty(
          '--announcement-bar-height',
          Math.round(section.clientHeight) + 'px'
        );
      }

      updateAnnouncementBarHeight();

      window.addEventListener('load', updateAnnouncementBarHeight);
      window.addEventListener('resize', updateAnnouncementBarHeight);

      var image = section.querySelector('.announcement-sale-banner__image');

      if (image) {
        image.addEventListener('load', updateAnnouncementBarHeight);
      }

      if ('ResizeObserver' in window) {
        new ResizeObserver(updateAnnouncementBarHeight).observe(section);
      }
    })();
  </script>
{%- endunless -%}

{% schema %}
{
  "name": "Announcement bar",
  "class": "shopify-section--announcement-bar",
  "tag": "aside",
  "max_blocks": 5,
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Announce something here"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_sticky",
      "label": "Enable sticky bar",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_on_homepage_only",
      "label": "Show on homepage only",
      "default": false
    },
    {
      "type": "url",
      "id": "banner_link",
      "label": "Banner link"
    },
    {
      "type": "text",
      "id": "banner_alt",
      "label": "Banner alt text",
      "default": "Memorial Day Sale"
    },
    {
      "type": "select",
      "id": "navigation_mode",
      "label": "Multiple message navigation",
      "options": [
        {
          "value": "arrows",
          "label": "Arrows"
        },
        {
          "value": "scrolling",
          "label": "Auto-scrolling"
        }
      ],
      "default": "arrows"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto rotate between messages",
      "default": false,
      "visible_if": "{{ section.settings.navigation_mode == 'arrows' }}"
    },
    {
      "type": "range",
      "id": "cycle_speed",
      "min": 4,
      "max": 20,
      "step": 1,
      "unit": "sec",
      "label": "Change messages every",
      "default": 6,
      "visible_if": "{{ section.settings.navigation_mode == 'arrows' and section.settings.autoplay }}"
    },
    {
      "type": "range",
      "id": "scrolling_speed",
      "label": "Scrolling speed",
      "min": 10,
      "max": 30,
      "unit": "s",
      "default": 20,
      "visible_if": "{{ section.settings.navigation_mode == 'scrolling' }}"
    },
    {
      "type": "select",
      "id": "text_size",
      "label": "Text size",
      "options": [
        {
          "value": "text-xxs",
          "label": "X-Small"
        },
        {
          "value": "text-xs",
          "label": "Small"
        },
        {
          "value": "text-base",
          "label": "Medium"
        },
        {
          "value": "text-lg",
          "label": "Large"
        }
      ],
      "default": "text-xs"
    },
    {
      "type": "header",
      "content": "Colors",
      "info": "These old color settings are kept for compatibility but are not used by the image banner."
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Background gradient"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text"
    }
  ]
}
{% endschema %}