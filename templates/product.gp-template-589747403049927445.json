        "ggLDYJogvxV_text": "<p>90-DAY MONEY BACK GUARANTEE</p>",
        "ggnoiLlCDO__text": "<p><span style=\"background-color:transparent;color:#000000;font-size:18px;\">If you’re not absolutely thrilled with the results, we will refund every single penny of your investment. No hassle. </span></p>",
        "ggS7aImJyob_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0252/1261/6781/files/gempages_464015397612422087-57c29034-4d6a-46b9-8286-ab77c5f0b8cb.png",
        "gggjLf4dDUF_text": "<p>FREE SHIPPING</p>",
        "gg8yY22gLoi_text": "<p><span style=\"background-color:transparent;color:#000000;font-size:18px;\">We provide fast free shipping and handling for all orders.</span></p>",
        "ggYRGn3_-rs_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0252/1261/6781/files/gempages_464015397612422087-00428b28-be38-4a92-add3-22f1e8e1171f.png",
        "ggtkmBCG_Es_text": "<p>GUARANTEED HIGH QUALITY</p>",
        "ggnO_gdadKG_text": "<p><span style=\"background-color:transparent;color:#000000;font-size:18px;\">Crafted with care using premium materials and natural ingredients - every patch delivers consistent, high-performing relief you can count on.</span></p>"
