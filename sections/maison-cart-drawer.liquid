{% schema %}
{
  "name": "Maison Cart Drawer",
  "settings": [
    {
      "type": "header",
      "content": "Free Shipping Bar"
    },
    {
      "type": "checkbox",
      "id": "show_shipping_bar",
      "label": "Show free shipping bar",
      "default": true
    },
    {
      "type": "range",
      "id": "free_shipping_threshold",
      "label": "Free shipping threshold",
      "min": 0,
      "max": 500,
      "step": 5,
      "unit": "$",
      "default": 100,
      "info": "Cart total needed for free shipping"
    },
    {
      "type": "text",
      "id": "shipping_unlocked_text",
      "label": "Shipping unlocked text",
      "default": "FREE Shipping Unlocked!"
    },
    {
      "type": "text",
      "id": "shipping_remaining_text",
      "label": "Remaining text",
      "default": "Spend [amount] more for FREE Shipping!",
      "info": "[amount] will be replaced with the remaining amount"
    },
    {
      "type": "header",
      "content": "Recommended Products"
    },
    {
      "type": "text",
      "id": "recommendations_title",
      "label": "Heading",
      "default": "Achieve maximum results with"
    },
    {
      "type": "product_list",
      "id": "recommended_products",
      "label": "Products",
      "info": "Products already in cart are hidden automatically.",
      "limit": 10
    },
    {
      "type": "header",
      "content": "Premium Shipping Insurance"
    },
    {
      "type": "checkbox",
      "id": "show_insurance",
      "label": "Show insurance toggle",
      "default": true
    },
    {
      "type": "product",
      "id": "insurance_product",
      "label": "Insurance product",
      "info": "Price is taken from this product"
    },
    {
      "type": "image_picker",
      "id": "insurance_image",
      "label": "Insurance icon/image"
    },
    {
      "type": "text",
      "id": "insurance_title",
      "label": "Insurance title",
      "default": "Premium Shipping Insurance"
    },
    {
      "type": "text",
      "id": "insurance_description",
      "label": "Insurance description",
      "default": "Our standard shipping is free, but with this option your order will be insured against: damage, loss, or theft."
    },
    {
      "type": "header",
      "content": "Checkout"
    },
    {
      "type": "checkbox",
      "id": "show_checkout_button",
      "label": "Show checkout button",
      "default": true
    },
    {
      "type": "text",
      "id": "checkout_button_label",
