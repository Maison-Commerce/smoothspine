  "tag": "section",
  "class": "contact-form-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Still Have Questions? Get In Touch"
