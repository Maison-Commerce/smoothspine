{% comment %}
  Global Trustpilot badge hydration.
  Included once in layout/theme.liquid. Finds all [data-tp-badge] elements on the page,
  fetches live data from the Worker (shared promise per worker URL), and updates
  stars + rating text inside each badge.
{% endcomment %}

<script>
(function() {
  if (window.__mtTrustpilotBadgeInit) return;
  window.__mtTrustpilotBadgeInit = true;

  function starFull() {
    return '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none"><rect width="16" height="16" fill="#00B67A"/><path d="M8 11.1509L10.6071 10.4528L11.6964 14L8 11.1509ZM14 6.56604H9.41071L8 2L6.58929 6.56604H2L5.71429 9.39623L4.30357 13.9623L8.01786 11.1321L10.3036 9.39623L14 6.56604Z" fill="white"/></svg>';
  }
  function starHalf() {
    return '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none"><rect width="16" height="16" fill="#00B67A"/><rect x="8" width="8" height="16" fill="#C5C2BD"/><path d="M8 11.1509L10.6071 10.4528L11.6964 14L8 11.1509ZM14 6.56604H9.41071L8 2L6.58929 6.56604H2L5.71429 9.39623L4.30357 13.9623L8.01786 11.1321L10.3036 9.39623L14 6.56604Z" fill="white"/></svg>';
  }
  function starEmpty() {
    return '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none"><rect width="16" height="16" fill="#C5C2BD"/><path d="M8 11.1509L10.6071 10.4528L11.6964 14L8 11.1509ZM14 6.56604H9.41071L8 2L6.58929 6.56604H2L5.71429 9.39623L4.30357 13.9623L8.01786 11.1321L10.3036 9.39623L14 6.56604Z" fill="white"/></svg>';
  }

  function renderStars(container, stars) {
    var full = Math.floor(stars);
    var hasHalf = (stars - full) >= 0.5;
    var html = '';
    for (var i = 0; i < 5; i++) {
      if (i < full) html += starFull();
      else if (i === full && hasHalf) html += starHalf();
      else html += starEmpty();
    }
    container.innerHTML = html;
  }

  function formatCount(n) {
    return n >= 1000 ? n.toLocaleString('en-US') : String(n);
  }

  function formatRating(data, format) {
    if (!data || data.score == null || data.reviews_count == null) return '';
    switch (format) {
      case 'count_only':
        return formatCount(data.reviews_count) + '+ reviews';
      case 'score_only':
        return data.score + '/5';
      default:
        return data.score + '/5 (' + formatCount(data.reviews_count) + '+ reviews)';
    }
  }

  // Shared fetch promise per worker URL
  var fetchCache = {};
  function fetchData(workerUrl, domain) {
    var url = workerUrl + (workerUrl.indexOf('?') === -1 ? '?domain=' : '&domain=') + encodeURIComponent(domain);
    if (!fetchCache[url]) {
      fetchCache[url] = fetch(url, { cache: 'default' })
        .then(function(r) { return r.ok ? r.json() : null; })
        .catch(function() { return null; });
    }
    return fetchCache[url];
  }

  function hydrate(badge) {
    var workerUrl = badge.dataset.tpWorker;
    var domain = badge.dataset.tpDomain || 'smoothspine.com';
    var format = badge.dataset.tpFormat || 'score_count';
    if (!workerUrl) return;

    fetchData(workerUrl, domain).then(function(data) {
      if (!data) return;
      var starsWrap = badge.querySelector('[data-tp-stars]');
      var ratingEl = badge.querySelector('[data-tp-rating]');
      if (starsWrap && typeof data.stars === 'number') renderStars(starsWrap, data.stars);
      if (ratingEl) ratingEl.textContent = formatRating(data, format);
    });
  }

  function init() {
    document.querySelectorAll('[data-tp-badge]').forEach(hydrate);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
