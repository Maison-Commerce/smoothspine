        "gggjLf4dDUF_text": "<p>FREE SHIPPING</p>",
        "ggnO_gdadKG_text": "<p><span style=\"background-color:transparent;color:#000000;font-size:18px;\">Made of high quality materials. Enjoy consistent, trouble-free performance for a long time.&nbsp;</span></p>",
        "ggnoiLlCDO__text": "<p><span style=\"background-color:transparent;color:#000000;font-size:18px;\">If you’re not absolutely thrilled with the results, we will refund every single penny of your investment. No hassle.&nbsp;</span></p>",
