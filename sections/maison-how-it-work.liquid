      "label": "Button background",
      "default": "#F07E3B"
    },
    {
      "type": "color",
      "id": "color_button_border",
      "label": "Button border",
      "default": "#BF642F"
    },
    {
      "type": "color",
      "id": "color_button_text",
      "label": "Button text",
