        "ggMqSUhQV7T_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0252/1261/6781/files/gempages_464015397612422087-f4fc434c-7412-4e79-98b5-4dc8f7b20abd.png",
        "ggMqSUhQV7T_srcSet_tablet_src": "https://cdn.shopify.com/s/files/1/0252/1261/6781/files/gempages_464015397612422087-b936f1ab-3d8b-4295-9922-326000cffbe2.jpg",
        "ggMqSUhQV7T_srcSet_mobile_src": "https://cdn.shopify.com/s/files/1/0252/1261/6781/files/gempages_464015397612422087-02cd5730-dd94-4602-a8fd-ee82e8a43a88.jpg",
        "ggDMIiaV6W6_text": "<p>\"Even short errands would flare up my hip pain and leave me limping by the end of the day. I’ve tried braces before, but they were either bulky or didn’t help at all. This one felt different right away — snug, supportive, and surprisingly comfortable. <strong>After the first full day wearing it</strong>, I realized… I wasn’t in pain. For the first time in months. It works.\"</p>",
