        },
        "checklist_item_W4iFTV": {
          "type": "checklist_item",
          "settings": {
            "text": "<p><strong>Tested on Real People:</strong> Before we sold a single unit, we had real patients, people with herniated discs, sciatica, and spinal stenosis, test our products for weeks. Their feedback shaped everything.</p>"
          }
        },
        "checklist_item_R39zbA": {
          "type": "checklist_item",
          "settings": {
            "text": "<p><strong>No Shortcuts:</strong> We could have launched faster. We could have cut corners. But we didn't. Because people living with pain deserve better than another cheap gimmick.</p>"
          }
        }
