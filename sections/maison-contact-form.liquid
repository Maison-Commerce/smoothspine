{% comment %}
  Section: Contact Form
  Description: Two-column contact form layout with a heading and lifestyle image
    on the left, and a full contact form (name, email, message, privacy checkbox,
    submit button) on the right. Stacks vertically on mobile with the image hidden.
    Ideal for contact or support pages.

  Dependencies:
  - Font: 'Plus Jakarta Sans' (heading), 'Open Sans' (body) — must be loaded by theme or via @import

  Blocks:
  - (none — fixed form layout)

  Notes:
  - Image is hidden on mobile via CSS
  - Checkbox label text and privacy policy link are merchant-configurable
  - All colors, typography, spacing, and border radius values are merchant-configurable
  - Form submits to Shopify's built-in contact form endpoint when used with Liquid form tag
  - Original source class prefix: maisoncode_contact-form
{% endcomment %}

{% style %}
  #shopify-section-{{ section.id }} .maisoncode_contact-form {
    --s-color-bg: {{ section.settings.color_background }};
    --s-color-bg-mobile: {{ section.settings.color_background_mobile }};
    --s-color-text-primary: {{ section.settings.color_text_primary }};
    --s-color-text-placeholder: {{ section.settings.color_text_placeholder }};
    --s-color-input-bg: {{ section.settings.color_input_bg }};
    --s-color-input-border: {{ section.settings.color_input_border }};
    --s-color-btn-bg: {{ section.settings.color_button_bg }};
    --s-color-btn-border: {{ section.settings.color_button_border }};
    --s-color-btn-text: {{ section.settings.color_button_text }};
    --s-radius-sm: {{ section.settings.radius_small }}px;
    --s-radius-md: {{ section.settings.radius_medium }}px;
    --s-radius-lg: {{ section.settings.radius_large }}px;
    --s-font-size-heading: {{ section.settings.heading_font_size }}px;
    --s-font-size-input: {{ section.settings.input_font_size }}px;
    --s-font-size-checkbox: {{ section.settings.checkbox_font_size }}px;
    --s-font-size-button: {{ section.settings.button_font_size }}px;
    --s-padding-top: {{ section.settings.padding_top }}px;
    --s-padding-bottom: {{ section.settings.padding_bottom }}px;
    --s-padding-horizontal: {{ section.settings.padding_horizontal }}px;
    --s-column-gap: {{ section.settings.column_gap }}px;
    --s-field-gap: {{ section.settings.field_gap }}px;
    --s-form-gap: {{ section.settings.form_gap }}px;
    --s-max-width: {{ section.settings.max_width }}px;
    --s-input-padding: {{ section.settings.input_padding | minus: 1 }}px {{ section.settings.input_padding }}px;
    --s-button-height: {{ section.settings.button_height }}px;

    background-color: var(--s-color-bg);
    font-family: 'Open Sans', sans-serif;
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} .maisoncode_contact-form *,
  #shopify-section-{{ section.id }} .maisoncode_contact-form *::before,
  #shopify-section-{{ section.id }} .maisoncode_contact-form *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  #shopify-section-{{ section.id }} .cf-inner {
    max-width: var(--s-max-width);
    margin: 0 auto;
    display: flex;
    gap: var(--s-column-gap);
    align-items: flex-start;
    padding: var(--s-padding-top) var(--s-padding-horizontal) var(--s-padding-bottom);
  }

  #shopify-section-{{ section.id }} .cf-left {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-self: stretch;
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .cf-heading {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 800;
    font-size: var(--s-font-size-heading);
    line-height: 1.5;
    color: var(--s-color-text-primary);
    text-transform: capitalize;
  }

  #shopify-section-{{ section.id }} .cf-image-wrapper {
    width: 100%;
    max-width: 600px;
    aspect-ratio: 600 / 286;
    border-radius: var(--s-radius-lg);
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .cf-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #shopify-section-{{ section.id }} .cf-image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #e8d5c4 0%, #f0e6da 50%, #d4bfae 100%);
    color: #7a9aa8;
    font-size: 14px;
    text-align: center;
    gap: 8px;
  }

  #shopify-section-{{ section.id }} .cf-image-placeholder svg {
    width: 48px;
    height: 48px;
    opacity: 0.4;
  }

  #shopify-section-{{ section.id }} .cf-right {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--s-form-gap);
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .cf-fields {
    display: flex;
    flex-direction: column;
    gap: var(--s-field-gap);
  }

  #shopify-section-{{ section.id }} .cf-input {
    width: 100%;
    background: var(--s-color-input-bg);
    border: 1px solid var(--s-color-input-border);
    border-radius: var(--s-radius-md);
    padding: var(--s-input-padding);
    font-family: 'Open Sans', sans-serif;
    font-size: var(--s-font-size-input);
    font-weight: 400;
    line-height: 1.5;
    color: var(--s-color-text-primary);
    outline: none;
  }

  #shopify-section-{{ section.id }} .cf-input::placeholder {
    color: var(--s-color-text-placeholder);
  }

  #shopify-section-{{ section.id }} .cf-textarea {
    width: 100%;
    height: {{ section.settings.textarea_height }}px;
    background: var(--s-color-input-bg);
    border: 1px solid var(--s-color-input-border);
    border-radius: var(--s-radius-md);
    padding: var(--s-input-padding);
    font-family: 'Open Sans', sans-serif;
    font-size: var(--s-font-size-input);
    font-weight: 400;
    line-height: 1.5;
    color: var(--s-color-text-primary);
    outline: none;
    resize: vertical;
  }

  #shopify-section-{{ section.id }} .cf-textarea::placeholder {
    color: var(--s-color-text-placeholder);
  }

  #shopify-section-{{ section.id }} .cf-checkbox-row {
    display: flex;
    align-items: center;
    gap: 12px;
    cursor: pointer;
  }

  #shopify-section-{{ section.id }} .cf-checkbox-row input[type="checkbox"] {
    appearance: none;
    -webkit-appearance: none;
    width: 20px;
    height: 20px;
    min-width: 20px;
    background: var(--s-color-input-bg);
    border: 1px solid var(--s-color-input-border);
    border-radius: var(--s-radius-sm);
    cursor: pointer;
    position: relative;
  }

  #shopify-section-{{ section.id }} .cf-checkbox-row input[type="checkbox"]:checked {
    background: var(--s-color-btn-bg);
    border-color: var(--s-color-btn-border);
  }

  #shopify-section-{{ section.id }} .cf-checkbox-row input[type="checkbox"]:checked::after {
    content: '';
    position: absolute;
    top: 3px;
    left: 6px;
    width: 5px;
    height: 10px;
    border: solid #fff;
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }

  #shopify-section-{{ section.id }} .cf-checkbox-label {
    font-family: 'Open Sans', sans-serif;
    font-size: var(--s-font-size-checkbox);
    font-weight: 400;
    line-height: 1.5;
    color: var(--s-color-text-primary);
  }

  #shopify-section-{{ section.id }} .cf-submit-btn {
    width: 100%;
    height: var(--s-button-height);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    background: var(--s-color-btn-bg);
    border: none;
    border-bottom: 4px solid var(--s-color-btn-border);
    border-radius: var(--s-radius-md);
    padding: 16px 32px;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  #shopify-section-{{ section.id }} .cf-submit-btn:hover {
    opacity: 0.9;
  }

  #shopify-section-{{ section.id }} .cf-submit-btn span {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 800;
    font-size: var(--s-font-size-button);
    line-height: 1.5;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--s-color-btn-text);
  }

  @media (max-width: 767px) {
    #shopify-section-{{ section.id }} .maisoncode_contact-form {
      background-color: var(--s-color-bg-mobile);
      --s-padding-top: {{ section.settings.padding_top_mobile }}px;
      --s-padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      --s-font-size-heading: {{ section.settings.heading_font_size_mobile }}px;
      --s-font-size-input: {{ section.settings.input_font_size_mobile }}px;
      --s-font-size-button: {{ section.settings.button_font_size_mobile }}px;
      --s-button-height: {{ section.settings.button_height_mobile }}px;
    }

    #shopify-section-{{ section.id }} .cf-inner {
      flex-direction: column;
      gap: 32px;
      padding: var(--s-padding-top) 20px var(--s-padding-bottom);
      align-items: center;
    }

    #shopify-section-{{ section.id }} .cf-left {
      align-items: center;
    }

    #shopify-section-{{ section.id }} .cf-heading {
      text-align: center;
      line-height: 1.4;
    }

    #shopify-section-{{ section.id }} .cf-image-wrapper {
      display: none;
    }

    #shopify-section-{{ section.id }} .cf-right {
      width: 100%;
    }

    #shopify-section-{{ section.id }} .cf-input {
      height: 56px;
      padding: var(--s-input-padding);
    }
  }
{% endstyle %}

<section class="maisoncode_contact-form">
  <div class="cf-inner">
    <div class="cf-left">
      {% if section.settings.heading != blank %}
        <h2 class="cf-heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.show_image %}
        <div class="cf-image-wrapper">
          {% if section.settings.image != blank %}
            {{ section.settings.image | image_url: width: 1200 | image_tag:
              loading: 'lazy',
              widths: '375, 550, 750, 1000, 1200',
              sizes: '(max-width: 767px) 100vw, 50vw'
            }}
          {% else %}
            <div class="cf-image-placeholder">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21 15 16 10 5 21"/>
              </svg>
              <span>{{ section.settings.image_placeholder_text }}</span>
            </div>
          {% endif %}
        </div>
      {% endif %}
    </div>

    <form class="cf-right" onsubmit="event.preventDefault()">
      <div class="cf-fields">
        {% if section.settings.show_name_field %}
          <input
            type="text"
            class="cf-input"
            placeholder="{{ section.settings.name_placeholder }}"
            aria-label="{{ section.settings.name_placeholder }}"
          />
        {% endif %}

        {% if section.settings.show_email_field %}
          <input
            type="email"
            class="cf-input"
            placeholder="{{ section.settings.email_placeholder }}"
            aria-label="{{ section.settings.email_placeholder }}"
          />
        {% endif %}

        {% if section.settings.show_message_field %}
          <textarea
            class="cf-textarea"
            placeholder="{{ section.settings.message_placeholder }}"
            aria-label="{{ section.settings.message_placeholder }}"
          ></textarea>
        {% endif %}

        {% if section.settings.show_checkbox %}
          <label class="cf-checkbox-row">
            <input type="checkbox" />
            <span class="cf-checkbox-label">{{ section.settings.checkbox_label }}</span>
          </label>
        {% endif %}
      </div>

      {% if section.settings.button_label != blank %}
        <button type="submit" class="cf-submit-btn">
          <span>{{ section.settings.button_label }}</span>
        </button>
      {% endif %}
    </form>
  </div>
</section>

{% schema %}
