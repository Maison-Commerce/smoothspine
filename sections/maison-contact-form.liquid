      "label": "Message field placeholder",
      "default": "Type your message..."
    },
    {
      "type": "text",
      "id": "checkbox_label",
      "label": "Checkbox label",
      "default": "I accept the Privacy Policy"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Send Message"
    },
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_name_field",
      "label": "Show name field",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_email_field",
      "label": "Show email field",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_message_field",
      "label": "Show message field",
