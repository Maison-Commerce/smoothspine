{% comment %}
  Section: About Page Header
  Description: Centered page header with a large heading and supporting
    description paragraph. Ideal for about pages, landing pages, or any
    page that needs a prominent centered text introduction.

  Dependencies:
  - Font: 'Plus Jakarta Sans' (heading), 'Open Sans' (body) — must be loaded by the theme

  Blocks:
  - None

  Notes:
  - Simple centered text section with no repeating elements
  - Heading supports inline_richtext for line breaks and basic formatting
  - All colors, typography, spacing, and max-width are merchant-configurable
  - Original source class prefix: maisoncode_about
{% endcomment %}

{% style %}
  #shopify-section-{{ section.id }} .maisoncode_about-page-header {
    --s-color-bg: {{ section.settings.color_background }};
    --s-color-text-primary: {{ section.settings.color_heading }};
    {%- assign body_opacity = section.settings.body_text_opacity | divided_by: 100.0 -%}
    --s-color-text-secondary: {{ section.settings.color_body_text | color_modify: 'alpha', body_opacity }};
    --s-font-size-heading: {{ section.settings.heading_font_size }}px;
    --s-font-size-body: {{ section.settings.body_font_size }}px;
    --s-padding-top: {{ section.settings.padding_top }}px;
    --s-padding-bottom: {{ section.settings.padding_bottom }}px;
    --s-padding-horizontal: {{ section.settings.padding_horizontal }}px;
    --s-max-width: {{ section.settings.max_width }}px;
    --s-max-width-text: {{ section.settings.max_width_text }}px;
    --s-gap-content: {{ section.settings.content_gap }}px;
    --s-gap-title: {{ section.settings.title_gap }}px;

    font-family: 'Open Sans', sans-serif;
    background-color: var(--s-color-bg);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--s-padding-top) var(--s-padding-horizontal) var(--s-padding-bottom);
    width: 100%;
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} .maisoncode_about-page-header *,
  #shopify-section-{{ section.id }} .maisoncode_about-page-header *::before,
  #shopify-section-{{ section.id }} .maisoncode_about-page-header *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  #shopify-section-{{ section.id }} .maisoncode_about-header-inner {
    max-width: var(--s-max-width);
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--s-gap-content);
  }

  #shopify-section-{{ section.id }} .maisoncode_about-section-title {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--s-gap-title);
    text-align: center;
    max-width: var(--s-max-width-text);
    width: 100%;
  }

  #shopify-section-{{ section.id }} .maisoncode_about-heading {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 800;
    font-size: var(--s-font-size-heading);
    line-height: 1.5;
    color: var(--s-color-text-primary);
    text-transform: capitalize;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .maisoncode_about-description {
    font-family: 'Open Sans', sans-serif;
    font-weight: 400;
    font-size: var(--s-font-size-body);
    line-height: 1.5;
    color: var(--s-color-text-secondary);
    margin: 0;
    max-width: {{ section.settings.max_width_description }}px;
    width: 100%;
  }

  /* Responsive — Mobile */
  @media (max-width: 767px) {
    #shopify-section-{{ section.id }} .maisoncode_about-page-header {
      --s-padding-top: {{ section.settings.padding_top_mobile }}px;
      --s-padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      --s-padding-horizontal: {{ section.settings.padding_horizontal_mobile }}px;
      --s-font-size-heading: {{ section.settings.heading_font_size_mobile }}px;
      --s-font-size-body: {{ section.settings.body_font_size_mobile }}px;
    }

    #shopify-section-{{ section.id }} .maisoncode_about-section-title {
      gap: {{ section.settings.title_gap_mobile }}px;
      max-width: 100%;
    }

    #shopify-section-{{ section.id }} .maisoncode_about-heading {
      line-height: 1.4;
    }

    #shopify-section-{{ section.id }} .maisoncode_about-description {
      max-width: 100%;
    }
  }
{% endstyle %}

<section class="maisoncode_about-page-header">
  <div class="maisoncode_about-header-inner">
    <div class="maisoncode_about-section-title">
      {% if section.settings.heading != blank %}
        <h2 class="maisoncode_about-heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.description != blank %}
        <p class="maisoncode_about-description">{{ section.settings.description }}</p>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "About Page Header",
  "tag": "section",
  "class": "about-page-header-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "We're Not Here To<br>Let You Feel A Miracle."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "We're here because we know what it's like to live with chronic pain. And we know how many \"solutions\" have let you down before."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "color_background",
      "label": "Background",
      "default": "#F8F4EE"
    },
    {
      "type": "color",
      "id": "color_heading",
      "label": "Heading text",
      "default": "#102A43"
    },
    {
      "type": "color",
      "id": "color_body_text",
      "label": "Body text",
      "default": "#102A43"
    },
    {
      "type": "range",
      "id": "body_text_opacity",
      "label": "Body text opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 75
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading font size (desktop)",
      "min": 20,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "label": "Heading font size (mobile)",
      "min": 16,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "body_font_size",
      "label": "Body font size (desktop)",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "body_font_size_mobile",
      "label": "Body font size (mobile)",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "header",
      "content": "Spacing & Layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding (desktop)",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding (desktop)",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Horizontal padding (desktop)",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top padding (mobile)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom padding (mobile)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_horizontal_mobile",
      "label": "Horizontal padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "content_gap",
      "label": "Content gap",
      "min": 8,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "title_gap",
      "label": "Gap between heading and description",
      "min": 4,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "title_gap_mobile",
      "label": "Gap between heading and description (mobile)",
      "min": 4,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max content width",
      "min": 600,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 1400
    },
    {
      "type": "range",
      "id": "max_width_text",
      "label": "Max text block width",
      "min": 300,
      "max": 900,
      "step": 20,
      "unit": "px",
      "default": 600
    },
    {
      "type": "range",
      "id": "max_width_description",
      "label": "Max description width",
      "min": 300,
      "max": 800,
      "step": 20,
      "unit": "px",
      "default": 544
    }
  ],
  "presets": [
    {
      "name": "About Page Header"
    }
  ]
}
{% endschema %}
