        "ggc8Jx1axa0_text": "<p>Name</p>",
        "ggFoPISFWBa_text": "<p>Verified Purchase</p>",
        "gglxMzPDaXv_background_desktop_video": "https://www.youtube.com/watch?v=cyzh48XRS4M",
        "gglxMzPDaXv_background_desktop_videoHtml5": "https://media.w3.org/2010/05/sintel/trailer.mp4",
        "ggTWbR7J5A3_text": "<p>(4.7/5 Rated By 21,539+ Customers)</p>",
        "ggiIss1Rofn_customContent_prefix": "Save",
        "ggavmk0YmvV_text": "<p>Every step feels like a knife to the hip?</p><p><i><u>Stop masking the pain. Fix the root cause - and finally move without flinching.</u></i></p>",
        "ggs0hHOJvUw_text": "<p>The SmoothSpine™ Align Hip &amp; Back Stabilizer uses advanced compression to support your hips and lower back, relieving pressure on the sciatic nerve and helping your body heal naturally - all from the comfort of home.</p>",
        "gg6tXSXNWai_text": "<p>Rapid relief from stabbing sciatica and deep hip pain</p>",
        "ggbcW1KUC8b_text": "<p>Locks your spine and hips into perfect alignment</p>",
        "ggxUNGGnafQ_text": "<p>Reduces nerve pressure and inflammation from day one</p>",
        "ggM-PIG0RRS_text": "<p>Wear it anytime - even while walking or watching TV</p>",
        "ggifZ8Bz922_label": "Add to cart",
        "ggifZ8Bz922_outOfStockLabel": "Out of stock",
