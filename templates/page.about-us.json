      "blocks": {
        "paragraph_pWNCj9": {
          "type": "paragraph",
          "settings": {
            "text": "It's the messages we get from customers like Margaret, who told us she slept through the night for the first time in months."
          }
        },
        "paragraph_ftaaYG": {
          "type": "paragraph",
          "settings": {
            "text": "Or Richard, who said he almost didn't buy it because he'd been burned before, but now he can walk his dog without stopping every few minutes."
          }
        },
        "paragraph_DyCmVb": {
          "type": "paragraph",
          "settings": {
            "text": "Or Carol, who wrote, \"I thought bending down to tie my shoes was gone for good. Thank you for giving me that back.\""
          }
        },
        "paragraph_7bpBjX": {
          "type": "paragraph",
          "settings": {
            "text": "That's why we do this. Not every product works for every person, we're honest about that. But when it does work, it changes lives."
          }
        },
        "paragraph_DbpJTa": {
          "type": "paragraph",
          "settings": {
            "text": "That question became SmoothSpine."
          }
        }
      },
