        "checklist_item_VwkkVk": {
          "type": "checklist_item",
          "settings": {
            "text": "<p><strong>Real Clinical Input:</strong> Every feature in our devices was reviewed by licensed physical therapists who treat chronic back pain every day. They told us what actually works, and what doesn't.</p>"
