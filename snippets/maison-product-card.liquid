{%- comment -%}
  Maison Product Card
  Renders a product card matching the Maison design system.

  Supported variables:
  * product: the product to render (required)
  * position: position in list (for lazy loading)
{%- endcomment -%}

{%- assign variant = product.selected_or_first_available_variant -%}
{%- assign compare_price = variant.compare_at_price -%}
{%- assign price = variant.price -%}
{%- assign on_sale = false -%}
{%- if compare_price > price -%}
  {%- assign on_sale = true -%}
  {%- assign save_percent = compare_price | minus: price | times: 100 | divided_by: compare_price -%}
{%- endif -%}

{%- assign rating_value = product.metafields.reviews.rating.value.rating | round: 1 | default: 0 -%}
{%- assign rating_count = product.metafields.reviews.rating_count.value | default: 0 -%}

<div class="mpc">
  {%- comment -%} Image {%- endcomment -%}
  <a href="{{ product.url }}" class="mpc__image-wrap">
    {%- if product.featured_media -%}
      {%- liquid
        assign loading = 'lazy'
        if position <= 4
          assign loading = 'eager'
        endif
      -%}
      <img
        src="{{ product.featured_media | image_url: width: 600 }}"
        srcset="{{ product.featured_media | image_url: width: 300 }} 300w, {{ product.featured_media | image_url: width: 450 }} 450w, {{ product.featured_media | image_url: width: 600 }} 600w"
        sizes="(max-width: 767px) 50vw, 25vw"
        alt="{{ product.featured_media.alt | escape | default: product.title | escape }}"
        width="{{ product.featured_media.width }}"
        height="{{ product.featured_media.height }}"
        loading="{{ loading }}"
        class="mpc__image"
      >
    {%- else -%}
      <div class="mpc__image-placeholder"></div>
    {%- endif -%}
  </a>

  {%- comment -%} Content {%- endcomment -%}
  <div class="mpc__content">
    {%- comment -%} Text block {%- endcomment -%}
    <div class="mpc__text">
      {%- comment -%} Title + Description {%- endcomment -%}
      <div class="mpc__title-group">
        <a href="{{ product.url }}" class="mpc__title">{{ product.title }}</a>
        {%- if product.metafields.custom.maison_short_product_card_description != blank -%}
          <p class="mpc__description">{{ product.metafields.custom.maison_short_product_card_description }}</p>
        {%- endif -%}
      </div>

      {%- comment -%} Rating {%- endcomment -%}
      {%- if rating_count > 0 -%}
        <div class="mpc__rating">
          <div class="mpc__stars">
            {%- assign full_stars = rating_value | floor -%}
            {%- for i in (1..5) -%}
              {%- if i <= full_stars -%}
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M7.68323 1.53009C7.71245 1.47107 7.75758 1.42138 7.81353 1.38664C7.86949 1.3519 7.93404 1.3335 7.9999 1.3335C8.06576 1.3335 8.13031 1.3519 8.18626 1.38664C8.24222 1.42138 8.28735 1.47107 8.31656 1.53009L9.85656 4.64943C9.95802 4.85474 10.1078 5.03236 10.293 5.16706C10.4782 5.30176 10.6933 5.3895 10.9199 5.42276L14.3639 5.92676C14.4292 5.93621 14.4905 5.96374 14.5409 6.00622C14.5913 6.04871 14.6288 6.10446 14.6492 6.16716C14.6696 6.22987 14.6721 6.29703 14.6563 6.36105C14.6405 6.42507 14.6071 6.48339 14.5599 6.52943L12.0692 8.95476C11.905 9.11483 11.7821 9.31241 11.7111 9.53051C11.6402 9.74861 11.6233 9.98069 11.6619 10.2068L12.2499 13.6334C12.2614 13.6987 12.2544 13.7658 12.2296 13.8272C12.2048 13.8886 12.1632 13.9418 12.1096 13.9808C12.056 14.0197 11.9925 14.0428 11.9265 14.0474C11.8604 14.052 11.7944 14.0379 11.7359 14.0068L8.65723 12.3881C8.45438 12.2816 8.22868 12.2259 7.99956 12.2259C7.77044 12.2259 7.54475 12.2816 7.3419 12.3881L4.2639 14.0068C4.20545 14.0377 4.1395 14.0516 4.07353 14.0469C4.00757 14.0422 3.94424 14.0191 3.89076 13.9802C3.83728 13.9413 3.79579 13.8882 3.771 13.8269C3.74622 13.7656 3.73914 13.6986 3.75056 13.6334L4.3379 10.2074C4.37669 9.98125 4.35989 9.74902 4.28892 9.53079C4.21796 9.31256 4.09497 9.11486 3.93056 8.95476L1.4399 6.53009C1.39229 6.48411 1.35856 6.42569 1.34254 6.36147C1.32652 6.29726 1.32886 6.22984 1.34928 6.16689C1.36971 6.10393 1.40741 6.04799 1.45808 6.00541C1.50876 5.96284 1.57037 5.93536 1.6359 5.92609L5.07923 5.42276C5.30607 5.38976 5.52149 5.30213 5.70695 5.16742C5.89242 5.0327 6.04237 4.85494 6.1439 4.64943L7.68323 1.53009Z" fill="#FEC84B" stroke="#FEC84B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {%- else -%}
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M7.68323 1.53009C7.71245 1.47107 7.75758 1.42138 7.81353 1.38664C7.86949 1.3519 7.93404 1.3335 7.9999 1.3335C8.06576 1.3335 8.13031 1.3519 8.18626 1.38664C8.24222 1.42138 8.28735 1.47107 8.31656 1.53009L9.85656 4.64943C9.95802 4.85474 10.1078 5.03236 10.293 5.16706C10.4782 5.30176 10.6933 5.3895 10.9199 5.42276L14.3639 5.92676C14.4292 5.93621 14.4905 5.96374 14.5409 6.00622C14.5913 6.04871 14.6288 6.10446 14.6492 6.16716C14.6696 6.22987 14.6721 6.29703 14.6563 6.36105C14.6405 6.42507 14.6071 6.48339 14.5599 6.52943L12.0692 8.95476C11.905 9.11483 11.7821 9.31241 11.7111 9.53051C11.6402 9.74861 11.6233 9.98069 11.6619 10.2068L12.2499 13.6334C12.2614 13.6987 12.2544 13.7658 12.2296 13.8272C12.2048 13.8886 12.1632 13.9418 12.1096 13.9808C12.056 14.0197 11.9925 14.0428 11.9265 14.0474C11.8604 14.052 11.7944 14.0379 11.7359 14.0068L8.65723 12.3881C8.45438 12.2816 8.22868 12.2259 7.99956 12.2259C7.77044 12.2259 7.54475 12.2816 7.3419 12.3881L4.2639 14.0068C4.20545 14.0377 4.1395 14.0516 4.07353 14.0469C4.00757 14.0422 3.94424 14.0191 3.89076 13.9802C3.83728 13.9413 3.79579 13.8882 3.771 13.8269C3.74622 13.7656 3.73914 13.6986 3.75056 13.6334L4.3379 10.2074C4.37669 9.98125 4.35989 9.74902 4.28892 9.53079C4.21796 9.31256 4.09497 9.11486 3.93056 8.95476L1.4399 6.53009C1.39229 6.48411 1.35856 6.42569 1.34254 6.36147C1.32652 6.29726 1.32886 6.22984 1.34928 6.16689C1.36971 6.10393 1.40741 6.04799 1.45808 6.00541C1.50876 5.96284 1.57037 5.93536 1.6359 5.92609L5.07923 5.42276C5.30607 5.38976 5.52149 5.30213 5.70695 5.16742C5.89242 5.0327 6.04237 4.85494 6.1439 4.64943L7.68323 1.53009Z" fill="none" stroke="#E8E6E3" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {%- endif -%}
            {%- endfor -%}
          </div>
          <span class="mpc__review-count">({{ rating_count | default: '0' }} Reviews)</span>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Price {%- endcomment -%}
    <div class="mpc__price-row">
      {%- if on_sale -%}
        <div class="mpc__prices">
          <span class="mpc__compare-price">{{ compare_price | money }}</span>
          <span class="mpc__sale-price">{{ price | money }}</span>
        </div>
        <span class="mpc__save-badge">Save {{ save_percent }}%</span>
      {%- else -%}
        <span class="mpc__sale-price">{{ price | money }}</span>
      {%- endif -%}
    </div>

    {%- comment -%} CTA Button {%- endcomment -%}
    <a href="{{ product.url }}" class="mpc__button">Shop Now</a>
  </div>
</div>

<style>
  .mpc {
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  /* Image */
  .mpc__image-wrap {
    display: block;
    aspect-ratio: 1 / 1;
    border-radius: 16px;
    overflow: hidden;
    position: relative;
  }

  .mpc__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .mpc__image-placeholder {
    width: 100%;
    height: 100%;
    background: #F8F4EE;
  }

  /* Content */
  .mpc__content {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding: 12px;
  }

  /* Text block */
  .mpc__text {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .mpc__title-group {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .mpc__title {
    font-family: 'Open Sans', sans-serif;
    font-weight: 700;
    font-size: 14px;
    line-height: 1.5;
    color: #102A43;
    text-decoration: none;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
  }

  .mpc__description {
    font-family: 'Open Sans', sans-serif;
    font-weight: 400;
    font-size: 14px;
    line-height: 1.5;
    color: rgba(16, 42, 67, 0.75);
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  /* Rating */
  .mpc__rating {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .mpc__stars {
    display: flex;
    gap: 2px;
    align-items: center;
  }

  .mpc__stars svg {
    width: 16px;
    height: 16px;
    display: block;
  }

  .mpc__review-count {
    font-family: 'Open Sans', sans-serif;
    font-weight: 600;
    font-size: 12px;
    line-height: 1.5;
    color: rgba(16, 42, 67, 0.75);
    white-space: nowrap;
  }

  /* Price */
  .mpc__price-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .mpc__prices {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .mpc__compare-price {
    font-family: 'Open Sans', sans-serif;
    font-weight: 600;
    font-size: 14px;
    line-height: 1.5;
    color: #102A43;
    opacity: 0.5;
    text-decoration: line-through;
  }

  .mpc__sale-price {
    font-family: 'Open Sans', sans-serif;
    font-weight: 700;
    font-size: 16px;
    line-height: 1.5;
    color: #102A43;
  }

  .mpc__save-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 24px;
    padding: 0 12px;
    background-color: #12B76A;
    border-radius: 4px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 800;
    font-size: 12px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #FFFFFF;
    white-space: nowrap;
  }

  /* Button */
  .mpc__button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 36px;
    background-color: #F07E3B;
    border-bottom: 4px solid #BF642F;
    border-radius: 8px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 800;
    font-size: 12px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #FFFCFB;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .mpc__button:hover {
    opacity: 0.9;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 767px) {
    .mpc__content {
      gap: 12px;
      padding: 8px 4px 4px;
    }

    .mpc__title-group {
      gap: 4px;
    }

    .mpc__title {
      font-size: 12px;
    }

    .mpc__description {
      font-size: 12px;
    }

    .mpc__stars svg {
      width: 12px;
      height: 12px;
    }

    .mpc__review-count {
      font-size: 10px;
    }

    .mpc__price-row {
      flex-direction: row;
      gap: 8px;
    }

    .mpc__prices {
      flex-direction: column;
      gap: 0;
      align-items: flex-start;
    }

    .mpc__compare-price {
      font-size: 10px;
    }

    .mpc__sale-price {
      font-size: 12px;
    }

    .mpc__save-badge {
      height: 20px;
      padding: 0 8px;
      font-size: 8px;
    }

    .mpc__button {
      height: 32px;
      font-size: 12px;
    }
  }
</style>
