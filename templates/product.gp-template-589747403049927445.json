        "checksum": "d7b38b91082ec3eda08c212e25f5f280e0c4b23b475d3fced6109af6dff2a257_1_1_1_0__1",
        "ggZDZF7ux33_text": "<p>STEP 1</p>",
        "ggmue6CCCwq_text": "<p><strong>Peel off the</strong></p><p><strong>protective backing</strong></p>",
        "ggUzc7iWT3z_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0252/1261/6781/files/gempages_464015397612422087-22550798-2bf0-4f09-abb0-d6be9cbb52f7.png",
        "gg6uV7yqBqY_text": "<p>STEP 2</p>",
        "ggBNVTsuXWb_text": "<p><strong>Stick the patch directly on your lower back, spine, or any painful area</strong></p>",
        "ggTns7PMuSs_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0252/1261/6781/files/gempages_464015397612422087-ae3354f0-8c22-4095-b3d1-b2685d49a0aa.png",
        "gg5tUayJ_Gz_text": "<p>STEP 3</p>",
        "ggU2h5Y-nxZ_text": "<p><strong>Let it work - enjoy up to 8–12 hours of continuous relief</strong></p>",
        "ggHbn1g2VIu_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0252/1261/6781/files/gempages_464015397612422087-9635ece7-9579-4b78-9301-49bb7721a00c.png",
        "gg0i-Ub2lvM_text": "<p>Use <strong>during the day</strong> to stay mobile, or <strong>overnight</strong> to wake up without stiffness.</p>",
        "ggdQgMyS6V9_text": "<p>The more <strong>consistently you use the patches</strong>, the more support your body gets - reducing flare-ups, improving flexibility, and helping you stay pain-free longer.</p>",
        "ggn3ggyX715_text": "<p>No pills, no prep, no complicated routines. Just stick, feel the heat, and <strong>get back to your life</strong>.</p>"
      }
    },
    "gp_section_589747403201512213": {
      "type": "gp-section-589747403201512213",
      "settings": {
