{% comment %}
  Section: UGC Tabs
  Description: CTA banner with heading, description, and button on top.
    Two tabs below, each containing custom Liquid content.
    Tabs switch content via Alpine.js.

  Dependencies:
  - Font: 'Plus Jakarta Sans', 'Open Sans' — must be loaded by theme
{% endcomment %}

{% style %}
  #shopify-section-{{ section.id }} .maisoncode_ugc-tabs {
    background-color: {{ section.settings.color_background }};
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_horizontal }}px {{ section.settings.padding_bottom }}px;
    width: 100%;
    box-sizing: border-box;
    font-family: 'Open Sans', sans-serif;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: {{ section.settings.section_gap }}px;
    max-width: 1280px;
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .maisoncode_ugc-tabs *,
  #shopify-section-{{ section.id }} .maisoncode_ugc-tabs *::before,
  #shopify-section-{{ section.id }} .maisoncode_ugc-tabs *::after {
    box-sizing: border-box;
    margin: 0;
  }

  /* CTA Banner */
  #shopify-section-{{ section.id }} .ugc-tabs-cta {
    background-color: {{ section.settings.color_cta_bg }};
    border-radius: 16px;
    padding: 48px 64px;
    display: flex;
    align-items: center;
    gap: 64px;
    width: 100%;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .ugc-tabs-cta-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  #shopify-section-{{ section.id }} .ugc-tabs-cta-heading {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 800;
    font-size: 20px;
    line-height: 1.4;
    color: {{ section.settings.color_heading }};
  }

  #shopify-section-{{ section.id }} .ugc-tabs-cta-desc {
    font-family: 'Open Sans', sans-serif;
    font-weight: 400;
    font-size: 14px;
    line-height: 1.5;
    color: {{ section.settings.color_heading | color_modify: 'alpha', 0.75 }};
  }

  #shopify-section-{{ section.id }} .ugc-tabs-cta-btn {
    flex-shrink: 0;
    width: 320px;
    height: 44px;
    background: {{ section.settings.color_btn_bg }};
    border: none;
    border-bottom: 4px solid {{ section.settings.color_btn_border }};
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  #shopify-section-{{ section.id }} .ugc-tabs-cta-btn:hover { opacity: 0.92; }

  #shopify-section-{{ section.id }} .ugc-tabs-cta-btn span {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 800;
    font-size: 14px;
    line-height: 1.5;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: {{ section.settings.color_btn_text }};
    white-space: nowrap;
  }

  /* Tabs row */
  #shopify-section-{{ section.id }} .ugc-tabs-row {
    display: flex;
    gap: 16px;
    width: 100%;
    flex-wrap: wrap;
  }

  #shopify-section-{{ section.id }} .ugc-tab-btn {
    flex: 1;
    min-width: 0;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 16px;
    border-radius: 8px;
    cursor: pointer;
    border: 1px solid {{ section.settings.color_tab_inactive_border }};
    background: {{ section.settings.color_tab_inactive_bg }};
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 800;
    font-size: 14px;
    line-height: 1.5;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: {{ section.settings.color_tab_inactive_text }};
    white-space: nowrap;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }

  #shopify-section-{{ section.id }} .ugc-tab-btn.is-active {
    background: {{ section.settings.color_tab_active_bg }};
    color: {{ section.settings.color_tab_active_text }};
    border-color: {{ section.settings.color_tab_active_bg }};
  }

  /* Tab content */
  #shopify-section-{{ section.id }} .ugc-tab-content {
    width: 100%;
  }

  /* VideoAsk grid */
  #shopify-section-{{ section.id }} .ugc-videoask {
    width: 100%;
  }

  #shopify-section-{{ section.id }} .ugc-videoask__loading,
  #shopify-section-{{ section.id }} .ugc-videoask__error {
    text-align: center;
    padding: 40px 20px;
    font-family: 'Open Sans', sans-serif;
    font-size: 14px;
    color: rgba(16, 42, 67, 0.6);
  }

  #shopify-section-{{ section.id }} .ugc-videoask__grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .ugc-videoask-card {
    position: relative;
    aspect-ratio: 9 / 16;
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
    background: #1a1a1a;
    transition: transform 0.2s ease;
  }

  #shopify-section-{{ section.id }} .ugc-videoask-card:hover {
    transform: scale(1.02);
  }

  #shopify-section-{{ section.id }} .ugc-videoask-card__media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #shopify-section-{{ section.id }} .ugc-videoask-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0) 50%);
    display: flex;
    align-items: flex-end;
    padding: 12px;
  }

  #shopify-section-{{ section.id }} .ugc-videoask-card__name {
    font-family: 'Open Sans', sans-serif;
    font-weight: 600;
    font-size: 13px;
    color: #fff;
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .ugc-videoask-card__play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(8px);
    transition: background 0.2s ease;
  }

  #shopify-section-{{ section.id }} .ugc-videoask-card:hover .ugc-videoask-card__play {
    background: rgba(0, 0, 0, 0.7);
  }

  #shopify-section-{{ section.id }} .ugc-videoask-card__play svg {
    width: 20px;
    height: 20px;
    margin-left: 2px;
  }

  /* Fullscreen modal */
  .ugc-videoask-modal {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.92);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .ugc-videoask-modal[hidden] { display: none; }

  .ugc-videoask-modal__close {
    position: absolute;
    top: 20px;
    right: 20px;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
    transition: background 0.2s;
  }

  .ugc-videoask-modal__close:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  .ugc-videoask-modal__video {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: 90vh;
    aspect-ratio: 9 / 16;
    border-radius: 12px;
    background: #000;
  }

  /* Tablet */
  @media (max-width: 1199px) {
    #shopify-section-{{ section.id }} .ugc-videoask__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (max-width: 949px) {
    #shopify-section-{{ section.id }} .ugc-videoask__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }
  }

  /* Mobile */
  @media (max-width: 949px) {
    #shopify-section-{{ section.id }} .maisoncode_ugc-tabs {
      padding: {{ section.settings.padding_top_mobile }}px {{ section.settings.padding_horizontal_mobile }}px {{ section.settings.padding_bottom_mobile }}px;
      gap: 20px;
    }

    #shopify-section-{{ section.id }} .ugc-tabs-cta {
      flex-direction: column;
      padding: 20px;
      gap: 24px;
      text-align: center;
    }

    #shopify-section-{{ section.id }} .ugc-tabs-cta-btn {
      width: 100%;
    }

    #shopify-section-{{ section.id }} .ugc-tabs-row {
      gap: 16px;
      flex-wrap: nowrap;
      overflow-x: auto;
      scrollbar-width: none;
    }

    #shopify-section-{{ section.id }} .ugc-tabs-row::-webkit-scrollbar { display: none; }

    #shopify-section-{{ section.id }} .ugc-tab-btn {
      flex: 0 0 auto;
      font-size: 12px;
    }

    #shopify-section-{{ section.id }} .ugc-videoask__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }

    #shopify-section-{{ section.id }} .ugc-videoask-card__name {
      font-size: 12px;
    }

    .ugc-videoask-modal__video {
      height: auto;
      max-height: 85vh;
      width: 100%;
    }
  }
{% endstyle %}

<section class="maisoncode_ugc-tabs" x-data="{ activeTab: 0 }">

  {%- comment -%} CTA Banner {%- endcomment -%}
  {% if section.settings.show_cta %}
    <div class="ugc-tabs-cta">
      <div class="ugc-tabs-cta-content">
        {% if section.settings.cta_heading != blank %}
          <h2 class="ugc-tabs-cta-heading">{{ section.settings.cta_heading }}</h2>
        {% endif %}
        {% if section.settings.cta_description != blank %}
          <p class="ugc-tabs-cta-desc">{{ section.settings.cta_description }}</p>
        {% endif %}
      </div>
      {% if section.settings.cta_button_label != blank %}
        <a
          {% if section.settings.cta_button_link != blank %}href="{{ section.settings.cta_button_link }}"{% endif %}
          class="ugc-tabs-cta-btn"
        >
          <span>{{ section.settings.cta_button_label }}</span>
        </a>
      {% endif %}
    </div>
  {% endif %}

  {%- comment -%} Build tabs array — only include tabs with a label {%- endcomment -%}
  {%- assign tab_labels = '' -%}
  {%- assign tab_uses_va = '' -%}
  {%- assign tab_tags = '' -%}
  {%- assign tab_contents_keys = '' -%}
  {%- for i in (1..4) -%}
    {%- assign label_key = 'tab_' | append: i | append: '_label' -%}
    {%- assign label = section.settings[label_key] -%}
    {%- if label != blank -%}
      {%- assign tab_labels = tab_labels | append: label | append: '|||' -%}
      {%- assign use_va_key = 'tab_' | append: i | append: '_use_videoask' -%}
      {%- if section.settings[use_va_key] -%}
        {%- assign tab_uses_va = tab_uses_va | append: '1|||' -%}
      {%- else -%}
        {%- assign tab_uses_va = tab_uses_va | append: '0|||' -%}
      {%- endif -%}
      {%- assign tag_key = 'tab_' | append: i | append: '_videoask_tag' -%}
      {%- assign tab_tags = tab_tags | append: section.settings[tag_key] | append: '|||' -%}
      {%- assign tab_contents_keys = tab_contents_keys | append: i | append: '|||' -%}
    {%- endif -%}
  {%- endfor -%}
  {%- assign labels_arr = tab_labels | split: '|||' -%}
  {%- assign uses_va_arr = tab_uses_va | split: '|||' -%}
  {%- assign tags_arr = tab_tags | split: '|||' -%}
  {%- assign content_keys_arr = tab_contents_keys | split: '|||' -%}

  {%- comment -%} Tabs row {%- endcomment -%}
  {%- if labels_arr.size > 0 -%}
    <div class="ugc-tabs-row">
      {%- for label in labels_arr -%}
        <button
          type="button"
          class="ugc-tab-btn"
          :class="{ 'is-active': activeTab === {{ forloop.index0 }} }"
          @click="activeTab = {{ forloop.index0 }}"
        >{{ label }}</button>
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- comment -%} Tab contents {%- endcomment -%}
  {%- assign has_any_videoask = false -%}
  {%- for label in labels_arr -%}
    {%- assign idx = forloop.index0 -%}
    {%- assign uses_va = uses_va_arr[idx] -%}
    {%- assign tag_filter = tags_arr[idx] -%}
    {%- assign content_idx = content_keys_arr[idx] -%}
    {%- assign content_key = 'tab_' | append: content_idx | append: '_content' -%}

    <div class="ugc-tab-content" x-show="activeTab === {{ idx }}" x-effect="if (activeTab === {{ idx }}) setTimeout(() => window.dispatchEvent(new Event('resize')), 100)">
      {%- if uses_va == '1' -%}
        {%- assign has_any_videoask = true -%}
        <div
          class="ugc-videoask"
          data-videoask-url="{{ section.settings.videoask_worker_url }}"
          data-videoask-tag="{{ tag_filter }}"
        >
          <div class="ugc-videoask__loading">Loading testimonials…</div>
          <div class="ugc-videoask__grid" hidden></div>
          <div class="ugc-videoask__error" hidden>Could not load testimonials.</div>
        </div>
      {%- else -%}
        {{ section.settings[content_key] }}
      {%- endif -%}
    </div>
  {%- endfor -%}

  {%- if has_any_videoask -%}
    {%- comment -%} Fullscreen video modal (single, shared) {%- endcomment -%}
    <div class="ugc-videoask-modal" hidden role="dialog" aria-modal="true" aria-label="Video testimonial">
      <button type="button" class="ugc-videoask-modal__close" aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M6 6L18 18M6 18L18 6" stroke="white" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
      <video class="ugc-videoask-modal__video" controls playsinline></video>
    </div>
  {%- endif -%}

</section>

<script>
  (function() {
    var section = document.getElementById('shopify-section-{{ section.id }}');
    if (!section) return;

    var containers = section.querySelectorAll('.ugc-videoask');
    var modal = section.querySelector('.ugc-videoask-modal');
    if (containers.length === 0 || !modal) return;

    var modalVideo = modal.querySelector('.ugc-videoask-modal__video');
    var modalClose = modal.querySelector('.ugc-videoask-modal__close');

    // Move modal to body to escape any transform/contain stacking context
    if (modal.parentNode !== document.body) {
      document.body.appendChild(modal);
    }

    function escapeHtml(s) {
      var d = document.createElement('div');
      d.textContent = s || '';
      return d.innerHTML;
    }

    function openModal(videoUrl) {
      modalVideo.src = videoUrl;
      modal.hidden = false;
      document.body.style.overflow = 'hidden';
      modalVideo.play().catch(function() {});
    }

    function closeModal() {
      modal.hidden = true;
      modalVideo.pause();
      modalVideo.removeAttribute('src');
      modalVideo.load();
      document.body.style.overflow = '';
    }

    modalClose.addEventListener('click', closeModal);
    modal.addEventListener('click', function(e) {
      if (e.target === modal) closeModal();
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && !modal.hidden) closeModal();
    });

    // Shared cache: fetch reviews once, share across all containers
    var reviewsPromise = null;
    function getReviews(workerUrl) {
      if (!reviewsPromise) {
        reviewsPromise = fetch(workerUrl, { cache: 'default' })
          .then(function(r) {
            if (!r.ok) throw new Error('HTTP ' + r.status);
            return r.json();
          })
          .then(function(d) { return (d && d.reviews) || []; });
      }
      return reviewsPromise;
    }

    function initContainer(container) {
      var loadingEl = container.querySelector('.ugc-videoask__loading');
      var gridEl = container.querySelector('.ugc-videoask__grid');
      var errorEl = container.querySelector('.ugc-videoask__error');
      var workerUrl = container.dataset.videoaskUrl;
      var tagFilter = (container.dataset.videoaskTag || '').trim().toLowerCase();
      var loaded = false;

      function renderGrid(reviews) {
        var html = reviews.map(function(r) {
          var thumb = r.gif || r.thumbnail || '';
          return '<div class="ugc-videoask-card" data-video="' + escapeHtml(r.video_url) + '">'
            + '<img class="ugc-videoask-card__media" src="' + escapeHtml(thumb) + '" alt="' + escapeHtml(r.name) + '" loading="lazy">'
            + '<div class="ugc-videoask-card__play">'
            +   '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg>'
            + '</div>'
            + '<div class="ugc-videoask-card__overlay">'
            +   '<div class="ugc-videoask-card__name">' + escapeHtml(r.name) + '</div>'
            + '</div>'
            + '</div>';
        }).join('');
        gridEl.innerHTML = html;

        gridEl.querySelectorAll('.ugc-videoask-card').forEach(function(card) {
          card.addEventListener('click', function() {
            openModal(card.dataset.video);
          });
        });
      }

      function load() {
        if (loaded) return;
        loaded = true;
        getReviews(workerUrl)
          .then(function(reviews) {
            // Filter by tag if set
            var filtered = reviews;
            if (tagFilter) {
              filtered = reviews.filter(function(r) {
                return (r.tags || []).some(function(t) { return (t || '').toLowerCase() === tagFilter; });
              });
            }
            if (filtered.length === 0) {
              loadingEl.hidden = true;
              errorEl.hidden = false;
              errorEl.textContent = 'No testimonials yet.';
              return;
            }
            renderGrid(filtered);
            loadingEl.hidden = true;
            gridEl.hidden = false;
          })
          .catch(function(err) {
            console.error('[VideoAsk]', err);
            loadingEl.hidden = true;
            errorEl.hidden = false;
          });
      }

      function tryLoad() {
        if (loaded) return;
        var tabContent = container.closest('.ugc-tab-content');
        if (tabContent && tabContent.offsetParent !== null) {
          load();
        }
      }

      tryLoad();

      var tabContent = container.closest('.ugc-tab-content');
      if (tabContent) {
        var observer = new MutationObserver(tryLoad);
        observer.observe(tabContent, {
          attributes: true,
          attributeFilter: ['style', 'hidden']
        });
      }
    }

    containers.forEach(initContainer);
  })();
</script>

{% schema %}
{
  "name": "UGC Tabs",
  "tag": "section",
  "class": "ugc-tabs-wrapper",
  "settings": [
    {
      "type": "header",
