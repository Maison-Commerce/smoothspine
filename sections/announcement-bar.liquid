{%- unless request.page_type != 'index' and section.settings.show_on_homepage_only -%}

  <style>
    :root {
      --sticky-announcement-bar-enabled: {%- if section.settings.enable_sticky -%}1{% else %}0{% endif %};
    }

    {%- if section.settings.enable_sticky -%}
      #shopify-section-{{ section.id }} {
        position: sticky;
        top: 0;
        z-index: 20;
      }

      .shopify-section--header ~ #shopify-section-{{ section.id }} {
        top: calc(var(--sticky-header-enabled, 0) * var(--header-height, 0px));
      }
    {%- endif -%}

    #shopify-section-{{ section.id }} .announcement-banner-image {
      width: 100%;
      display: block;
      overflow: hidden;
      line-height: 0;
    }

    #shopify-section-{{ section.id }} .announcement-banner-image a {
      display: block;
      width: 100%;
    }

    #shopify-section-{{ section.id }} .announcement-banner-image picture {
      display: block;
      width: 100%;
    }

    #shopify-section-{{ section.id }} .announcement-banner-image img {
      width: 100%;
      height: auto;
      display: block;
    }
  </style>

  <height-observer variable="announcement-bar">
    <div class="announcement-banner-image">
      {%- if section.settings.banner_link != blank -%}
        <a href="{{ section.settings.banner_link }}">
      {%- endif -%}

        <picture>
          <source
            media="(max-width: 749px)"
            srcset="https://cdn.shopify.com/s/files/1/0252/1261/6781/files/M_-_Smoothspine_-_Memorial_Day_Sale_Banner_v1_Mobile.png?v=1778701607"
          >

          <img
            src="https://cdn.shopify.com/s/files/1/0252/1261/6781/files/Smoothspine_-_Memorial_Day_Sale_Banner_min.png?v=1778701606"
            alt="{{ section.settings.banner_alt | escape }}"
            loading="eager"
            fetchpriority="high"
          >
        </picture>

      {%- if section.settings.banner_link != blank -%}
        </a>
      {%- endif -%}
    </div>
  </height-observer>

  <script>
    document.documentElement.style.setProperty(
      '--announcement-bar-height',
      Math.round(document.getElementById('shopify-section-{{ section.id }}').clientHeight) + 'px'
    );

    window.addEventListener('load', function () {
      document.documentElement.style.setProperty(
        '--announcement-bar-height',
        Math.round(document.getElementById('shopify-section-{{ section.id }}').clientHeight) + 'px'
      );
    });

    window.addEventListener('resize', function () {
      document.documentElement.style.setProperty(
        '--announcement-bar-height',
        Math.round(document.getElementById('shopify-section-{{ section.id }}').clientHeight) + 'px'
      );
    });
  </script>

{%- endunless -%}


{% schema %}
{
  "name": "Announcement bar",
  "class": "shopify-section--announcement-bar",
  "tag": "aside",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_sticky",
      "label": "Enable sticky bar",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_on_homepage_only",
      "label": "Show on homepage only",
      "default": false
    },
    {
      "type": "url",
      "id": "banner_link",
      "label": "Banner link"
    },
    {
      "type": "text",
      "id": "banner_alt",
      "label": "Banner alt text",
      "default": "Memorial Day Sale"
    }
  ]
}
{% endschema %}