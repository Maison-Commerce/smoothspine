        {% if section.settings.show_checkout_button %}
          <form action="{{ routes.cart_url }}" method="POST">
            <button type="submit" name="checkout" class="maison-cart-checkout-btn">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none"><path fill-rule="evenodd" clip-rule="evenodd" d="M6.17872 1.58301C7.19231 0.569427 8.56702 0 10.0005 0C11.4339 0 12.8086 0.569427 13.8222 1.58301C14.8357 2.5966 15.4052 3.97133 15.4052 5.40476V6.63774C17.0026 7.31177 18.1904 8.80733 18.4056 10.6032C18.5022 11.4089 18.5724 12.2426 18.5724 13.0952C18.5724 13.9478 18.5022 14.7814 18.4056 15.5871C18.1186 17.9829 16.1006 19.8441 13.6886 19.9337C12.5112 19.9773 11.3049 20 9.99958 20C8.6943 20 7.48794 19.9773 6.31054 19.9337C3.89857 19.8441 1.88052 17.9829 1.59357 15.5871C1.49705 14.7814 1.42676 13.9478 1.42676 13.0952C1.42676 12.2426 1.49705 11.4089 1.59357 10.6032C1.80875 8.80667 2.99744 7.31067 4.59571 6.63701V5.40476C4.59571 3.97133 5.16514 2.5966 6.17872 1.58301ZM13.2624 5.40476V6.2419C12.2196 6.20794 11.1479 6.19044 9.99958 6.19044C8.85195 6.19044 7.7808 6.20791 6.73857 6.24184V5.40476C6.73857 4.53964 7.08222 3.70997 7.69395 3.09824C8.30567 2.48651 9.13535 2.14286 10.0005 2.14286C10.8656 2.14286 11.6952 2.48651 12.307 3.09824C12.9187 3.70997 13.2624 4.53964 13.2624 5.40476ZM11.071 12.2287C11.071 11.6369 10.5913 11.1572 9.99958 11.1572C9.40785 11.1572 8.92815 11.6369 8.92815 12.2287V13.7143C8.92815 14.306 9.40785 14.7857 9.99958 14.7857C10.5913 14.7857 11.071 14.306 11.071 13.7143V12.2287Z" fill="#FFFCFB"/></svg>
              <span>{{ section.settings.checkout_button_label }}</span>
            </button>
          </form>
        {% endif %}

        {%- comment -%} Payment Icons {%- endcomment -%}
        {% if section.settings.show_payment_icons %}
          <div class="maison-cart-payments">
            {%- for i in (1..10) -%}
              {%- capture payment_setting -%}payment_icon_{{ i }}{%- endcapture -%}
              {%- if section.settings[payment_setting] != blank -%}
                <div class="maison-cart-payment-icon">
                  {{ section.settings[payment_setting] | image_url: width: 46 | image_tag: loading: 'lazy', widths: '23, 46', sizes: '23px' }}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {% endif %}

        {%- comment -%} Trust Badges {%- endcomment -%}
        {% if section.settings.show_trust_badges %}
          <div class="maison-cart-trust">
            {% if section.settings.trust_badge_1 != blank %}
              <div class="maison-cart-trust__item">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none"><g clip-path="url(#mc-shield)"><path fill-rule="evenodd" clip-rule="evenodd" d="M2.63463 0.176497C2.74243 0.063764 2.89163 0 3.04762 0H12.9523C13.1083 0 13.2576 0.063764 13.3654 0.176497C13.6894 0.515322 14.3575 1.21448 14.9382 2.42882C15.5183 3.6421 16 5.34517 16 7.6923C16 10.4923 14.6697 12.4184 13.0341 13.7085C11.416 14.9845 9.49067 15.649 8.21923 15.9814C8.12447 16.0062 8.02493 16.0062 7.93017 15.9814C6.66139 15.6497 4.70039 14.9862 3.04591 13.7126C1.37442 12.4257 0 10.4993 0 7.6923C0 5.34517 0.481736 3.6421 1.06185 2.42882C1.64248 1.21448 2.31062 0.515322 2.63463 0.176497ZM11.6126 5.16624C11.9632 4.84818 11.9896 4.30611 11.6715 3.9555C11.3535 3.60487 10.8114 3.57848 10.4608 3.89654C9.44797 4.81529 8.68333 5.64447 8.03722 6.65293C7.58974 7.35137 7.21039 8.11826 6.84237 9.03351L5.57879 7.73046C5.24925 7.39061 4.70659 7.38226 4.36675 7.71181C4.0269 8.04135 4.01856 8.584 4.3481 8.92384L6.55655 11.2013C6.76358 11.4148 7.06648 11.5057 7.35686 11.4416C7.64725 11.3774 7.88361 11.1673 7.98138 10.8864C8.49064 9.42353 8.94082 8.42033 9.48067 7.57771C10.0171 6.74039 10.6653 6.02557 11.6126 5.16624Z" fill="#102A43"/></g><defs><clipPath id="mc-shield"><rect width="16" height="16" fill="white"/></clipPath></defs></svg>
                <span>{{ section.settings.trust_badge_1 }}</span>
              </div>
            {% endif %}
            {% if section.settings.trust_badge_1 != blank and section.settings.trust_badge_2 != blank %}
              <span class="maison-cart-trust__separator"></span>
            {% endif %}
            {% if section.settings.trust_badge_2 != blank %}
              <div class="maison-cart-trust__item">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none"><g clip-path="url(#mc-check)"><path fill-rule="evenodd" clip-rule="evenodd" d="M2.63463 0.176497C2.74243 0.063764 2.89163 0 3.04762 0H12.9523C13.1083 0 13.2576 0.063764 13.3654 0.176497C13.6894 0.515322 14.3575 1.21448 14.9382 2.42882C15.5183 3.6421 16 5.34517 16 7.6923C16 10.4923 14.6697 12.4184 13.0341 13.7085C11.416 14.9845 9.49067 15.649 8.21923 15.9814C8.12447 16.0062 8.02493 16.0062 7.93017 15.9814C6.66139 15.6497 4.70039 14.9862 3.04591 13.7126C1.37442 12.4257 0 10.4993 0 7.6923C0 5.34517 0.481736 3.6421 1.06185 2.42882C1.64248 1.21448 2.31062 0.515322 2.63463 0.176497ZM11.6126 5.16624C11.9632 4.84818 11.9896 4.30611 11.6715 3.9555C11.3535 3.60487 10.8114 3.57848 10.4608 3.89654C9.44797 4.81529 8.68333 5.64447 8.03722 6.65293C7.58974 7.35137 7.21039 8.11826 6.84237 9.03351L5.57879 7.73046C5.24925 7.39061 4.70659 7.38226 4.36675 7.71181C4.0269 8.04135 4.01856 8.584 4.3481 8.92384L6.55655 11.2013C6.76358 11.4148 7.06648 11.5057 7.35686 11.4416C7.64725 11.3774 7.88361 11.1673 7.98138 10.8864C8.49064 9.42353 8.94082 8.42033 9.48067 7.57771C10.0171 6.74039 10.6653 6.02557 11.6126 5.16624Z" fill="#102A43"/></g><defs><clipPath id="mc-check"><rect width="16" height="16" fill="white"/></clipPath></defs></svg>
                <span>{{ section.settings.trust_badge_2 }}</span>
              </div>
            {% endif %}
          </div>
        {% endif %}
      </div>
    </div>
  {%- endif -%}
</cart-drawer>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>

<script>
  function initMaisonCartRecs() {
    var section = document.getElementById('cart-drawer');
    if (!section) return;

    var swiperEl = section.querySelector('[data-maison-cart-recs]');
    if (!swiperEl) return;

    /* Destroy any existing swiper on this element */
    if (swiperEl.swiper) {
      try { swiperEl.swiper.destroy(true, true); } catch(e) {}
    }

    var prevBtn = section.querySelector('.maison-cart-recs__prev');
    var nextBtn = section.querySelector('.maison-cart-recs__next');
    var dotsEl = section.querySelector('[data-maison-cart-dots]');

    new Swiper(swiperEl, {
      slidesPerView: 'auto',
      spaceBetween: 0,
      navigation: prevBtn && nextBtn ? {
        prevEl: prevBtn,
        nextEl: nextBtn
      } : false,
      pagination: dotsEl ? {
        el: dotsEl,
        clickable: true
      } : false
    });

    /* "+ ADD" button handler */
    section.querySelectorAll('.maison-cart-rec-card__add').forEach(function(btn) {
      btn.addEventListener('click', function() {
        if (btn.classList.contains('is-loading')) return;
        btn.classList.add('is-loading');
        var variantId = btn.getAttribute('data-variant-id');

        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: [{ id: parseInt(variantId), quantity: 1 }] })
        })
        .then(function(res) { return res.json(); })
        .then(function() {
          btn.classList.remove('is-loading');
          document.documentElement.dispatchEvent(new CustomEvent('cart:refresh'));
        })
        .catch(function() {
          btn.classList.remove('is-loading');
        });
      });
    });
  }

  /* Init on DOMContentLoaded or when Swiper is ready */
  if (typeof Swiper !== 'undefined') {
    initMaisonCartRecs();
  } else {
    document.addEventListener('DOMContentLoaded', initMaisonCartRecs);
  }

  /* Insurance toggle */
  function _insuranceChangeHandler(e) {
    var el = e.target.closest('[data-maison-insurance]');
    if (!el) return;
    var variantId = el.getAttribute('data-variant-id');
    var lineKey = el.getAttribute('data-line-key');
    var isChecked = e.target.checked;

    if (isChecked) {
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: [{ id: parseInt(variantId), quantity: 1 }] })
      })
      .then(function(res) { return res.json(); })
      .then(function() {
        document.documentElement.dispatchEvent(new CustomEvent('cart:refresh'));
      });
    } else {
      if (lineKey) {
        fetch('/cart/change.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: lineKey, quantity: 0 })
        })
        .then(function(res) { return res.json(); })
        .then(function() {
          document.documentElement.dispatchEvent(new CustomEvent('cart:refresh'));
        });
      }
    }
  }

  function initMaisonInsurance() {
    var el = document.querySelector('[data-maison-insurance]');
    if (!el) return;
    var checkbox = el.querySelector('[data-maison-insurance-checkbox]');
    if (!checkbox) return;

    /* Remove old listener before adding new one */
    checkbox.removeEventListener('change', _insuranceChangeHandler);
    checkbox.addEventListener('change', _insuranceChangeHandler);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMaisonInsurance);
  } else {
    initMaisonInsurance();
  }

  /* Re-init after cart updates — simple debounced approach */
  var _reinitTimer = null;

  function reinitMaisonCart() {
    clearTimeout(_reinitTimer);
    _reinitTimer = setTimeout(function() {
      if (typeof Swiper === 'undefined') return;
      initMaisonCartRecs();
      initMaisonInsurance();
    }, 500);
  }

  /* Watch for drawer open attribute */
  var _cartDrawer = document.getElementById('cart-drawer');
  if (_cartDrawer) {
    new MutationObserver(function() {
      if (_cartDrawer.hasAttribute('open')) {
        reinitMaisonCart();
      }
    }).observe(_cartDrawer, { attributes: true, attributeFilter: ['open'] });
  }

  /* Listen to theme cart events */
  document.documentElement.addEventListener('cart:change', function() {
    setTimeout(reinitMaisonCart, 800);
  });
  document.documentElement.addEventListener('cart:refresh', function() {
    setTimeout(reinitMaisonCart, 800);
  });
</script>

{% style %}
  /* ===== MAISON CART DRAWER ===== */

  /* Reset drawer padding */
  #shopify-section-{{ section.id }} .cart-drawer::part(body) {
    padding: 0 !important;
  }

  #shopify-section-{{ section.id }} .drawer::part(content){
    background: #F8F4EE;
  }

  #shopify-section-{{ section.id }} .cart-drawer {
    --rounded-sm: 16px 0 0 16px;
  }

  @media (max-width: 999px) {
    #shopify-section-{{ section.id }} .cart-drawer {
      --rounded-sm: 0px;
    }
  }

  #shopify-section-{{ section.id }} .cart-drawer::part(footer) {
    padding: 0 !important;
  }

  /* Header */
  #shopify-section-{{ section.id }} .maison-cart-header {
    background: #fff;
    padding: 0;
    border-bottom: none;
  }

  #shopify-section-{{ section.id }} .maison-cart-header__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 20px 12px;
  }

  #shopify-section-{{ section.id }} .maison-cart-header__left {
    display: flex;
    align-items: center;
    gap: 12px;
    flex: 1;
  }

  #shopify-section-{{ section.id }} .maison-cart-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 800;
    font-size: 24px;
    line-height: 1.4;
    color: #102A43;
    margin: 0;
    text-transform: capitalize;
  }

  #shopify-section-{{ section.id }} .maison-cart-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #102A43;
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .maison-cart-count {
    background: #065BDC !important;
    color: #FAFCFE !important;
    font-family: 'Plus Jakarta Sans', sans-serif !important;
    font-weight: 800 !important;
    font-size: 16px !important;
    letter-spacing: 1px;
    text-transform: uppercase;
    min-width: 32px;
    height: 24px;
    padding: 0 12px;
    border-radius: 4px !important;
    display: inline-flex !important;
    align-items: center;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .maison-cart-close {
    width: 32px;
    height: 32px;
    padding: 8px;
    border-radius: 999px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
  }

  #shopify-section-{{ section.id }} .maison-cart-close svg {
    width: 16px;
    height: 16px;
    opacity: 0.5;
  }

  /* Custom Line Item */
  #shopify-section-{{ section.id }} .mc-line-item {
    background: #fff;
    padding: 20px;
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  #shopify-section-{{ section.id }} .mc-line-item__img {
    width: 80px;
    height: 80px;
    border-radius: 8px;
    overflow: hidden;
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .mc-line-item__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #shopify-section-{{ section.id }} .mc-line-item__body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-self: stretch;
  }

  #shopify-section-{{ section.id }} .mc-line-item__top {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  #shopify-section-{{ section.id }} .mc-line-item__text {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  #shopify-section-{{ section.id }} .mc-line-item__title {
    font-family: 'Open Sans', sans-serif;
    font-weight: 700;
    font-size: 16px;
    line-height: 1.5;
    color: #102A43;
    text-decoration: none;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .mc-line-item__desc {
    font-family: 'Open Sans', sans-serif;
    font-weight: 400;
    font-size: 12px;
    line-height: 1.5;
    color: rgba(16,42,67,0.75);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .mc-line-item__delete {
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .mc-line-item__delete svg {
    width: 16px;
    height: 16px;
  }

  #shopify-section-{{ section.id }} .mc-line-item__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* Quantity picker */
  #shopify-section-{{ section.id }} .mc-line-item__qty {
    display: flex;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .mc-line-item__qty-btn {
    width: 32px;
    height: 32px;
    border: 1px solid rgba(44,41,38,0.08);
    border-radius: 4px;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: 0;
  }

  #shopify-section-{{ section.id }} .mc-line-item__qty-btn svg {
    width: 12px;
    height: 12px;
  }

  #shopify-section-{{ section.id }} .mc-line-item__qty-input {
    width: 40px;
    height: 32px;
    text-align: center;
    border: none !important;
    background: transparent;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 800;
    font-size: 12px;
    letter-spacing: 1px;
    color: #102A43;
    -moz-appearance: textfield;
  }

  #shopify-section-{{ section.id }} .mc-line-item__qty-input::-webkit-outer-spin-button,
  #shopify-section-{{ section.id }} .mc-line-item__qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  /* Prices */
  #shopify-section-{{ section.id }} .mc-line-item__prices {
    display: flex;
    align-items: center;
    gap: 8px;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .mc-line-item__compare {
    font-family: 'Open Sans', sans-serif;
    font-weight: 600;
    font-size: 14px;
    line-height: 1.5;
    color: #102A43;
    opacity: 0.5;
    text-decoration: line-through;
  }

  #shopify-section-{{ section.id }} .mc-line-item__price {
    font-family: 'Open Sans', sans-serif;
    font-weight: 700;
    font-size: 16px;
    line-height: 1.5;
    color: #102A43;
  }

  @media (max-width: 999px) {
    #shopify-section-{{ section.id }} .mc-line-item {
      padding: 12px 20px;
      gap: 12px;
    }

    #shopify-section-{{ section.id }} .mc-line-item__img {
      width: 64px;
      height: 64px;
    }

    #shopify-section-{{ section.id }} .mc-line-item__body {
      gap: 8px;
    }

    #shopify-section-{{ section.id }} .mc-line-item__title {
      font-size: 12px;
    }

    #shopify-section-{{ section.id }} .mc-line-item__desc {
      font-size: 10px;
    }

    #shopify-section-{{ section.id }} .mc-line-item__qty-btn {
      width: 28px;
      height: 28px;
    }

    #shopify-section-{{ section.id }} .mc-line-item__qty-input {
      height: 28px;
    }

    #shopify-section-{{ section.id }} .mc-line-item__compare {
      font-size: 10px;
    }

    #shopify-section-{{ section.id }} .mc-line-item__price {
      font-size: 12px;
    }
  }

  /* Shipping Bar */
  #shopify-section-{{ section.id }} .maison-cart-shipping-bar {
    background: #E5EEFB;
    padding: 12px 48px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  #shopify-section-{{ section.id }} .maison-cart-shipping-bar__text {
    font-family: 'Open Sans', sans-serif;
    font-weight: 600;
    font-size: 14px;
    line-height: 1.5;
    color: #102A43;
    text-align: center;
    white-space: nowrap;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .maison-cart-shipping-bar__track {
    width: 100%;
    height: 10px;
    border: 1px solid rgba(44,41,38,0.12);
    border-radius: 999px;
    padding: 2px;
    position: relative;
    overflow: hidden;
    background: transparent;
  }

  #shopify-section-{{ section.id }} .maison-cart-shipping-bar__track::before {
    content: '';
    position: absolute;
    inset: 2px;
    background: #EAECF0;
    border-radius: 999px;
  }

  #shopify-section-{{ section.id }} .maison-cart-shipping-bar__fill {
    height: 6px;
    background: #065BDC;
    border-radius: 999px;
    position: relative;
    z-index: 1;
    transition: width 0.4s ease;
    position: relative;
    top: -1px;
  }

  /* Line items area */
  #shopify-section-{{ section.id }} .maison-cart-items {
    background: #F8F4EE;
  }

  #shopify-section-{{ section.id }} .cart-drawer__line-items > * + * {
    border-top: none;
  }

  #shopify-section-{{ section.id }} .maison-recs-wrapper-grid{
    display: grid;
  }

  /* Recommendations */
  #shopify-section-{{ section.id }} .maison-cart-recs {
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: center;
    overflow: hidden;
    max-width: 100%;
  }

  #shopify-section-{{ section.id }} .maison-cart-recs__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .maison-cart-recs__title {
    font-family: 'Open Sans', sans-serif;
    font-weight: 700;
    font-size: 16px;
    line-height: 1.5;
    color: #102A43;
  }

  #shopify-section-{{ section.id }} .maison-cart-recs__nav {
    display: flex;
    gap: 8px;
  }

  #shopify-section-{{ section.id }} .maison-cart-recs__arrow {
    width: 32px;
    height: 32px;
    background: #102A43;
    border: none;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: 8px;
    transition: opacity 0.2s;
