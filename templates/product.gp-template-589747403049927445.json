    "gp_section_589747403201315605": {
      "type": "gp-section-589747403201315605",
      "settings": {
        "section_preload": "false",
        "checksum": "166b16deb9476ee8c5cef2430daa7315abdb1c41e586e331f81d3614b6b144c7_1_1_1_0__1",
        "ggrydDXALPH_text": "Trusted by People Who Were Tired of Living in Pain",
        "gg_nv0E1WSj_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0252/1261/6781/files/gempages_464015397612422087-939e3ba0-77bd-4473-8ac6-d6b5ac2146ea.png",
        "gg029TQ7PQT_text": "<p>“I was waking up in pain every morning - now I sleep through the night.”</p>",
        "ggnkoHZd9S5_text": "<p>“I’ve tried everything for my sciatica. These patches are the first thing that gave me real relief without side effects. I use one before bed and actually wake up rested.”</p>",
        "ggmciU_MO8m_text": "<p>- Maria L., 54</p>",
        "ggx_FgcD6ei_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0252/1261/6781/files/gempages_464015397612422087-df2bff79-1c60-4aa9-8bcd-90957e26554d.png",
        "ggBi7vQvbIj_text": "<p>“The heat kicks in fast and hits right where I need it.”</p>",
        "ggJ8hCrLXJq_text": "<p>“I used to rely on painkillers just to get through the workday. With these, I can move without wincing. Total game changer.”</p>",
        "ggReBUA1njy_text": "<p>- Jared W., 42</p>",
        "ggcIBXq5yW6_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0252/1261/6781/files/gempages_464015397612422087-53823a8b-15e3-477c-a803-c8cd5fea7931.png",
        "gg4lOxj8MET_text": "<p>“Felt the difference within 10 minutes.”</p>",
        "ggZSVoxxXVa_text": "<p>“I have chronic lower back pain and stiff hips from an old injury. One patch and I was walking more freely by the end of the day. I honestly didn’t expect much - now I’m reordering.”</p>",
        "ggQgcHb_VvV_text": "<p>- Dee A., 61</p>"
      }
