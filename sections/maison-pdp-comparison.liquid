      "default": "#102A43"
    },
    {
      "type": "color",
      "id": "color_brand_blue",
      "label": "Highlight text color",
      "default": "#065BDC"
    },
    {
      "type": "color",
      "id": "color_text_secondary",
      "label": "Secondary text color",
      "default": "#102A43"
    },
