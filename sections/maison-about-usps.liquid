{% comment %}
  Section: About Page USPs
  Description: Centered header with title and subtitle, followed by a row of
    unique selling propositions (USPs) separated by vertical dividers. Each USP
    features an icon, title, and description. Stacks vertically on mobile with
    horizontal dividers. Ideal for about pages or landing pages to communicate
    brand values.

  Dependencies:
  - Font: 'Plus Jakarta Sans' (headings), 'Open Sans' (body) — must be loaded by the theme

  Blocks:
  - usp_item: Individual USP with icon image, title, and description (limit: 6)

  Notes:
  - Dividers between USP items are auto-generated and toggle via show_dividers setting
  - Icon images use a dashed border style matching the original design
  - All colors, typography, spacing, and border radius values are merchant-configurable
  - Original source class prefix: maisoncode_about-page-usps
{% endcomment %}

{% style %}
  #shopify-section-{{ section.id }} .maisoncode_about-page-usps {
    --s-color-bg: {{ section.settings.color_background }};
    --s-color-text-primary: {{ section.settings.color_heading }};
    --s-color-text-secondary: {{ section.settings.color_body_text }};
    --s-color-brand-accent: {{ section.settings.color_icon_border }};
    --s-color-icon-bg: {{ section.settings.color_icon_bg }};
    --s-color-divider: {{ section.settings.color_divider }};
    --s-font-size-title: {{ section.settings.title_font_size }}px;
    --s-font-size-subtitle: {{ section.settings.subtitle_font_size }}px;
    --s-font-size-usp-title: {{ section.settings.usp_title_font_size }}px;
    --s-font-size-usp-desc: {{ section.settings.usp_desc_font_size }}px;
    --s-radius-icon: {{ section.settings.icon_border_radius }}px;
    --s-padding-top: {{ section.settings.padding_top }}px;
    --s-padding-bottom: {{ section.settings.padding_bottom }}px;
    --s-padding-horizontal: {{ section.settings.padding_horizontal }}px;
    --s-gap-header: {{ section.settings.header_gap }}px;
    --s-gap-sections: {{ section.settings.sections_gap }}px;
    --s-gap-usps: {{ section.settings.usps_gap }}px;
    --s-gap-usp-icon-text: {{ section.settings.icon_text_gap }}px;
    --s-gap-usp-text: {{ section.settings.text_gap }}px;
    --s-max-width: {{ section.settings.max_width }}px;
    --s-icon-size: {{ section.settings.icon_box_size }}px;
    --s-icon-img-size: {{ section.settings.icon_image_size }}px;
    --s-divider-height: {{ section.settings.divider_height }}px;

    font-family: 'Open Sans', sans-serif;
    background-color: var(--s-color-bg);
    width: 100%;
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} .maisoncode_about-page-usps *,
  #shopify-section-{{ section.id }} .maisoncode_about-page-usps *::before,
  #shopify-section-{{ section.id }} .maisoncode_about-page-usps *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  #shopify-section-{{ section.id }} .usps-inner {
    max-width: var(--s-max-width);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--s-gap-sections);
    padding: var(--s-padding-top) var(--s-padding-horizontal) var(--s-padding-bottom);
  }

  #shopify-section-{{ section.id }} .usps-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--s-gap-header);
    text-align: center;
    max-width: {{ section.settings.header_max_width }}px;
  }

  #shopify-section-{{ section.id }} .usps-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 800;
    font-size: var(--s-font-size-title);
    line-height: 1.5;
    color: var(--s-color-text-primary);
    text-transform: capitalize;
  }

  #shopify-section-{{ section.id }} .usps-subtitle {
    font-family: 'Open Sans', sans-serif;
    font-weight: 400;
    font-size: var(--s-font-size-subtitle);
    line-height: 1.5;
    color: var(--s-color-text-secondary);
  }

  #shopify-section-{{ section.id }} .usps-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--s-gap-usps);
    width: 100%;
  }

  #shopify-section-{{ section.id }} .usp-item {
    display: flex;
    align-items: center;
    gap: var(--s-gap-usp-icon-text);
    flex: 1 1 0;
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .usp-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--s-icon-size);
    height: var(--s-icon-size);
    padding: 12px;
    background-color: var(--s-color-icon-bg);
    border: 1px dashed var(--s-color-brand-accent);
    border-radius: var(--s-radius-icon);
  }

  #shopify-section-{{ section.id }} .usp-icon img {
    width: var(--s-icon-img-size);
    height: var(--s-icon-img-size);
    display: block;
    object-fit: contain;
  }

  #shopify-section-{{ section.id }} .usp-icon .placeholder-svg {
    width: var(--s-icon-img-size);
    height: var(--s-icon-img-size);
  }

  #shopify-section-{{ section.id }} .usp-text {
    display: flex;
    flex-direction: column;
    gap: var(--s-gap-usp-text);
    flex: 1 1 0;
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .usp-text-title {
    font-family: 'Open Sans', sans-serif;
    font-weight: 700;
    font-size: var(--s-font-size-usp-title);
    line-height: 1.5;
    color: var(--s-color-text-primary);
  }

  #shopify-section-{{ section.id }} .usp-text-desc {
    font-family: 'Open Sans', sans-serif;
    font-weight: 400;
    font-size: var(--s-font-size-usp-desc);
    line-height: 1.5;
    color: {{ section.settings.color_body_text | hex_to_rgba: 0.75 }};
  }

  #shopify-section-{{ section.id }} .usp-divider {
    flex-shrink: 0;
    width: {% if section.settings.divider_style == 'dashed' %}0{% else %}1{% endif %}px;
    height: var(--s-divider-height);
    {% if section.settings.divider_style == 'dashed' %}
      border-left: dashed 0.5px var(--s-color-divider);
    {% else %}
      background-color: var(--s-color-divider);
    {% endif %}
  }

  /* Mobile < 768px */
  @media (max-width: 949px) {
    #shopify-section-{{ section.id }} .maisoncode_about-page-usps {
      --s-padding-top: {{ section.settings.padding_top_mobile }}px;
      --s-padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      --s-font-size-title: {{ section.settings.title_font_size_mobile }}px;
      --s-font-size-subtitle: {{ section.settings.subtitle_font_size_mobile }}px;
    }

    #shopify-section-{{ section.id }} .usps-inner {
      gap: 32px;
    }

    #shopify-section-{{ section.id }} .usps-header {
      max-width: 100%;
      gap: 12px;
    }

    #shopify-section-{{ section.id }} .usps-row {
      flex-direction: column;
      gap: 12px;
      align-items: stretch;
    }

    #shopify-section-{{ section.id }} .usp-item {
      gap: 18px;
      padding: 12px;
    }

    #shopify-section-{{ section.id }} .usp-text-title {
      font-size: 16px;
    }

    #shopify-section-{{ section.id }} .usp-divider {
      width: 100%;
      height: {% if section.settings.divider_style == 'dashed' %}0{% else %}1{% endif %}px;
      {% if section.settings.divider_style == 'dashed' %}
        border-left: none;
        border-top: dashed 0.5px var(--s-color-divider);
      {% else %}
        background-color: var(--s-color-divider);
      {% endif %}
    }
  }
{% endstyle %}

<section class="maisoncode_about-page-usps">
  <div class="usps-inner">

    {%- comment -%} Header {%- endcomment -%}
    {% if section.settings.heading != blank or section.settings.subtitle != blank %}
      <header class="usps-header">
        {% if section.settings.heading != blank %}
          <h2 class="usps-title">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.subtitle != blank %}
          <p class="usps-subtitle">{{ section.settings.subtitle }}</p>
        {% endif %}
      </header>
    {% endif %}

    {%- comment -%} USP Items (Blocks) {%- endcomment -%}
    {% if section.blocks.size > 0 %}
      <div class="usps-row">
        {% for block in section.blocks %}
          {% if block.type == 'usp_item' %}
            {% unless forloop.first %}
              {% if section.settings.show_dividers %}
                <div class="usp-divider" role="separator"></div>
              {% endif %}
            {% endunless %}

            <article class="usp-item" {{ block.shopify_attributes }}>
              <div class="usp-icon">
                {% if block.settings.icon != blank %}
                  {{ block.settings.icon | image_url: width: 64 | image_tag:
                    loading: 'lazy',
                    widths: '32, 64',
                    sizes: '32px'
                  }}
                {% else %}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {% endif %}
              </div>
              <div class="usp-text">
                {% if block.settings.title != blank %}
                  <h3 class="usp-text-title">{{ block.settings.title }}</h3>
                {% endif %}
                {% if block.settings.description != blank %}
                  <p class="usp-text-desc">{{ block.settings.description }}</p>
                {% endif %}
              </div>
            </article>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "About Page USPs",
  "tag": "section",
  "class": "about-page-usps-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What We Stand For"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Our mission is to provide those with chronic back pain options beyond surgery and costly treatments."
    },
    {
      "type": "header",
      "content": "Dividers"
    },
    {
      "type": "checkbox",
      "id": "show_dividers",
      "label": "Show dividers between items",
      "default": true
    },
    {
      "type": "select",
      "id": "divider_style",
      "label": "Divider style",
      "options": [
        { "value": "solid", "label": "Solid" },
        { "value": "dashed", "label": "Dashed" }
      ],
      "default": "solid"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "color_background",
      "label": "Background",
      "default": "#E5EEFB"
    },
    {
      "type": "color",
      "id": "color_heading",
      "label": "Heading text",
      "default": "#102A43"
    },
    {
      "type": "color",
      "id": "color_body_text",
      "label": "Body / subtitle text",
      "default": "#102A43"
    },
    {
      "type": "color",
      "id": "color_icon_border",
      "label": "Icon border color",
      "default": "#065BDC"
    },
    {
      "type": "color",
      "id": "color_icon_bg",
      "label": "Icon background color",
      "default": "#FAFCFE"
    },
    {
      "type": "color",
      "id": "color_divider",
      "label": "Divider color",
      "default": "#102A43"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "label": "Heading font size (desktop)",
      "min": 20,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "title_font_size_mobile",
      "label": "Heading font size (mobile)",
      "min": 16,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "subtitle_font_size",
      "label": "Subtitle font size (desktop)",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "subtitle_font_size_mobile",
      "label": "Subtitle font size (mobile)",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "usp_title_font_size",
      "label": "USP title font size",
      "min": 12,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "usp_desc_font_size",
      "label": "USP description font size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "header",
      "content": "Spacing & Layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding (desktop)",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding (desktop)",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top padding (mobile)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom padding (mobile)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "min": 16,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "sections_gap",
      "label": "Gap between header and USPs",
      "min": 16,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "header_gap",
      "label": "Gap between heading and subtitle",
      "min": 4,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "usps_gap",
      "label": "Gap between USP items",
      "min": 8,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "icon_text_gap",
      "label": "Gap between icon and text",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "text_gap",
      "label": "Gap between title and description",
      "min": 2,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "icon_border_radius",
      "label": "Icon border radius",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "icon_box_size",
      "label": "Icon box size",
      "min": 32,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "icon_image_size",
      "label": "Icon image size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "divider_height",
      "label": "Divider height",
      "min": 20,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max content width",
      "min": 800,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 1400
    },
    {
      "type": "range",
      "id": "header_max_width",
      "label": "Header max width",
      "min": 300,
      "max": 1000,
      "step": 20,
      "unit": "px",
      "default": 600
    }
  ],
  "blocks": [
    {
      "type": "usp_item",
      "name": "USP Item",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "USP Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "A short description for this unique selling point."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Page USPs",
      "blocks": [
        {
          "type": "usp_item",
          "settings": {
            "title": "Relief You Can Feel",
            "description": "We offer a daily routine with traction, heat, and massage to decompress your spine."
          }
        },
        {
          "type": "usp_item",
          "settings": {
            "title": "On Your Time, At Home",
            "description": "No appointments or waiting. Just 15 minutes a day in your living room."
          }
        },
        {
          "type": "usp_item",
          "settings": {
            "title": "No Risk, Real Support",
            "description": "90 days to see if it works. If not, get your money back. A real person is here to help."
          }
        }
      ]
    }
  ]
}
{% endschema %}
