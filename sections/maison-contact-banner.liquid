{% comment %}
  Section: Contact Options
  Description: Contact section with three contact method cards (Chat, Email, Call)
    on desktop and a contact form on mobile. Each card displays an icon, title,
    description, contact info, and business hours. Mobile view shows a form with
    name, email, message fields and a submit button.

  Dependencies:
  - Font: 'Plus Jakarta Sans' (headings), 'Open Sans' (body) — must be loaded by theme

  Blocks:
  - contact_card: Individual contact method with icon, title, description, contact info, and hours (limit: 6)

  Notes:
  - Desktop shows contact cards in a 3-column grid; mobile shows a contact form instead
  - Mobile form is a static HTML form (not connected to any backend by default)
  - Card icons use image_picker; merchants must upload their own icons
  - Clock icon for hours uses image_picker at section level
  - All colors, typography, spacing, and border radius values are merchant-configurable
  - Original source class prefix: maisoncode_contact-options
{% endcomment %}

{% style %}
  #shopify-section-{{ section.id }} .maisoncode_contact-options {
    --s-color-primary: {{ section.settings.color_primary }};
    --s-color-secondary: {{ section.settings.color_secondary }};
    --s-color-brand-blue: {{ section.settings.color_brand_blue }};
    --s-color-brand-blue-light: {{ section.settings.color_brand_blue_light }};
    --s-color-white: {{ section.settings.color_white }};
    --s-color-card-bg: {{ section.settings.color_card_bg }};
    --s-color-bg-from: {{ section.settings.color_bg_from }};
    --s-color-bg-to: {{ section.settings.color_bg_to }};
    --s-color-orange: {{ section.settings.color_orange }};
    --s-color-orange-dark: {{ section.settings.color_orange_dark }};
    --s-color-input-bg: {{ section.settings.color_input_bg }};
    --s-color-input-border: {{ section.settings.color_input_border }};
    --s-color-btn-text: {{ section.settings.color_btn_text }};
    --s-font-heading: 'Plus Jakarta Sans', sans-serif;
    --s-font-body: 'Open Sans', sans-serif;
    --s-radius-sm: {{ section.settings.radius_sm }}px;
    --s-radius-md: {{ section.settings.radius_md }}px;
    --s-font-size-heading: {{ section.settings.heading_font_size }}px;
    --s-font-size-subheading: {{ section.settings.subheading_font_size }}px;
    --s-font-size-card-title: {{ section.settings.card_title_font_size }}px;
    --s-font-size-card-desc: {{ section.settings.card_desc_font_size }}px;
    --s-font-size-contact: {{ section.settings.contact_font_size }}px;
    --s-font-size-hours: {{ section.settings.hours_font_size }}px;
    --s-padding-top: {{ section.settings.padding_top }}px;
    --s-padding-bottom: {{ section.settings.padding_bottom }}px;
    --s-padding-horizontal: {{ section.settings.padding_horizontal }}px;
    --s-gap-section: {{ section.settings.section_gap }}px;
    --s-gap-cards: {{ section.settings.cards_gap }}px;
    --s-max-width: {{ section.settings.max_width }}px;

    width: 100%;
    background: linear-gradient(to bottom, var(--s-color-bg-from), var(--s-color-bg-to));
    font-family: var(--s-font-body);
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} .maisoncode_contact-options *,
  #shopify-section-{{ section.id }} .maisoncode_contact-options *::before,
  #shopify-section-{{ section.id }} .maisoncode_contact-options *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  #shopify-section-{{ section.id }} .co-inner {
    max-width: var(--s-max-width);
    margin: 0 auto;
    padding: var(--s-padding-top) var(--s-padding-horizontal) var(--s-padding-bottom);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--s-gap-section);
  }

  /* Section Title */
  #shopify-section-{{ section.id }} .co-title-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-align: center;
    max-width: 600px;
  }

  #shopify-section-{{ section.id }} .co-heading {
    font-family: var(--s-font-heading);
    font-weight: 800;
    font-size: var(--s-font-size-heading);
    line-height: 1.5;
    color: var(--s-color-primary);
    text-transform: capitalize;
  }

  #shopify-section-{{ section.id }} .co-subheading {
    font-family: var(--s-font-body);
    font-weight: 400;
    font-size: var(--s-font-size-subheading);
    line-height: 1.5;
    color: {{ section.settings.color_secondary | color_modify: 'alpha', 0.75 }};
    max-width: 544px;
  }

  /* Cards Grid */
  #shopify-section-{{ section.id }} .co-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--s-gap-cards);
    width: 100%;
    max-width: 1200px;
  }

  #shopify-section-{{ section.id }} .co-card {
    background: var(--s-color-card-bg);
    border-radius: var(--s-radius-md);
    padding: 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  #shopify-section-{{ section.id }} .co-card-icon {
    width: 70px;
    height: 70px;
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .co-card-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  #shopify-section-{{ section.id }} .co-card-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .co-card-content {
    display: flex;
    flex-direction: column;
    gap: 18px;
    width: 100%;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .co-card-text {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: center;
    text-align: center;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .co-card-title {
    font-family: var(--s-font-heading);
    font-weight: 800;
    font-size: var(--s-font-size-card-title);
    line-height: 1.4;
    color: var(--s-color-primary);
  }

  #shopify-section-{{ section.id }} .co-card-desc {
    font-family: var(--s-font-body);
    font-weight: 400;
    font-size: var(--s-font-size-card-desc);
    line-height: 1.5;
    color: {{ section.settings.color_secondary | color_modify: 'alpha', 0.75 }};
    max-width: 280px;
  }

  #shopify-section-{{ section.id }} .co-card-info {
    background: var(--s-color-brand-blue-light);
    border-radius: var(--s-radius-sm);
    padding: 8px 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .co-card-contact {
    font-family: var(--s-font-body);
    font-weight: 700;
    font-size: var(--s-font-size-contact);
    line-height: 1.5;
    color: var(--s-color-brand-blue);
    text-align: center;
    text-decoration: none;
  }

  #shopify-section-{{ section.id }} .co-card-contact--underline {
    text-decoration: underline;
  }

  #shopify-section-{{ section.id }} .co-card-hours {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  #shopify-section-{{ section.id }} .co-card-hours svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .co-card-hours span {
    font-family: var(--s-font-body);
    font-weight: 400;
    font-size: var(--s-font-size-hours);
    line-height: 1.5;
    color: {{ section.settings.color_secondary | color_modify: 'alpha', 0.75 }};
    text-align: center;
  }


  /* Mobile styles */
  @media (max-width: 999px) {
    #shopify-section-{{ section.id }} .maisoncode_contact-options {
      background: linear-gradient(to bottom, #F8F4EE, #FDFCFA);
      --s-padding-top: 24px;
      --s-padding-bottom: 24px;
      --s-font-size-heading: 24px;
    }

    #shopify-section-{{ section.id }} .co-inner {
      padding: var(--s-padding-top) 20px var(--s-padding-bottom);
      gap: 32px;
    }

    #shopify-section-{{ section.id }} .co-heading {
      line-height: 1.4;
    }

    #shopify-section-{{ section.id }} .co-subheading {
      font-size: 14px;
      max-width: 100%;
    }

    #shopify-section-{{ section.id }} .co-cards {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    #shopify-section-{{ section.id }} .co-card {
      flex-direction: column;
      padding: 18px;
      gap: 18px;
      background: rgba(255, 255, 255, 0.83);
    }

    #shopify-section-{{ section.id }} .co-card-header {
      flex-direction: row;
      align-items: flex-start;
      gap: 12px;
    }

    #shopify-section-{{ section.id }} .co-card-text {
      align-items: flex-start;
      text-align: left;
    }

    #shopify-section-{{ section.id }} .co-card-title {
      font-size: 18px;
    }

    #shopify-section-{{ section.id }} .co-card-desc {
      font-size: 14px;
      max-width: 100%;
    }

    #shopify-section-{{ section.id }} .co-mobile-heading {
      font-family: var(--s-font-heading);
      font-weight: 800;
      font-size: 24px;
      line-height: 1.4;
      color: var(--s-color-primary);
      text-align: center;
      text-transform: capitalize;
    }

    #shopify-section-{{ section.id }} .co-form {
      display: flex;
      flex-direction: column;
      gap: 40px;
      width: 100%;
    }

    #shopify-section-{{ section.id }} .co-form-fields {
      display: flex;
      flex-direction: column;
      gap: 16px;
      width: 100%;
    }

    #shopify-section-{{ section.id }} .co-input {
      width: 100%;
      height: 56px;
      background: var(--s-color-input-bg);
      border: 1px solid var(--s-color-input-border);
      border-radius: var(--s-radius-sm);
      padding: 20px;
      font-family: var(--s-font-body);
      font-weight: 400;
      font-size: 14px;
      line-height: 1.5;
      color: var(--s-color-primary);
      outline: none;
    }

    #shopify-section-{{ section.id }} .co-input::placeholder {
      color: var(--s-color-secondary);
    }

    #shopify-section-{{ section.id }} .co-textarea {
      width: 100%;
      height: 120px;
      background: var(--s-color-input-bg);
      border: 1px solid var(--s-color-input-border);
      border-radius: var(--s-radius-sm);
      padding: 20px;
      font-family: var(--s-font-body);
      font-weight: 400;
      font-size: 14px;
      line-height: 1.5;
      color: var(--s-color-primary);
      resize: vertical;
      outline: none;
    }

    #shopify-section-{{ section.id }} .co-textarea::placeholder {
      color: var(--s-color-secondary);
    }

    #shopify-section-{{ section.id }} .co-checkbox-row {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    #shopify-section-{{ section.id }} .co-checkbox {
      width: 20px;
      height: 20px;
      background: var(--s-color-input-bg);
      border: 1px solid var(--s-color-input-border);
      border-radius: 4px;
      appearance: none;
      -webkit-appearance: none;
      cursor: pointer;
      flex-shrink: 0;
    }

    #shopify-section-{{ section.id }} .co-checkbox:checked {
      background: var(--s-color-brand-blue);
      border-color: var(--s-color-brand-blue);
    }

    #shopify-section-{{ section.id }} .co-checkbox-label {
      font-family: var(--s-font-body);
      font-weight: 400;
      font-size: 14px;
      line-height: 1.5;
      color: var(--s-color-primary);
    }

    #shopify-section-{{ section.id }} .co-submit-btn {
      width: 100%;
      height: 44px;
      background: var(--s-color-orange);
      border: none;
      border-bottom: 4px solid var(--s-color-orange-dark);
      border-radius: var(--s-radius-sm);
      font-family: var(--s-font-heading);
      font-weight: 800;
      font-size: 14px;
      line-height: 1.5;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: var(--s-color-btn-text);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
    }
  }

  /* Tablet adjustment */
  @media (min-width: 1000px) and (max-width: 1200px) {
    #shopify-section-{{ section.id }} .co-inner {
      padding: 48px 40px;
    }

    #shopify-section-{{ section.id }} .co-cards {
      max-width: 100%;
    }

    #shopify-section-{{ section.id }} .co-heading {
      font-size: 28px;
    }
  }
{% endstyle %}

<section class="maisoncode_contact-options">
  <div class="co-inner">
    <header class="co-title-block">
      {% if section.settings.heading != blank %}
        <h2 class="co-heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="co-subheading">{{ section.settings.subheading }}</p>
      {% endif %}
    </header>

    {% if section.blocks.size > 0 %}
      <div class="co-cards">
        {% for block in section.blocks %}
          {% if block.type == 'contact_card' %}
            <div class="co-card" {{ block.shopify_attributes }}>
              <div class="co-card-header">
                {% if block.settings.icon != blank %}
                  <div class="co-card-icon">
                    {{ block.settings.icon | image_url: width: 140 | image_tag:
                      loading: 'lazy',
                      widths: '70, 140',
                      sizes: '70px'
                    }}
                  </div>
                {% endif %}
                <div class="co-card-text">
                  {% if block.settings.title != blank %}
                    <h3 class="co-card-title">{{ block.settings.title }}</h3>
                  {% endif %}
                  {% if block.settings.description != blank %}
                    <p class="co-card-desc">{{ block.settings.description }}</p>
                  {% endif %}
                </div>
              </div>
              <div class="co-card-info">
                {% if block.settings.contact_text != blank %}
                  {% if block.settings.contact_link != blank %}
                    <a href="{{ block.settings.contact_link }}" class="co-card-contact{% if block.settings.underline_contact %} co-card-contact--underline{% endif %}">
                      {{ block.settings.contact_text }}
                    </a>
                  {% else %}
                    <span class="co-card-contact">{{ block.settings.contact_text }}</span>
                  {% endif %}
                {% endif %}
                {% if block.settings.hours_text != blank %}
                  <div class="co-card-hours">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
                      <g clip-path="url(#clip0_4078_18349{{ block.id }})">
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M2.0995 2.0995C3.49981 0.699178 5.52055 0 8 0C10.4795 0 12.5002 0.699178 13.9005 2.0995C15.3008 3.49981 16 5.52055 16 8C16 10.4795 15.3008 12.5002 13.9005 13.9005C12.5002 15.3008 10.4795 16 8 16C5.52055 16 3.49981 15.3008 2.0995 13.9005C0.699178 12.5002 0 10.4795 0 8C0 5.52055 0.699178 3.49981 2.0995 2.0995ZM8.03711 3.60157C8.51049 3.60157 8.89425 3.98531 8.89425 4.45871V7.60485L10.7101 9.45282C11.0419 9.79048 11.0371 10.3332 10.6995 10.6649C10.3618 10.9967 9.81912 10.992 9.48733 10.6543L7.42573 8.55625C7.26822 8.39596 7.17997 8.18022 7.17997 7.9555V4.45871C7.17997 3.98531 7.56373 3.60157 8.03711 3.60157Z" fill="#102A43"/>
                      </g>
                      <defs>
                        <clipPath id="clip0_4078_18349{{ block.id }}">
                          <rect width="16" height="16" fill="white"/>
                        </clipPath>
                      </defs>
                    </svg>
                    <span>{{ block.settings.hours_text }}</span>
                  </div>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Contact Options",
  "tag": "section",
  "class": "contact-options-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "We're Here To Help"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Real people. Real answers. Whether you have a question before buying or need help with your order, we'll get back to you within 24 hours."
    },
    {
      "type": "header",
      "content": "Mobile form"
    },
    {
      "type": "checkbox",
      "id": "show_mobile_form",
      "label": "Show mobile contact form",
      "default": true
    },
    {
      "type": "text",
      "id": "mobile_heading",
      "label": "Mobile heading",
      "default": "Still Have Questions?<br>Get In Touch"
    },
    {
      "type": "text",
      "id": "form_name_placeholder",
      "label": "Name field placeholder",
      "default": "Name"
    },
    {
      "type": "text",
      "id": "form_email_placeholder",
      "label": "Email field placeholder",
      "default": "Email"
    },
    {
      "type": "text",
      "id": "form_message_placeholder",
      "label": "Message field placeholder",
      "default": "Type your message..."
    },
    {
      "type": "checkbox",
      "id": "show_privacy_checkbox",
      "label": "Show privacy policy checkbox",
      "default": true
    },
    {
      "type": "text",
      "id": "privacy_label",
      "label": "Privacy checkbox label",
      "default": "I accept the Privacy Policy"
    },
    {
      "type": "text",
      "id": "submit_button_text",
      "label": "Submit button text",
      "default": "Send Message"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "color_primary",
      "label": "Primary text color",
      "default": "#102A43"
    },
    {
      "type": "color",
      "id": "color_secondary",
      "label": "Secondary text color",
      "default": "#102A43"
    },
    {
      "type": "paragraph",
      "content": "Secondary text uses 75% opacity of the color above."
    },
    {
      "type": "color",
      "id": "color_brand_blue",
      "label": "Brand blue (contact links)",
      "default": "#065BDC"
    },
    {
      "type": "color",
      "id": "color_brand_blue_light",
      "label": "Info box background",
      "default": "#E5EEFB"
    },
    {
      "type": "color",
      "id": "color_white",
      "label": "Mobile background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "color_card_bg",
      "label": "Card background",
      "default": "#FDFCFA"
    },
    {
      "type": "color",
      "id": "color_bg_from",
      "label": "Gradient start",
      "default": "#F8F4EE"
    },
    {
      "type": "color",
      "id": "color_bg_to",
      "label": "Gradient end",
      "default": "#FDFCFA"
    },
    {
      "type": "color",
      "id": "color_orange",
      "label": "Button color",
      "default": "#F07E3B"
    },
    {
      "type": "color",
      "id": "color_orange_dark",
      "label": "Button border color",
      "default": "#BF642F"
    },
    {
      "type": "color",
      "id": "color_input_bg",
      "label": "Input background",
      "default": "#F8F4EE"
    },
    {
      "type": "color",
      "id": "color_input_border",
      "label": "Input border",
      "default": "#DCD9D3"
    },
    {
      "type": "color",
      "id": "color_btn_text",
